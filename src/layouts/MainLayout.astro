---
import SiteFooter from "../components/site/SiteFooter.astro";
import SiteHeader from "../components/site/SiteHeader.astro";
import "../styles/layout.css";

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Aurora",
  "description": "Aurora calcula las consecuencias de una decisión antes de ejecutarla.",
  "url": "https://aurora-site.com"
};

const organizationJSON = JSON.stringify(organizationSchema);

interface Props {
  title?: string;
  description?: string;
  shell?: "default" | "landing";
}

const {
  title = "Aurora",
  description = "Aurora calcula las consecuencias de una decisión antes de ejecutarla.",
  shell = "default"
} = Astro.props;

const bodyClass = shell === "landing" ? "landing-shell" : "default-shell";
const currentPath = Astro.url.pathname;
const canonicalHref = new URL(currentPath, "https://aurora-site.com").toString();
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:type" content="website" />

    <link rel="canonical" href={canonicalHref} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" set:html={organizationJSON}></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <SiteHeader variant={shell} currentPath={currentPath} />

    <main id="top" class="site-main">
      <slot />
    </main>

    <SiteFooter variant={shell} currentPath={currentPath} />
  </body>
</html>
