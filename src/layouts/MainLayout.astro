---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = "Aurora",
  description = "Aurora: arquitectura de decisiones y cálculo soberano.",
  lang = "es",
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>
