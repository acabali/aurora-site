---
// Aurora — Infraestructura Decisional
// JSON-LD en frontmatter para evitar conflictos con esbuild

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Aurora",
  "description": "Infraestructura decisional que prueba decisiones antes de ejecutarlas",
  "url": "https://aurora-site.com",
  "logo": "https://aurora-site.com/aurora-logo.png"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué es Aurora?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Aurora prueba decisiones antes de ejecutarlas. Infraestructura decisional que integra datos, simula escenarios y ejecuta bajo umbrales controlados."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuál es la diferencia con BI tradicional?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "BI mira atrás (reportes históricos). Aurora mira adelante (simula futuros posibles). BI es descriptivo. Aurora es predictivo y ejecutable."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué es ejecución bajo umbrales?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Defines umbrales de riesgo. Si la decisión está bajo umbral, Aurora ejecuta automáticamente. Si está sobre umbral, requiere tu aprobación."
      }
    }
  ]
};

const organizationJSON = JSON.stringify(organizationSchema);
const faqJSON = JSON.stringify(faqSchema);
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Aurora | Infraestructura Decisional | Prueba Decisiones Antes de Ejecutarlas</title>
    <meta name="description" content="Aurora prueba decisiones antes de ejecutarlas. Infraestructura decisional que integra datos, simula escenarios y ejecuta bajo umbrales. Para PYME y emprendedores." />
    <meta name="keywords" content="Infrastructure decisional, Decision Intelligence, evaluador de decisiones, cálculo de riesgo empresarial, decisiones bajo evidencia" />

    <meta property="og:title" content="Aurora | Infraestructura Decisional" />
    <meta property="og:description" content="Prueba decisiones antes de ejecutarlas." />
    <meta property="og:url" content="https://aurora-site.com" />
    <meta property="og:type" content="website" />

    <link rel="canonical" href="https://aurora-site.com" />
    <link rel="alternate" hreflang="es" href="https://aurora-site.com" />
    <link rel="alternate" hreflang="en" href="https://aurora-site.com/en" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" set:html={organizationJSON}></script>
    <script type="application/ld+json" set:html={faqJSON}></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <slot name="head" />

    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      :root {
        --bg-dark: #0A0E27;
        --text-light: #F7F7F5;
        --text-muted: #BFC2C7;
        --accent-blue: #2E5BFF;
        --accent-green: #00C389;
        --accent-red: #FF3D3D;
        --border-light: rgba(46, 91, 255, 0.1);
        --border-green: rgba(0, 195, 137, 0.2);
        --border-red: rgba(255, 61, 61, 0.2);
      }
      body {
        background: var(--bg-dark);
        color: var(--text-light);
        font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        line-height: 1.6;
        overflow-x: hidden;
      }
      header {
        height: 80px;
        padding: 0 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid var(--border-light);
        position: sticky;
        top: 0;
        z-index: 1000;
        background: var(--bg-dark);
      }
      .header-left { display: flex; align-items: center; gap: 32px; }
      .logo { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; font-size: 32px; }
      .nav-trigger {
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--accent-blue);
        cursor: pointer;
        border: none;
        background: none;
        padding: 8px 0;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .nav-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        margin-top: 12px;
        background: rgba(46, 91, 255, 0.1);
        border: 1px solid var(--border-light);
        border-radius: 8px;
        padding: 12px;
        min-width: 240px;
        display: none;
        flex-direction: column;
        gap: 8px;
      }
      .nav-dropdown.active { display: flex; }
      .nav-dropdown-item {
        padding: 8px 12px;
        font-size: 14px;
        color: var(--text-light);
        cursor: pointer;
        border-radius: 4px;
        transition: background 200ms;
      }
      .nav-dropdown-item:hover { background: rgba(46, 91, 255, 0.2); }
      .nav-dropdown-label { font-weight: 600; color: var(--text-light); }
      .nav-dropdown-desc { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
      .header-right { display: flex; align-items: center; gap: 24px; }
      .nav-horizontal {
        display: flex;
        gap: 32px;
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--accent-green);
      }
      .nav-horizontal a { color: var(--accent-green); text-decoration: none; }
      .nav-horizontal a:hover { color: var(--text-light); }
      .particles {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100vh;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
      }
      .particle {
        position: absolute;
        border-radius: 50%;
        animation: float-particle linear infinite;
      }
      @keyframes float-particle {
        0% { transform: translateY(0) translateX(0); opacity: 0.3; }
        50% { opacity: 0.6; }
        100% { transform: translateY(-100vh) translateX(20px); opacity: 0.3; }
      }
      .particle.gray { background: var(--text-muted); }
      .particle.blue { background: var(--accent-blue); }
      .particle.green { background: var(--accent-green); }
      .particle.red { background: var(--accent-red); }
      main { position: relative; z-index: 1; }
      section { padding: 80px 24px; max-width: 1200px; margin: 0 auto; }
      .hero {
        max-width: 900px;
        margin: 0 auto;
        text-align: center;
        padding: 120px 24px;
      }
      h1 { font-size: 56px; line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 32px; font-weight: 700; }
      h2 { font-size: 42px; line-height: 1.3; margin-bottom: 24px; font-weight: 600; }
      h3 { font-size: 20px; font-weight: 600; margin-bottom: 12px; }
      p { font-size: 16px; color: var(--text-muted); margin-bottom: 16px; line-height: 1.7; }
      .accent-green { color: var(--accent-green); }
      .accent-blue { color: var(--accent-blue); }
      .accent-red { color: var(--accent-red); }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 48px;
        padding: 0 24px;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: all 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
        text-decoration: none;
      }
      .btn-primary { background: var(--accent-blue); color: var(--text-light); }
      .btn-primary:hover { box-shadow: 0 16px 32px rgba(46, 91, 255, 0.3); }
      .btn-secondary { background: transparent; color: var(--accent-blue); border: 1px solid var(--accent-blue); }
      .btn-secondary:hover { background: rgba(46, 91, 255, 0.1); }
      .buttons-group { display: flex; gap: 16px; justify-content: center; margin-top: 32px; }
      .grid-3 {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
        margin-top: 48px;
      }
      .grid-2x3 {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 24px;
        margin-top: 48px;
      }
      .card {
        padding: 32px;
        border-radius: 8px;
        border: 1px solid var(--border-light);
        background: rgba(46, 91, 255, 0.05);
        transition: all 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      .card:hover {
        box-shadow: 0 16px 32px rgba(46, 91, 255, 0.2);
        transform: translateY(-4px);
      }
      .card-icon { font-size: 32px; margin-bottom: 12px; }
      .card-title { font-size: 18px; font-weight: 600; margin-bottom: 12px; }
      .card-desc { font-size: 14px; color: var(--text-muted); margin-bottom: 16px; line-height: 1.6; }
      .card-example { font-size: 13px; color: var(--accent-green); margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border-light); }
      .governance-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-top: 48px;
      }
      .card-governance {
        padding: 20px;
        border-radius: 8px;
        border: 1px solid var(--border-red);
        background: rgba(255, 61, 61, 0.05);
      }
      .card-governance-label { font-weight: 600; color: var(--accent-red); margin-bottom: 8px; }
      .card-governance-text { font-size: 14px; color: var(--text-muted); line-height: 1.6; }
      .governance-table { margin-top: 32px; overflow-x: auto; }
      table { width: 100%; font-family: 'DM Mono', monospace; font-size: 13px; border-collapse: collapse; }
      table th { text-align: left; padding: 12px; border-bottom: 1px solid var(--border-light); color: var(--text-muted); font-weight: 600; }
      table td { padding: 12px; border-bottom: 1px solid var(--border-light); color: var(--text-light); }
      table tr:hover { background: rgba(46, 91, 255, 0.05); }
      .diagram {
        background: rgba(0, 195, 137, 0.05);
        border: 1px solid var(--border-green);
        border-radius: 8px;
        padding: 40px;
        margin-top: 48px;
        text-align: center;
        font-family: 'DM Mono', monospace;
        color: var(--accent-green);
        line-height: 2;
      }
      footer {
        border-top: 1px solid var(--border-light);
        padding: 40px 24px;
        background: var(--bg-dark);
      }
      .footer-content {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 40px;
        margin-bottom: 40px;
      }
      .footer-section h4 { font-size: 12px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-light); margin-bottom: 16px; }
      .footer-links { display: flex; flex-direction: column; gap: 8px; }
      .footer-link { color: var(--text-muted); text-decoration: none; font-size: 14px; transition: color 200ms; }
      .footer-link:hover { color: var(--text-light); }
      .footer-social { display: flex; gap: 16px; }
      .footer-bottom { text-align: center; color: var(--text-muted); font-size: 12px; padding-top: 24px; border-top: 1px solid var(--border-light); }
      @media (max-width: 768px) {
        h1 { font-size: 42px; }
        h2 { font-size: 32px; }
        header { padding: 0 16px; }
        .header-right { display: none; }
        .grid-3, .grid-2x3 { grid-template-columns: 1fr; }
        .buttons-group { flex-direction: column; }
        .btn { width: 100%; }
      }
    </style>
  </head>
  <body>
    <div class="particles" id="particles"></div>

    <header>
      <div class="header-left">
        <a href="/" class="logo">◧</a>
        <div class="nav-menu">
          <button class="nav-trigger" type="button" id="nav-trigger">PRODUCTOS ▼</button>
          <div class="nav-dropdown" id="nav-dropdown">
            <div class="nav-dropdown-item">
              <div class="nav-dropdown-label">AURORA CORE</div>
              <div class="nav-dropdown-desc">10 decisiones/mes</div>
            </div>
            <div class="nav-dropdown-item">
              <div class="nav-dropdown-label">AURORA PRO</div>
              <div class="nav-dropdown-desc">100 decisiones/mes</div>
            </div>
            <div class="nav-dropdown-item">
              <div class="nav-dropdown-label">AURORA ENTERPRISE</div>
              <div class="nav-dropdown-desc">Ilimitado + full governance</div>
            </div>
            <div class="nav-dropdown-item">
              <div class="nav-dropdown-label">AURORA ADVANCED</div>
              <div class="nav-dropdown-desc">Premium add-ons</div>
            </div>
          </div>
        </div>
      </div>
      <div class="header-right">
        <nav class="nav-horizontal">
          <a href="#sistema">SISTEMA</a>
          <a href="#aplicaciones">APLICACIONES</a>
          <a href="#demo">DEMO</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-content">
        <div class="footer-section">
          <h4>Producto</h4>
          <div class="footer-links">
            <a href="#sistema" class="footer-link">Sistema</a>
            <a href="#aplicaciones" class="footer-link">Aplicaciones</a>
            <a href="#demo" class="footer-link">Demo</a>
          </div>
        </div>
        <div class="footer-section">
          <h4>Empresa</h4>
          <div class="footer-links">
            <a href="#" class="footer-link">Pricing</a>
            <a href="#" class="footer-link">Governance</a>
            <a href="#" class="footer-link">Blog</a>
          </div>
        </div>
        <div class="footer-section">
          <h4>Social</h4>
          <div class="footer-social">
            <a href="https://linkedin.com/company/aurora" class="footer-link" target="_blank" rel="noopener">LinkedIn</a>
            <a href="https://twitter.com/aurora" class="footer-link" target="_blank" rel="noopener">Twitter</a>
            <a href="mailto:demo@aurora-site.com" class="footer-link">Email</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">© 2026 Aurora. Infraestructura decisional.</div>
    </footer>

    <script>
      document.getElementById('nav-trigger')?.addEventListener('click', (e) => {
        e.stopPropagation();
        document.getElementById('nav-dropdown')?.classList.toggle('active');
      });
      document.addEventListener('click', (e) => {
        if (!document.querySelector('.nav-menu')?.contains(e.target)) {
          document.getElementById('nav-dropdown')?.classList.remove('active');
        }
      });
      function scrollToSection(id) {
        document.getElementById(id)?.scrollIntoView({ behavior: 'smooth' });
      }
      function generateParticles() {
        const container = document.getElementById('particles');
        const colors = ['gray', 'blue', 'green', 'red'];
        for (let i = 0; i < 18; i++) {
          const p = document.createElement('div');
          p.className = `particle ${colors[Math.floor(Math.random() * colors.length)]}`;
          const size = Math.random() * 8 + 4;
          p.style.cssText = `width:${size}px;height:${size}px;left:${Math.random()*100}%;top:-20px;animation:float-particle ${40+Math.random()*40}s linear ${Math.random()*5}s infinite`;
          container?.appendChild(p);
        }
      }
      window.addEventListener('load', generateParticles);
    </script>
  </body>
</html>
