---
import SiteFooter from "../components/site/SiteFooter.astro";
import SiteHeader from "../components/site/SiteHeader.astro";
import "../styles/layout.css";

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Aurora",
  "description": "Aurora calcula las consecuencias de una decisión antes de ejecutarla.",
  "url": "https://aurora-site.com"
};

const organizationJSON = JSON.stringify(organizationSchema);

interface Props {
  title?: string;
  description?: string;
  shell?: "default" | "landing";
  locale?: "es" | "en";
  pathName?: string;
}

const {
  title = "Aurora",
  description = "Aurora calcula las consecuencias de una decisión antes de ejecutarla.",
  shell = "default",
  locale = "es",
  pathName = "/"
} = Astro.props;

const bodyClass = shell === "landing" ? "landing-shell" : "default-shell";
const siteUrl = "https://aurora-site.com";
const canonicalUrl = new URL(pathName, siteUrl).toString();
const esUrl = new URL(pathName.startsWith("/en") ? pathName.replace(/^\/en/, "") || "/" : pathName, siteUrl).toString();
const enUrl = new URL(pathName.startsWith("/en") ? pathName : pathName === "/demo" ? "/en/demo" : "/en", siteUrl).toString();
const demoHref = locale === "en" ? "/en/demo" : "/demo";
const homeHref = locale === "en" ? "/en" : "/";
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://aurora-site.com" />
    <meta property="og:type" content="website" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" set:html={organizationJSON}></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <SiteHeader variant={shell} locale={locale} demoHref={demoHref} homeHref={homeHref} />

    <main id="top" class="site-main">
      <slot />
    </main>

    <SiteFooter variant={shell} homeHref={homeHref} demoHref={demoHref} />
  </body>
</html>
