---
import SiteFooter from "../components/site/SiteFooter.astro";
import SiteHeader from "../components/site/SiteHeader.astro";
import "../styles/layout.css";
import { colors } from "../system/design/colors";
import { typography } from "../system/design/typography";
import { motion } from "../system/design/motion";

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Aurora",
  "description": "Aurora calculates the structural consequences of a decision before executing it.",
  "url": "https://aurora-site.com"
};

const organizationJSON = JSON.stringify(organizationSchema);

interface Props {
  title?: string;
  description?: string;
  shell?: "default" | "landing";
}

const {
  title = "Aurora | Decision Infrastructure",
  description = "Aurora calculates the structural consequences of a decision before executing it.",
  shell = "default"
} = Astro.props;

const bodyClass = shell === "landing" ? "landing-shell" : "default-shell";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://aurora-site.com" />
    <meta property="og:type" content="website" />

    <link rel="canonical" href="https://aurora-site.com" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" set:html={organizationJSON}></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    </noscript>

    <slot name="head" />

    <style define:vars={{
      bg: colors.bg,
      textPrimary: colors.text.primary,
      textSecondary: colors.text.secondary,
      accentBlue: colors.accent.blue,
      accentGreen: colors.accent.green,
      accentRed: colors.accent.red,
      ease: motion.ease,
      fontSans: typography.font.sans
    }}>
      :root {
        --color-bg: var(--bg);
        --color-text: var(--textPrimary);
        --color-text-secondary: var(--textSecondary);
        --color-accent-blue: var(--accentBlue);
        --color-accent-green: var(--accentGreen);
        --color-accent-red: var(--accentRed);
        --ease-aurora: var(--ease);
      }

      body {
        background: var(--color-bg);
        color: var(--color-text);
        margin: 0;
        font-family: var(--fontSans);
      }
    </style>
  </head>
  <body class={bodyClass}>
    <SiteHeader variant={shell} />

    <main id="top" class="site-main">
      <slot />
    </main>

    <SiteFooter variant={shell} />
  </body>
</html>
