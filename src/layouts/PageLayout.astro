---
import "../styles/global.css";
import DecisionField from "../components/system/DecisionField.astro";

interface Props {
  title?: string;
}

const { title = "Aurora" } = Astro.props;
const pagePath = Astro.url.pathname;
const pageDescription = "La era de construir con evidencia.";
const advancedSystems = [
  {
    key: "counterfactual",
    name: "Counterfactual Engine™",
    technical: "Modela escenarios alternativos con sensibilidad multivariable y umbrales de ruptura.",
    impact: "Reduce errores de inversión antes de que la decisión toque la operación.",
  },
  {
    key: "regime-shift",
    name: "Regime Shift Detector™",
    technical: "Detecta cambios de régimen en señales operativas mediante anomalías persistentes.",
    impact: "Acelera el cambio de estrategia cuando el contexto deja de responder a supuestos previos.",
  },
  {
    key: "entropy-map",
    name: "Decision Entropy Map™",
    technical: "Cuantifica dispersión causal y dependencia entre variables críticas.",
    impact: "Prioriza foco ejecutivo donde la incertidumbre destruye más valor.",
  },
] as const;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body
    data-page={pagePath === "/" ? "home" : pagePath.startsWith("/demo") ? "demo" : "site"}
    data-regime="unstable"
    data-state="unstable"
    data-algorithm="core"
  >
    <DecisionField />

    <header class="site-header">
      <div class="container-base site-header-inner" data-products-nav data-open="false">
        <a href="/" class="site-brand" aria-label="Aurora home">
          <img src="/brand/aurora-symbol.png" alt="" class="brand-symbol" />
          <span class="brand-word">Aurora</span>
        </a>
        <span class="site-nav-divider" aria-hidden="true">|</span>
        <button
          type="button"
          class="site-nav-trigger"
          data-products-trigger
          aria-controls="products-dropdown"
          aria-expanded="false"
        >
          Productos
        </button>
        <span class="site-nav-divider" aria-hidden="true">|</span>
        <a href="/demo" class="site-nav-link">Demo</a>

        <div id="products-dropdown" class="products-dropdown" data-products-panel hidden>
          <p class="products-dropdown-subtitle">Advanced Systems</p>
          <ul class="products-dropdown-list">
            {advancedSystems.map((system) => (
              <li class="products-item" data-product-key={system.key} data-active="false" tabindex="0">
                <p class="products-item-name">{system.name}</p>
                <p class="products-item-tech">{system.technical}</p>
                <p class="products-item-impact">{system.impact}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer id="contacto" class="site-footer">Aurora</footer>

    <script is:inline>
      const PRODUCTS_KEY = "__auroraProductsCleanup";
      const REGIME_KEY = "__auroraRegimeController";

      const mountProductsMenu = () => {
        const navRoot = document.querySelector("[data-products-nav]");
        if (!navRoot) return () => {};

        const trigger = navRoot.querySelector("[data-products-trigger]");
        const panel = navRoot.querySelector("[data-products-panel]");
        const items = Array.from(navRoot.querySelectorAll("[data-product-key]"));

        if (!trigger || !panel || items.length === 0) return () => {};

        let isOpen = false;

        const setProductFocus = (nextKey) => {
          if (nextKey) {
            document.body.dataset.productFocus = nextKey;
          } else {
            delete document.body.dataset.productFocus;
          }

          items.forEach((item) => {
            item.dataset.active = item.dataset.productKey === nextKey ? "true" : "false";
          });
        };

        const setOpen = (nextOpen) => {
          isOpen = nextOpen;
          navRoot.dataset.open = nextOpen ? "true" : "false";
          trigger.setAttribute("aria-expanded", nextOpen ? "true" : "false");
          panel.hidden = !nextOpen;
          if (!nextOpen) setProductFocus(null);
        };

        const onPointerEnter = () => setOpen(true);
        const onPointerLeave = () => setOpen(false);
        const onTriggerClick = () => setOpen(!isOpen);
        const onClickOutside = (event) => {
          if (isOpen && !navRoot.contains(event.target)) setOpen(false);
        };
        const onKeyDown = (event) => {
          if (event.key === "Escape" && isOpen) {
            setOpen(false);
            trigger.focus();
          }
        };

        navRoot.addEventListener("pointerenter", onPointerEnter);
        navRoot.addEventListener("pointerleave", onPointerLeave);
        trigger.addEventListener("click", onTriggerClick);
        document.addEventListener("pointerdown", onClickOutside);
        document.addEventListener("keydown", onKeyDown);

        const itemCleanups = items.map((item) => {
          const onEnter = () => {
            setOpen(true);
            setProductFocus(item.dataset.productKey ?? null);
          };
          const onLeave = () => {
            if (!panel.matches(":hover")) setProductFocus(null);
          };

          item.addEventListener("pointerenter", onEnter);
          item.addEventListener("focus", onEnter);
          item.addEventListener("pointerleave", onLeave);
          item.addEventListener("blur", onLeave);

          return () => {
            item.removeEventListener("pointerenter", onEnter);
            item.removeEventListener("focus", onEnter);
            item.removeEventListener("pointerleave", onLeave);
            item.removeEventListener("blur", onLeave);
          };
        });

        return () => {
          navRoot.removeEventListener("pointerenter", onPointerEnter);
          navRoot.removeEventListener("pointerleave", onPointerLeave);
          trigger.removeEventListener("click", onTriggerClick);
          document.removeEventListener("pointerdown", onClickOutside);
          document.removeEventListener("keydown", onKeyDown);
          itemCleanups.forEach((cleanup) => cleanup());
          setOpen(false);
        };
      };

      class RegimeController {
        constructor() {
          this.raf = 0;
          this.lastScrollY = window.scrollY;
          this.rawVelocity = 0;
          this.smoothVelocity = 0;
          this.bootAt = performance.now();
          this.sections = [];

          this.onScroll = this.onScroll.bind(this);
          this.onResize = this.onResize.bind(this);
          this.frame = this.frame.bind(this);

          window.addEventListener("scroll", this.onScroll, { passive: true, capture: true });
          window.addEventListener("resize", this.onResize, { passive: true });
          this.syncSections();
          this.update(performance.now());
          this.schedule();
        }

        destroy() {
          if (this.raf) {
            cancelAnimationFrame(this.raf);
            this.raf = 0;
          }
          window.removeEventListener("scroll", this.onScroll, true);
          window.removeEventListener("resize", this.onResize);
          delete document.body.dataset.scrollVelocity;
          delete document.body.dataset.binarySide;
        }

        syncSections() {
          this.sections = Array.from(document.querySelectorAll("[data-era-section]"));
        }

        onScroll() {
          const nextY = window.scrollY;
          this.rawVelocity = nextY - this.lastScrollY;
          this.lastScrollY = nextY;
          this.update(performance.now());
          this.schedule();
        }

        onResize() {
          this.syncSections();
          this.update(performance.now());
          this.schedule();
        }

        schedule() {
          if (this.raf) return;
          this.raf = requestAnimationFrame(this.frame);
        }

        frame(now) {
          this.raf = 0;
          this.smoothVelocity = this.smoothVelocity * 0.86 + this.rawVelocity * 0.14;
          this.rawVelocity *= 0.45;
          this.update(now);

          if (Math.abs(this.smoothVelocity) > 0.02) {
            this.schedule();
          }
        }

        update(now) {
          const phase = this.resolvePhase(now);
          document.body.dataset.regime = phase;
          document.body.dataset.state = phase;
          document.body.dataset.scrollVelocity = Math.abs(this.smoothVelocity).toFixed(3);
          this.syncBinaryBoundary();
        }

        resolvePhase(now) {
          if (window.location.pathname.startsWith("/demo")) {
            return "stabilized";
          }

          if (!this.sections.length) {
            const progress = Math.min(1, Math.max(0, (now - this.bootAt) / 3000));
            if (progress < 0.2) return "unstable";
            if (progress < 0.42) return "compressing";
            if (progress < 0.64) return "collision";
            if (progress < 0.82) return "rupture";
            return "reordering";
          }

          const targetY = window.innerHeight * 0.48;
          let bestSection = this.sections[0];
          let bestDistance = Number.POSITIVE_INFINITY;

          for (const section of this.sections) {
            const rect = section.getBoundingClientRect();
            const sectionCenter = rect.top + rect.height * 0.5;
            const distance = Math.abs(sectionCenter - targetY);
            if (distance < bestDistance) {
              bestDistance = distance;
              bestSection = section;
            }
          }

          return bestSection.dataset.eraPhase || "unstable";
        }

        syncBinaryBoundary() {
          const boundary = document.querySelector("[data-binary-boundary]");
          if (!boundary) {
            delete document.body.dataset.binarySide;
            return;
          }

          const rect = boundary.getBoundingClientRect();
          const numerator = window.innerHeight * 0.5 - rect.top;
          const progress = rect.height > 0 ? numerator / rect.height : -1;

          if (progress < 0 || progress > 1) {
            delete document.body.dataset.binarySide;
            return;
          }

          document.body.dataset.binarySide = progress < 0.5 ? "entropy" : "center";
        }
      }

      const boot = () => {
        if (window[PRODUCTS_KEY]) window[PRODUCTS_KEY]();
        if (window[REGIME_KEY]) window[REGIME_KEY].destroy();

        const controller = new RegimeController();
        window[PRODUCTS_KEY] = mountProductsMenu();
        window[REGIME_KEY] = controller;
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", boot, { once: true });
      } else {
        boot();
      }

      window.addEventListener(
        "pagehide",
        () => {
          if (window[PRODUCTS_KEY]) {
            window[PRODUCTS_KEY]();
            delete window[PRODUCTS_KEY];
          }
          if (window[REGIME_KEY]) {
            window[REGIME_KEY].destroy();
            delete window[REGIME_KEY];
          }
        },
        { once: true }
      );
    </script>
  </body>
</html>
