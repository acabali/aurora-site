---
import AuroraField from "../components/system/AuroraField.astro";
import "../styles/tokens.css";
import "../styles/global.css";

const { title = "Aurora", page = "home" } = Astro.props;

const buildMarker = import.meta.env.VERCEL_GIT_COMMIT_SHA || "dev";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=IBM+Plex+Sans:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body data-page={page} data-build={buildMarker} data-story="AURORA-VOMEGA">
    <header class="site-header" data-header>
      <div class="header-instrument">
        <a href="/" class="brand-lockup" aria-label="Aurora home">
          <img
            src="/aurora-logo.png"
            alt=""
            class="brand-mark"
            width="14"
            height="14"
            aria-hidden="true"
          />
          <span class="brand-name">AURORA</span>
        </a>
        <p class="header-readout" aria-hidden="true">SYSTEM INTERFACE</p>
      </div>

      <div class="header-controls">
        <a href="/demo" class="header-link">DEMO</a>
      </div>
    </header>

    <div class="site-shell">
      
  <AuroraField />
<slot />
    </div>
  </body>
</html>
