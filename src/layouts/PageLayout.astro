---
const { title = "Aurora" } = Astro.props;
const buildMarker = Date.now();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>

    <link rel="stylesheet" href="/src/styles/tokens.css" />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>

  <body data-build={buildMarker} data-story="AURORA-VOMEGA">

    <header class="site-header" data-header>
      <div class="header-left">
        <a href="/" class="brand" aria-label="Aurora">
          <img
            src="/aurora-logo.png"
            alt=""
            class="brand-logo"
            aria-hidden="true"
          />
          <span class="brand-name">AURORA</span>
        </a>
      </div>

      <nav class="site-nav" aria-label="Principal">
        <a href="/#field" class="header-link">FIELD</a>
        <a href="/#system" class="header-link">SYSTEM</a>
        <a href="/#engine" class="header-link">ENGINE</a>
        <a href="/#demo" class="header-link">DEMO</a>
      </nav>

      <div class="header-right">
        <span class="sys-status">SYS.ONLINE</span>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

  </body>
</html>
