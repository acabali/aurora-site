---
import "../styles/tokens.css";
import "../styles/global.css";

const { title = "Aurora", page = "home" } = Astro.props;

const buildMarker =
  import.meta.env?.VERCEL_GIT_COMMIT_SHA ??
  process.env?.VERCEL_GIT_COMMIT_SHA ??
  `${Date.now()}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body data-page={page} data-build={buildMarker} data-story="AURORA-VOMEGA">
    <header class="site-header" data-header>
      <div class="header-left">
        <a href="/" class="brand" aria-label="Aurora">
          <img
            src="/aurora-logo.png"
            alt=""
            class="brand-logo"
            width="14"
            height="14"
            aria-hidden="true"
          />
          <span class="brand-name">AURORA</span>
        </a>
      </div>

      <nav class="site-nav" aria-label="Principal">
        <a href="/#field" class="header-link">FIELD</a>
        <a href="/#system" class="header-link">SYSTEM</a>
        <a href="/#engine" class="header-link">ENGINE</a>
        <a href="/#demo" class="header-link">DEMO</a>
      </nav>

      <div class="header-right">
        <span class="sys-status">SYS.ONLINE</span>
      </div>
    </header>

    <div class="site-shell">
      <slot />
    </div>
  </body>
</html>
