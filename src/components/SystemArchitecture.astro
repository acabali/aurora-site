---
const layers = [
  {
    title: "Core",
    summary: "Concentra el cálculo basal del sistema y conserva consistencia entre lectura, huella y trazabilidad.",
    outputs: ["Aurora Core", "Signal", "Ledger"],
  },
  {
    title: "Motores",
    summary: "Evalúan presión estructural, escenarios, reversibilidad y huella decisional antes de ejecutar.",
    outputs: ["Scenario", "Risk", "Decision Evaluation Engine", "Counterfactual Engine", "Structural Pressure Detection", "Reversibility Mapping", "Decision Footprint"],
  },
  {
    title: "Superficie operativa",
    summary: "Expone la lectura del sistema en productos y soluciones concretas sin duplicar lógica en la web.",
    outputs: ["Demo", "Optimización de Costos", "Estrategia de Crecimiento", "Estrategia de Marketing", "Evaluación de Inversiones", "Soporte a Decisiones Clave", "Control de Caja y Runway"],
  },
];
---

<div class="system-architecture">
  {layers.map((layer) => (
    <article class="system-architecture__layer">
      <div class="system-architecture__label">{layer.title}</div>
      <div class="system-architecture__content">
        <p class="system-architecture__summary">{layer.summary}</p>
        <div class="system-architecture__outputs">
          {layer.outputs.map((item) => (
            <span class="system-architecture__chip">{item}</span>
          ))}
        </div>
      </div>
    </article>
  ))}
</div>

<style>
  .system-architecture {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }

  .system-architecture__layer {
    display: grid;
    grid-template-columns: 150px minmax(0, 1fr);
    gap: 1.2rem;
    padding: 1rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .system-architecture__label {
    color: var(--color-text);
    font: 600 12px/1 "Inter", sans-serif;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .system-architecture__content {
    display: grid;
    gap: 0.9rem;
  }

  .system-architecture__summary {
    margin: 0;
    color: rgba(244, 246, 242, 0.9);
    font-size: 17px;
    line-height: 1.6;
  }

  .system-architecture__outputs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .system-architecture__chip {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 0.8rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--color-text-secondary);
    font: 500 13px/1 "Inter", sans-serif;
  }

  @media (max-width: 768px) {
    .system-architecture__layer {
      grid-template-columns: minmax(0, 1fr);
      gap: 0.7rem;
    }
  }
</style>
