<div class="system-architecture">
  <div class="system-header">
    <span>SYSTEM ARCHITECTURE</span>
  </div>

  <div class="module-list">
    <div class="module-group">
      <h3>STRUCTURAL FIELD</h3>

      <div class="module-line">
        <span class="module-line__name">pressure</span>
        <span class="module-line__detail">Calculates structural pressure between decision variables.</span>
      </div>

      <div class="module-line">
        <span class="module-line__name">signal</span>
        <span class="module-line__detail">Identifies peripheral changes before they reorganize the field.</span>
      </div>

      <div class="module-line">
        <span class="module-line__name">scenario</span>
        <span class="module-line__detail">Contrasts structural futures before the plan enters execution.</span>
      </div>
    </div>

    <div class="module-group">
      <h3>RISK FIELD</h3>

      <div class="module-line">
        <span class="module-line__name">exposure</span>
        <span class="module-line__detail">Measures where the decision transfers load into vulnerable nodes.</span>
      </div>

      <div class="module-line">
        <span class="module-line__name">breakpoints</span>
        <span class="module-line__detail">Locates the thresholds where reversibility and stability collapse.</span>
      </div>
    </div>

    <div class="module-group">
      <h3>OPERATIVE FIELD</h3>

      <div class="module-line">
        <span class="module-line__name">ledger</span>
        <span class="module-line__detail">Stores execution memory so the next reading starts from reality.</span>
      </div>

      <div class="module-line">
        <span class="module-line__name">trace</span>
        <span class="module-line__detail">Preserves the path of structural changes across the system.</span>
      </div>

      <div class="module-line">
        <span class="module-line__name">monitoring</span>
        <span class="module-line__detail">Keeps the field readable while conditions continue to move.</span>
      </div>
    </div>
  </div>
</div>
