---
import { mountAuroraField } from "../../lib/homeField"
---

<div class="aurora-field" data-aurora-field aria-hidden="true">
  <canvas class="aurora-field-canvas" data-aurora-canvas></canvas>
</div>

<script type="module" client:load>

import { mountAuroraField } from "../../lib/homeField"

const root = document.querySelector("[data-aurora-field]")

if (root) {
  mountAuroraField(root)
}

</script>
