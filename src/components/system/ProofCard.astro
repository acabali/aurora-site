---
interface Props {
  label: string;
  value: string;
}

const { label, value } = Astro.props;
---

<div class="proof-card">
  <div class="proof-label">{label}</div>
  <div class="proof-value">{value}</div>
</div>

<style>
  .proof-card {
    padding: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.02);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .proof-label {
    font-family: "DM Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent-red, #ff3d3d);
    opacity: 0.8;
  }

  .proof-value {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text, #f7f7f5);
  }
</style>
