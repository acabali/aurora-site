<script type="module">

import {mountNeuralBackground} from "/src/lib/aurora/neural/background.ts"
import {mountCursorGravity} from "/src/lib/aurora/gravity/cursorGravity.ts"
import {mountTimeline} from "/src/lib/aurora/temporal/replay.ts"
import {ripple} from "/src/lib/aurora/ripple/ripple.ts"

const canvas=document.querySelector("[data-aurora-canvas]")

mountNeuralBackground()

if(canvas){
mountCursorGravity(canvas)
}

mountTimeline(document.body)

window.addEventListener("click",e=>{
ripple(e.clientX,e.clientY)
})

</script>
