---
interface Props {
  code: string;
  summary: string;
}

const { code, summary } = Astro.props;
---

<div class="decision-footprint">
  <div class="footprint-code">{code}</div>
  <div class="footprint-summary">{summary}</div>
</div>

<style>
  .decision-footprint {
    padding: 1.5rem;
    border-left: 2px solid var(--color-accent-blue, #2e5bff);
    background: rgba(46, 91, 255, 0.03);
  }

  .footprint-code {
    font-family: "DM Mono", monospace;
    font-size: 14px;
    letter-spacing: 0.1em;
    color: var(--color-accent-blue, #2e5bff);
    margin-bottom: 0.5rem;
  }

  .footprint-summary {
    font-size: 16px;
    line-height: 1.5;
    color: var(--color-text, #f7f7f5);
  }
</style>
