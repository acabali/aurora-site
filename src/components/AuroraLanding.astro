---
import AuroraField from "./AuroraField.astro";
import SystemArchitecture from "./SystemArchitecture.astro";
import SystemInterface from "./SystemInterface.astro";
---

<div class="aurora-page" data-aurora-page data-aurora-field-host>
  <div class="aurora-page__field" aria-hidden="true">
    <AuroraField />
  </div>

  <div class="legacy-aliases" aria-hidden="true">
    que-cambio desajuste aurora evaluates scenarios risk differentiation demo
  </div>

  <section class="hero" id="hero" data-aurora-section="hero" data-aurora-state="latent">
    <div class="hero-structure" aria-hidden="true"></div>

    <div class="hero-shell">
      <span class="section-kicker" data-reveal="line">DECISION INFRASTRUCTURE</span>
      <h1 data-reveal="line">El límite humano ya no alcanza.</h1>
      <div class="hero-body" data-reveal="line" data-reveal-delay="70">
        <p class="hero-subtitle">El mercado ya no compite con personas.</p>
        <p class="hero-subtitle">Compite con sistemas.</p>
        <p class="hero-subtitle">Quedarse en intuición</p>
        <p class="hero-subtitle">es quedar fuera del juego real.</p>
        <p class="hero-subtitle">Aurora no mejora decisiones.</p>
        <p class="hero-subtitle">Desplaza el límite humano por el cálculo permanente.</p>
        <p class="hero-subtitle">No es digitalización.</p>
        <p class="hero-subtitle">Es sustitución operativa.</p>
      </div>

      <div class="hero-cta-row" data-reveal data-reveal-delay="160">
        <a href="/demo" class="cta-link">→ Poner una decisión bajo evidencia</a>
      </div>
    </div>
  </section>

  <section class="section" id="context" data-aurora-section="context" data-aurora-state="activation">
    <div class="section-grid section-grid--intro">
      <div class="section-rail">
        <span class="section-kicker" data-reveal="line">Context</span>
      </div>

      <div class="section-copy">
        <h2 data-reveal="line">Critical decisions fail when variables move faster than the plan.</h2>
        <p class="section-lead" data-reveal="line" data-reveal-delay="60">The problem is structural interaction, not missing information.</p>
        <p data-reveal="line" data-reveal-delay="120">Cost. Demand. Regulation. Timing. Each variable changes the pressure on every other variable.</p>
      </div>
    </div>
  </section>

  <section class="section" id="aurora-operating" data-aurora-section="aurora-operating" data-aurora-state="tension">
    <div class="section-grid section-grid--interface">
      <div class="section-rail">
        <span class="section-kicker" data-reveal="line">Aurora Operating</span>
      </div>

      <div class="section-copy section-copy--full">
        <h2 data-reveal="line">Aurora reads the decision while the field is still under pressure.</h2>
        <p class="section-lead" data-reveal="line" data-reveal-delay="60">
          The interface does not describe software. It exposes an active system reading.
        </p>

        <div data-reveal data-reveal-delay="140">
          <SystemInterface />
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="system-architecture" data-aurora-section="system-architecture" data-aurora-state="order">
    <div class="section-grid section-grid--architecture">
      <div class="section-rail">
        <span class="section-kicker" data-reveal="line">Architecture</span>
      </div>

      <div class="section-copy section-copy--full">
        <h2 data-reveal="line">Aurora is organized as system modules, not a commercial feature grid.</h2>
        <p data-reveal="line" data-reveal-delay="70">
          Each module calculates one part of the decision field and returns a coherent operational surface.
        </p>

        <div data-reveal data-reveal-delay="140">
          <SystemArchitecture />
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="decision-entry" data-aurora-section="decision-entry" data-aurora-state="contextual">
    <div class="section-grid section-grid--entry">
      <div class="section-rail">
        <span class="section-kicker" data-reveal="line">Decision Entry</span>
      </div>

      <div class="section-copy section-copy--full">
        <h2 data-reveal="line">What decision do you want to evaluate?</h2>
        <p data-reveal="line" data-reveal-delay="50">
          Enter through a decision surface and move directly into the system demo.
        </p>

        <div class="decision-entry-list" data-reveal data-reveal-delay="80">
          <a href="/demo" class="decision-entry-link">Reduce costs</a>
          <a href="/demo" class="decision-entry-link">Invest in growth</a>
          <a href="/demo" class="decision-entry-link">Change go-to-market strategy</a>
          <a href="/demo" class="decision-entry-link">Evaluate runway</a>
          <a href="/demo" class="decision-entry-link">Other decision</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-demo" id="demo" data-aurora-section="demo" data-aurora-state="comparison">
    <div class="section-grid section-grid--demo">
      <div class="section-rail">
        <span class="section-kicker" data-reveal="line">Demo</span>
      </div>

      <div class="section-copy">
        <h2 data-reveal="line">Submit a decision to calculation.</h2>
        <p class="section-lead" data-reveal="line" data-reveal-delay="60">Evaluate a real plan before execution.</p>
        <p data-reveal="line" data-reveal-delay="120">
          The demo registers movement, locates the pressure point and returns a deterministic structural reading.
        </p>

        <div class="hero-cta-row hero-cta-row--section" data-reveal data-reveal-delay="180">
          <a href="/demo" class="cta-link">See how Aurora works</a>
        </div>
      </div>

      <div class="demo-output" data-reveal data-reveal-delay="160" aria-label="Aurora demo signals">
        <div class="demo-output__title">AURORA DEMO SIGNAL</div>
        <p>registering movement</p>
        <p>mapping structural variables</p>
        <p>locating pressure point</p>
        <div class="demo-output__divider"></div>
        <p>system reading</p>
        <p>decision_id: AUR-4931</p>
        <p>protocol: vΩ</p>
        <p>structural load: elevated</p>
        <p>pressure point: day 32</p>
        <p>compression mechanism: restricted absorption + partial reversibility</p>
        <p>run_signature: 9af31d</p>
        <p class="demo-output__state">movement recorded</p>
      </div>
    </div>
  </section>
</div>

<style>
  .aurora-page {
    position: relative;
    isolation: isolate;
    min-height: 100vh;
    color: var(--color-text);
    --duration-reveal: 360ms;
    --duration-reveal-line: 240ms;
    --duration-reveal-strong: 520ms;
    --max-page: 1180px;
    --max-copy: 820px;
  }

  .aurora-page__field {
    position: sticky;
    top: 0;
    height: 100svh;
    margin-bottom: -100svh;
    z-index: 0;
    pointer-events: none;
  }

  .aurora-page > :not(.aurora-page__field) {
    position: relative;
    z-index: 1;
  }

  .legacy-aliases {
    display: none;
  }

  .hero,
  .section {
    position: relative;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .hero {
    min-height: calc(100svh - 80px);
    padding: 96px 24px 108px;
    border-top: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }

  .hero::before,
  .hero::after,
  .hero-structure::before,
  .hero-structure::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero::before {
    background:
      linear-gradient(180deg, rgba(11, 11, 12, 0.06), rgba(11, 11, 12, 0)),
      radial-gradient(circle at 44% 42%, rgba(247, 247, 245, 0.04), transparent 30%);
  }

  .hero::after {
    background: radial-gradient(circle at 50% 46%, transparent 0 34%, rgba(11, 11, 12, 0.3) 68%, rgba(11, 11, 12, 0.84) 100%);
  }

  .hero-structure::before {
    background:
      radial-gradient(circle at 50% 44%, rgba(46, 91, 255, 0.08), transparent 30%),
      radial-gradient(circle at 52% 38%, rgba(247, 247, 245, 0.03), transparent 42%);
    opacity: 0.82;
  }

  .hero-structure::after {
    inset: 20% 17% 14%;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.04);
    transform: scaleY(0.78);
    opacity: 0.28;
  }

  .hero-shell,
  .section-grid {
    width: min(var(--max-page), 100%);
    margin: 0 auto;
  }

  .hero-shell {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 1.35rem;
    max-width: 760px;
  }

  .section {
    padding: 112px 24px;
  }

  .section-grid {
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    gap: 3rem;
    align-items: start;
  }

  .section-grid--demo {
    grid-template-columns: 180px minmax(0, 1fr) minmax(280px, 360px);
  }

  .section-rail {
    padding-top: 0.25rem;
  }

  .section-copy {
    display: grid;
    gap: 1rem;
    max-width: var(--max-copy);
  }

  .section-copy--full {
    max-width: 100%;
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0;
    color: var(--color-accent-green);
    font: 500 11px/1 "DM Mono", monospace;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .section-kicker::before {
    content: "";
    width: 32px;
    height: 1px;
    background: rgba(0, 195, 137, 0.42);
  }

  .hero h1,
  .section-copy h2 {
    margin: 0;
    color: var(--color-text);
    text-wrap: balance;
  }

  .hero h1 {
    max-width: 8.6ch;
    font-size: clamp(50px, 7vw, 86px);
    line-height: 0.98;
    letter-spacing: -0.05em;
    font-weight: 700;
  }

  .section-copy h2 {
    max-width: 16ch;
    font-size: clamp(34px, 4.8vw, 56px);
    line-height: 1.04;
    letter-spacing: -0.045em;
    font-weight: 700;
  }

  .hero-subtitle,
  .section-copy p,
  .demo-output p {
    margin: 0;
    color: var(--color-text-secondary);
  }

  .hero-body {
    display: grid;
    gap: 0.2rem;
    max-width: 32ch;
  }

  .hero-subtitle {
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.34;
    color: rgba(247, 247, 245, 0.9);
    letter-spacing: -0.025em;
  }

  .section-lead {
    max-width: 28ch;
    color: var(--color-text) !important;
    font-size: 22px !important;
    line-height: 1.34 !important;
    letter-spacing: -0.025em;
    font-weight: 500;
  }

  .hero-cta-row {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    margin-top: 1rem;
  }

  .hero-cta-row--section {
    margin-top: 1.6rem;
  }

  .cta-link,
  .decision-entry-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    color: rgba(247, 247, 245, 0.96);
    text-decoration: none;
    transition: color 240ms var(--ease-aurora), transform 240ms var(--ease-aurora);
  }

  .cta-link {
    min-height: 40px;
    padding: 0.35rem 0 0.65rem;
    font: 500 18px/1.3 "DM Sans", sans-serif;
    letter-spacing: 0.02em;
  }

  .cta-link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -6px;
    height: 1px;
    background: rgba(247, 247, 245, 0.48);
    transform: scaleX(0.58);
    transform-origin: center;
    transition: transform 240ms var(--ease-aurora), background 240ms var(--ease-aurora);
  }

  .cta-link:hover::after,
  .cta-link:focus-visible::after {
    transform: scaleX(1);
    background: rgba(247, 247, 245, 0.76);
  }

  .decision-entry-list {
    display: grid;
    gap: 0;
    margin-top: 1rem;
  }

  .decision-entry-link {
    padding: 1rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font: 500 18px/1.4 "DM Sans", sans-serif;
    letter-spacing: -0.01em;
  }

  .decision-entry-link:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .decision-entry-link:hover,
  .decision-entry-link:focus-visible {
    transform: translateX(6px);
    color: var(--color-text);
  }

  .demo-output {
    display: grid;
    gap: 0.25rem;
    align-content: start;
    padding-top: 0.2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .demo-output__title {
    margin-bottom: 0.7rem;
    color: var(--color-text);
    font: 500 10px/1 "DM Mono", monospace;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .demo-output p {
    font: 400 12px/1.6 "DM Mono", monospace;
    letter-spacing: 0.04em;
  }

  .demo-output__divider {
    height: 1px;
    margin: 0.8rem 0;
    background: rgba(255, 255, 255, 0.08);
  }

  .demo-output__state {
    margin-top: 0.5rem !important;
    color: var(--color-accent-green) !important;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(12px);
    filter: blur(3px);
    transition:
      opacity var(--duration-reveal) var(--ease-aurora),
      transform var(--duration-reveal) var(--ease-aurora),
      filter var(--duration-reveal) var(--ease-aurora);
  }

  [data-reveal="line"] {
    opacity: 0;
    transform: translateY(8px);
    filter: blur(2px);
    transition:
      opacity var(--duration-reveal-line) var(--ease-aurora),
      transform var(--duration-reveal-line) var(--ease-aurora),
      filter var(--duration-reveal-line) var(--ease-aurora);
  }

  [data-reveal="strong"] {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity var(--duration-reveal-strong) var(--ease-aurora),
      transform var(--duration-reveal-strong) var(--ease-aurora);
  }

  [data-reveal].is-visible,
  [data-reveal="line"].is-visible,
  [data-reveal="strong"].is-visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  @media (max-width: 1120px) {
    .section-grid,
    .section-grid--demo {
      grid-template-columns: minmax(0, 1fr);
      gap: 1.8rem;
    }

    .section-rail {
      padding-top: 0;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 60px 20px 76px;
    }

    .section {
      padding: 92px 20px;
    }

    .hero h1 {
      font-size: clamp(40px, 9vw, 58px);
    }

    .hero-subtitle,
    .section-lead {
      font-size: 20px !important;
    }
  }

  @media (max-width: 767px) {
    .hero {
      padding: 40px 18px 58px;
      min-height: min(72svh, 620px);
    }

    .hero h1 {
      max-width: 9.2ch;
      font-size: clamp(34px, 11vw, 46px);
    }

    .hero-subtitle {
      max-width: 22ch;
      font-size: 18px !important;
    }

    .cta-link,
    .decision-entry-link {
      font-size: 17px;
    }

    .section-copy h2 {
      max-width: 13ch;
      font-size: clamp(30px, 9vw, 42px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal="line"],
    [data-reveal="strong"] {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }

    .cta-link,
    .decision-entry-link {
      transition: none;
    }
  }
</style>

<script>
  const revealTargets = Array.from(document.querySelectorAll('[data-reveal]'));
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if ('IntersectionObserver' in window && !prefersReducedMotion) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const delay = parseInt((entry.target as HTMLElement).dataset.revealDelay || '0', 10);
            if (delay > 0) {
              setTimeout(() => entry.target.classList.add('is-visible'), delay);
            } else {
              entry.target.classList.add('is-visible');
            }
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -48px 0px' }
    );

    revealTargets.forEach((el) => observer.observe(el));
  } else {
    revealTargets.forEach((el) => el.classList.add('is-visible'));
  }
</script>
