---
---

<div class="aurora-page">
  <section class="hero">
    <div class="hero-structure" aria-hidden="true">
      <div class="hero-grid"></div>
    </div>

    <div class="hero-content">
      <h1 data-reveal="line">La mente humana tiene un límite.<br />La realidad no.</h1>

      <p data-reveal="line" data-reveal-delay="80">
        El mercado ya no compite con personas.<br />
        Compite con sistemas.
      </p>

      <p class="hero-thesis" data-reveal="line" data-reveal-delay="200">
        El cálculo reemplaza la interpretación.
      </p>

      <p data-reveal="line" data-reveal-delay="320">
        Aurora introduce esa capacidad.
      </p>

      <p data-reveal="line" data-reveal-delay="400">
        No es digitalización.
      </p>

      <p class="hero-emphasis" data-reveal="line" data-reveal-delay="460">
        Es sustitución operativa.
      </p>

      <div class="hero-cta-row" data-reveal data-reveal-delay="560">
        <a href="#aurora" class="cta-button">→ See how Aurora works</a>
      </div>
    </div>
  </section>

  <section class="section section-1" id="que-cambio">
    <div class="section-inner">
      <h2 data-reveal="line">Qué cambió</h2>

      <p data-reveal="line" data-reveal-delay="0">La forma de operar cambió.</p>
      <p data-reveal="line" data-reveal-delay="60">Ver la estructura de un movimiento antes de actuar ya es posible.</p>

      <p class="gap-top" data-reveal="line" data-reveal-delay="0">No es optimización.</p>
      <p class="text-accent-blue text-bold" data-reveal="line" data-reveal-delay="80">Es condición de entrada.</p>

      <p data-reveal="line" data-reveal-delay="0">La precisión define quién compite.</p>
    </div>
  </section>

  <section class="section section-2" id="desajuste">
    <div class="section-inner">
      <h2 data-reveal="line">Desajuste</h2>

      <p data-reveal="line" data-reveal-delay="0">El mercado ya no opera a velocidad humana.</p>
      <p data-reveal="line" data-reveal-delay="60">Opera sobre movimientos.</p>
      <p data-reveal="line" data-reveal-delay="120">Movimientos que comprometen recursos, cierran posiciones y activan consecuencias.</p>

      <p class="gap-top" data-reveal="line" data-reveal-delay="0">Añadir más interpretación no aumenta capacidad.</p>
      <p class="text-accent-red text-bold" data-reveal="line" data-reveal-delay="120">Aumenta retraso.</p>

      <p class="gap-top" data-reveal="line" data-reveal-delay="0">La ventaja ya no es crecer.</p>
      <p class="text-accent-blue text-bold" data-reveal="line" data-reveal-delay="60">Es ver la estructura antes de entrar en ella.</p>
    </div>
  </section>

  <section class="section section-rupture" id="ruptura">
    <div class="section-inner">
      <h2 data-reveal="line">Ruptura</h2>

      <div class="rupture-container">
        <div class="rupture-before">
          <h3 class="rupture-label rupture-label--before" data-reveal="line" data-reveal-delay="0">Antes</h3>
          <p class="rupture-item rupture-item--muted" data-reveal="line" data-reveal-delay="60">El error se absorbía.</p>
          <p class="rupture-item rupture-item--muted" data-reveal="line" data-reveal-delay="120">El ajuste era posterior.</p>
        </div>

        <div class="rupture-divider" data-reveal data-reveal-delay="200"></div>

        <div class="rupture-after">
          <h3 class="rupture-label rupture-label--after" data-reveal="line" data-reveal-delay="260">Hoy</h3>
          <p class="rupture-item rupture-key" data-reveal="strong" data-reveal-delay="340">El cálculo reemplaza la interpretación.</p>
          <p class="rupture-item" data-reveal="line" data-reveal-delay="480">El mercado ejecuta con cálculo continuo.</p>
        </div>
      </div>

      <p class="gap-top" data-reveal="line" data-reveal-delay="0">No es transformación digital.</p>
      <p class="text-accent-blue text-bold" data-reveal="line" data-reveal-delay="60">Es cambio de estándar.</p>
    </div>
  </section>

  <section class="section section-definition" id="aurora">
    <div class="section-inner">
      <h2 data-reveal="line">Aurora</h2>

      <p data-reveal="line" data-reveal-delay="0">Aurora introduce cálculo sobre los movimientos.</p>
      <p data-reveal="line" data-reveal-delay="60">La interpretación humana ya no alcanza.</p>

      <p class="gap-top text-bold" data-reveal="line" data-reveal-delay="0">Aurora no mejora el juicio.</p>
      <p class="text-accent-blue text-bold" data-reveal="line" data-reveal-delay="60">Lo reemplaza.</p>
    </div>
  </section>

  <section class="section section-demo" id="demo">
    <div class="section-inner section-inner--centered">
      <h2 data-reveal="line">Demo</h2>

      <p data-reveal="line" data-reveal-delay="60">Pon tu próximo movimiento bajo cálculo.</p>
      <p data-reveal="line" data-reveal-delay="120">Aurora no opina. Calcula.</p>
      <p data-reveal="line" data-reveal-delay="180">Detecta la interacción dominante. Expone la vulnerabilidad central.</p>
      <p class="text-bold" data-reveal="line" data-reveal-delay="260">Una señal. Un movimiento correcto.</p>

      <div class="hero-cta-row" data-reveal data-reveal-delay="360">
        <a href="/demo" class="cta-button">→ Explore Aurora</a>
      </div>
    </div>
  </section>
</div>

<style>
  .aurora-page {
    min-height: 100vh;
    color: var(--color-text);
    --duration-reveal: 350ms;
    --duration-reveal-line: 220ms;
    --duration-reveal-strong: 520ms;
  }

  .hero {
    position: relative;
    padding: 128px 24px 140px;
    overflow: hidden;
  }

  .hero-structure {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(46, 91, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(46, 91, 255, 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 20%, transparent 70%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 0 auto;
    text-align: center;
  }

  .hero h1 {
    margin: 0;
    font-size: 58px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  .hero p {
    margin-top: 1.25rem;
    margin-bottom: 0;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .hero-thesis {
    font-size: 21px;
    font-weight: 500;
    color: var(--color-text) !important;
    letter-spacing: -0.015em;
    line-height: 1.35;
    margin-top: 2.75rem !important;
    margin-bottom: 2.25rem !important;
  }

  .hero-emphasis {
    font-weight: 600;
    color: var(--color-text) !important;
  }

  .hero-cta-row {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 2.5rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 20px;
    border-radius: 6px;
    text-decoration: none;
    font: 600 15px/1 "DM Sans", sans-serif;
    letter-spacing: 0.01em;
    transition:
      transform 250ms var(--ease-aurora),
      box-shadow 250ms var(--ease-aurora);
    background: var(--color-accent-blue);
    color: var(--color-text);
  }

  .cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 28px rgba(46, 91, 255, 0.3);
  }

  .section {
    padding: 112px 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .section-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .section-inner--centered {
    text-align: center;
  }

  .section h2 {
    margin: 0 0 2.5rem;
    font-size: 28px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: var(--color-text);
  }

  .section p {
    margin: 0 0 1.5rem;
    max-width: 760px;
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-size: 16px;
  }

  .gap-top {
    margin-top: 2.5rem !important;
  }

  .text-bold {
    font-weight: 600;
    color: var(--color-text);
  }

  .text-accent-blue {
    color: var(--color-accent-blue) !important;
  }

  .text-accent-red {
    color: var(--color-accent-red) !important;
  }

  .rupture-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 2.5rem;
    margin: 3.5rem 0;
    padding: 2.5rem 2rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .rupture-before,
  .rupture-after {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .rupture-label {
    margin: 0;
    font-size: 13px;
    font-family: "DM Mono", monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .rupture-label--before {
    color: var(--color-accent-red);
    opacity: 0.7;
  }

  .rupture-label--after {
    color: var(--color-accent-green);
  }

  .rupture-item {
    margin: 0;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .rupture-item--muted {
    opacity: 0.45;
  }

  .rupture-key {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--color-text) !important;
    opacity: 1 !important;
  }

  .rupture-divider {
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(46, 91, 255, 0.4), transparent);
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(12px);
    filter: blur(3px);
    transition:
      opacity var(--duration-reveal) var(--ease-aurora),
      transform var(--duration-reveal) var(--ease-aurora),
      filter var(--duration-reveal) var(--ease-aurora);
  }

  [data-reveal="line"] {
    opacity: 0;
    transform: translateY(8px);
    filter: blur(2px);
    transition:
      opacity var(--duration-reveal-line) var(--ease-aurora),
      transform var(--duration-reveal-line) var(--ease-aurora),
      filter var(--duration-reveal-line) var(--ease-aurora);
  }

  [data-reveal="strong"] {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity var(--duration-reveal-strong) var(--ease-aurora),
      transform var(--duration-reveal-strong) var(--ease-aurora);
  }

  [data-reveal].is-visible,
  [data-reveal="line"].is-visible,
  [data-reveal="strong"].is-visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal="line"],
    [data-reveal="strong"] {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 80px 24px 96px;
    }

    .hero h1 {
      font-size: 36px;
    }

    .hero-thesis {
      font-size: 18px;
    }

    .section {
      padding: 80px 24px;
    }

    .rupture-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .rupture-divider {
      display: none;
    }
  }
</style>

<script>
  const revealTargets = Array.from(document.querySelectorAll('[data-reveal]'));

  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const delay = parseInt((entry.target as HTMLElement).dataset.revealDelay || '0', 10);
            if (delay > 0) {
              setTimeout(() => entry.target.classList.add('is-visible'), delay);
            } else {
              entry.target.classList.add('is-visible');
            }
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    revealTargets.forEach((el) => observer.observe(el));
  } else {
    revealTargets.forEach((el) => el.classList.add('is-visible'));
  }
</script>
