---
---

<div class="aurora-page" id="top">
  <header class="header">
    <div class="header-left">
      <a href="/" class="logo-link" aria-label="Aurora home">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 24a12 12 0 0 1 24 0" stroke="var(--color-text)" stroke-width="6" stroke-linecap="square"/>
          <path d="M36 24a12 12 0 0 1-12 12" stroke="var(--color-text)" stroke-width="6" stroke-linecap="square"/>
        </svg>
      </a>
    </div>

    <nav class="nav" aria-label="Primary navigation">
      <a href="/demo">DEMO</a>
    </nav>
  </header>

  <main>
    <section class="hero">
      <div class="hero-structure" aria-hidden="true">
        <div class="hero-grid"></div>
      </div>

      <div class="hero-content">
        <h1 data-reveal="line">The environment has already surpassed human anticipation capacity.</h1>

        <p data-reveal="line" data-reveal-delay="80">
          The market no longer competes with people.<br />
          It competes with systems.
        </p>

        <p class="hero-thesis" data-reveal="line" data-reveal-delay="200">
          Calculation replaces interpretation.
        </p>

        <p data-reveal="line" data-reveal-delay="320">
          Aurora introduces that capability.
        </p>

        <p data-reveal="line" data-reveal-delay="400">
          It is not digitalization.
        </p>

        <p class="hero-emphasis" data-reveal="line" data-reveal-delay="460">
          It is operational substitution.
        </p>

        <div class="hero-cta-row" data-reveal data-reveal-delay="560">
          <a href="/demo" class="cta-button">→ Put a move under calculation</a>
        </div>
      </div>
    </section>

    <section class="section section-products">
      <div class="section-inner">
        <h2 data-reveal="line">Infrastructure</h2>
        <div class="product-cards-mini">
          <div class="product-card-mini" data-reveal="line" data-reveal-delay="100">
            <h3>Aurora Core</h3>
            <p>Structural dependency mapping.</p>
            <a href="/products">Explore →</a>
          </div>
          <div class="product-card-mini" data-reveal="line" data-reveal-delay="200">
            <h3>Scenario</h3>
            <p>Dynamic strategic simulation.</p>
            <a href="/products">Explore →</a>
          </div>
          <div class="product-card-mini" data-reveal="line" data-reveal-delay="300">
            <h3>Risk</h3>
            <p>Structural exposure quantification.</p>
            <a href="/products">Explore →</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-1" id="what-changed">
      <div class="section-inner">
        <h2 data-reveal="line">What Changed</h2>

        <p data-reveal="line" data-reveal-delay="0">The way we operate has changed.</p>
        <p data-reveal="line" data-reveal-delay="60">Seeing the structure of a movement before acting is now possible.</p>

        <p class="gap-top" data-reveal="line" data-reveal-delay="0">This is not optimization.</p>
        <p class="text-accent-blue text-bold" data-reveal="line" data-reveal-delay="80">It is an entry condition.</p>

        <p data-reveal="line" data-reveal-delay="0">Precision defines who competes.</p>
      </div>
    </section>

    <section class="section section-2" id="misalignment">
      <div class="section-inner">
        <h2 data-reveal="line">Misalignment</h2>

        <p data-reveal="line" data-reveal-delay="0">The market no longer operates at human speed.</p>
        <p data-reveal="line" data-reveal-delay="60">It operates on movements.</p>
        <p data-reveal="line" data-reveal-delay="120">Movements that commit resources, close positions, and trigger consequences.</p>

        <p class="gap-top" data-reveal="line" data-reveal-delay="0">Adding more interpretation does not increase capability.</p>
        <p class="text-accent-red text-bold" data-reveal="line" data-reveal-delay="120">It increases delay.</p>

        <p class="gap-top" data-reveal="line" data-reveal-delay="0">The advantage is no longer growth.</p>
        <p class="text-accent-blue text-bold" data-reveal="line" data-reveal-delay="60">It is seeing the structure before entering it.</p>

        <p data-reveal="line" data-reveal-delay="0">The market rewards those who operate with calculation. The rest learn by consequence.</p>
      </div>
    </section>

    <section class="section section-rupture" id="rupture">
      <div class="section-inner">
        <h2 data-reveal="line">Breakpoint</h2>

        <div class="rupture-container">
          <div class="rupture-before">
            <h3 class="rupture-label rupture-label--before" data-reveal="line" data-reveal-delay="0">Before</h3>
            <p class="rupture-item rupture-item--muted" data-reveal="line" data-reveal-delay="60">Errors were absorbed.</p>
            <p class="rupture-item rupture-item--muted" data-reveal="line" data-reveal-delay="120">Adjustments were retrospective.</p>
          </div>

          <div class="rupture-divider" data-reveal data-reveal-delay="200"></div>

          <div class="rupture-after">
            <h3 class="rupture-label rupture-label--after" data-reveal="line" data-reveal-delay="260">Today</h3>
            <p class="rupture-item rupture-key" data-reveal="strong" data-reveal-delay="340">Calculation replaces interpretation.</p>
            <p class="rupture-item" data-reveal="line" data-reveal-delay="480">The market executes with continuous calculation.</p>
          </div>
        </div>

        <p class="gap-top" data-reveal="line" data-reveal-delay="0">It is not digital transformation.</p>
        <p class="text-accent-blue text-bold" data-reveal="line" data-reveal-delay="60">It is a standard shift.</p>
      </div>
    </section>

    <section class="section section-definition" id="aurora">
      <div class="section-inner">
        <h2 data-reveal="line">Aurora</h2>

        <p data-reveal="line" data-reveal-delay="0">Aurora introduces calculation over movements.</p>
        <p data-reveal="line" data-reveal-delay="60">Human interpretation is no longer sufficient.</p>

        <p class="gap-top text-bold" data-reveal="line" data-reveal-delay="0">Aurora does not improve judgment.</p>
        <p class="text-accent-blue text-bold" data-reveal="line" data-reveal-delay="60">It replaces it.</p>
      </div>
    </section>

    <section class="section section-solutions">
      <div class="section-inner">
        <h2 data-reveal="line">Applied Solutions</h2>
        <div class="solutions-grid-mini">
          <div class="solution-card-mini" data-reveal="line" data-reveal-delay="100">
            <h3>Cost Optimization</h3>
            <p>Structural waste elimination.</p>
          </div>
          <div class="solution-card-mini" data-reveal="line" data-reveal-delay="200">
            <h3>Growth Strategy</h3>
            <p>High-probability expansion.</p>
          </div>
          <div class="solution-card-mini" data-reveal="line" data-reveal-delay="300">
            <h3>Investment Evaluation</h3>
            <p>Stress-testing commitments.</p>
          </div>
        </div>
        <div class="hero-cta-row" data-reveal data-reveal-delay="400">
          <a href="/solutions" class="cta-button secondary">View all solutions</a>
        </div>
      </div>
    </section>

    <section class="section section-demo" id="demo">
      <div class="section-inner section-inner--centered">
        <h2 data-reveal="line">Demo</h2>

        <p data-reveal="line" data-reveal-delay="60">Put your next move under calculation.</p>
        <p data-reveal="line" data-reveal-delay="120">Aurora does not provide opinions. It calculates.</p>
        <p data-reveal="line" data-reveal-delay="180">Detect the dominant interaction. Expose the central vulnerability.</p>
        <p class="text-bold" data-reveal="line" data-reveal-delay="260">One signal. One correct movement.</p>

        <p class="demo-transition" data-reveal="line" data-reveal-delay="360">Seeing the system in action.</p>
        <div class="hero-cta-row" data-reveal data-reveal-delay="460">
          <a href="/demo" class="cta-button">→ Put a move under calculation</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <a href="#top">Home</a>
      <a href="/demo">Demo</a>
      <span class="footer-copy">© 2026 Aurora</span>
    </div>
  </footer>
</div>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:wght@400;500;600;700&display=swap");

  :root {
    --color-bg: #0b0b0c;
    --color-text: #f7f7f5;
    --color-text-secondary: #bfc2c7;
    --color-accent-blue: #2e5bff;
    --color-accent-green: #00c389;
    --color-accent-red: #ff3d3d;
    --ease-aurora: cubic-bezier(0.22, 1, 0.36, 1);
    --duration-reveal: 350ms;
    --duration-reveal-line: 220ms;
    --duration-reveal-strong: 520ms;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    font-family: "DM Sans", sans-serif;
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.55;
    overflow-x: hidden;
  }

  main {
    display: block;
  }

  .aurora-page {
    min-height: 100vh;
  }

  /* Header */
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
    padding: 0 24px;
    background: rgba(11, 11, 12, 0.94);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    display: none; /* MainLayout already has a header */
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .logo-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    text-decoration: none;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .nav a {
    font-family: "DM Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent-green);
    text-decoration: none;
  }

  /* Hero */
  .hero {
    position: relative;
    padding: 120px 24px 80px;
    overflow: hidden;
  }

  .hero-structure {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(46, 91, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(46, 91, 255, 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 20%, transparent 70%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .hero h1 {
    margin: 0;
    font-size: 64px;
    line-height: 1.1;
    letter-spacing: -0.03em;
    font-weight: 700;
  }

  .hero p {
    margin-top: 1.25rem;
    margin-bottom: 0;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* Core thesis line — visually dominant */
  .hero-thesis {
    font-size: 21px;
    font-weight: 500;
    color: var(--color-text) !important;
    letter-spacing: -0.015em;
    line-height: 1.35;
    margin-top: 2.75rem !important;
    margin-bottom: 2.25rem !important;
  }

  .hero-emphasis {
    font-weight: 600;
    color: var(--color-text) !important;
  }

  .hero-cta-row {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 2.5rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 20px;
    border-radius: 6px;
    text-decoration: none;
    font: 600 15px/1 "DM Sans", sans-serif;
    letter-spacing: 0.01em;
    transition:
      transform 250ms var(--ease-aurora),
      box-shadow 250ms var(--ease-aurora);
    background: var(--color-accent-blue);
    color: var(--color-text);
  }

  .cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 28px rgba(46, 91, 255, 0.3);
  }

  /* Sections */
  .section {
    padding: 80px 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .section-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .section-inner--centered {
    text-align: center;
  }

  .section h2 {
    margin: 0 0 2.5rem;
    font-size: 28px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: var(--color-text);
  }

  .section p {
    margin: 0 0 1.5rem;
    max-width: 760px;
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-size: 16px;
  }

  /* Utility */
  .gap-top {
    margin-top: 2.5rem !important;
  }

  .text-bold {
    font-weight: 600;
    color: var(--color-text);
  }

  .text-accent-blue {
    color: var(--color-accent-blue) !important;
  }

  .text-accent-red {
    color: var(--color-accent-red) !important;
  }

  /* Rupture */
  .rupture-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 2.5rem;
    margin: 3.5rem 0;
    padding: 2.5rem 2rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .rupture-before,
  .rupture-after {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .rupture-label {
    margin: 0;
    font-size: 13px;
    font-family: "DM Mono", monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .rupture-label--before {
    color: var(--color-accent-red);
    opacity: 0.7;
  }

  .rupture-label--after {
    color: var(--color-accent-green);
  }

  .rupture-item {
    margin: 0;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Antes items — muted, receding */
  .rupture-item--muted {
    opacity: 0.45;
  }

  /* Dominant thesis line in Hoy */
  .rupture-key {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--color-text) !important;
    opacity: 1 !important;
  }

  .rupture-divider {
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(46, 91, 255, 0.4), transparent);
  }

  /* Demo section */
  .demo-transition {
    font-family: "DM Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent-green) !important;
    margin-top: 3.5rem !important;
    margin-bottom: 0.5rem !important;
  }

  .product-cards-mini {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .product-card-mini {
    padding: 24px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 4px;
  }

  .product-card-mini h3 {
    font-size: 18px;
    margin-bottom: 8px;
  }

  .product-card-mini p {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin-bottom: 16px;
  }

  .product-card-mini a {
    font-size: 12px;
    font-family: "DM Mono", monospace;
    color: var(--color-accent-blue);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .solutions-grid-mini {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 40px;
    margin-bottom: 40px;
  }

  .solution-card-mini {
    padding: 24px;
    border-left: 2px solid var(--color-accent-blue);
    background: rgba(255, 255, 255, 0.02);
  }

  .solution-card-mini h3 {
    font-size: 16px;
    margin-bottom: 8px;
  }

  .solution-card-mini p {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .cta-button.secondary {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 768px) {
    .product-cards-mini, .solutions-grid-mini {
      grid-template-columns: 1fr;
    }
  }

  /* Footer */
  .footer {
    padding: 40px 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: none; /* MainLayout already has a footer */
  }

  .footer-inner {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer a {
    font-size: 14px;
    text-decoration: none;
    color: var(--color-text-secondary);
  }

  .footer a:hover {
    color: var(--color-text);
  }

  .footer-copy {
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  /* Aurora Motion System v1 */
  [data-reveal] {
    opacity: 0;
    transform: translateY(12px);
    filter: blur(3px);
    transition:
      opacity var(--duration-reveal) var(--ease-aurora),
      transform var(--duration-reveal) var(--ease-aurora),
      filter var(--duration-reveal) var(--ease-aurora);
  }

  [data-reveal="line"] {
    opacity: 0;
    transform: translateY(8px);
    filter: blur(2px);
    transition:
      opacity var(--duration-reveal-line) var(--ease-aurora),
      transform var(--duration-reveal-line) var(--ease-aurora),
      filter var(--duration-reveal-line) var(--ease-aurora);
  }

  [data-reveal="strong"] {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity var(--duration-reveal-strong) var(--ease-aurora),
      transform var(--duration-reveal-strong) var(--ease-aurora);
  }

  [data-reveal].is-visible,
  [data-reveal="line"].is-visible,
  [data-reveal="strong"].is-visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal="line"],
    [data-reveal="strong"] {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: 80px 24px 96px;
    }

    .hero h1 {
      font-size: 36px;
    }

    .hero-thesis {
      font-size: 18px;
    }

    .section {
      padding: 80px 24px;
    }

    .rupture-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .rupture-divider {
      display: none;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const delay = parseInt((entry.target as HTMLElement).dataset.revealDelay || '0', 10);
          if (delay > 0) {
            setTimeout(() => entry.target.classList.add('is-visible'), delay);
          } else {
            entry.target.classList.add('is-visible');
          }
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
</script>
