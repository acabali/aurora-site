<script>
  const menu = document.querySelector('[data-products-menu]');
  const trigger = document.querySelector('[data-products-trigger]');
  const dropdown = document.querySelector('[data-products-dropdown]');

  if (menu && trigger && dropdown) {
    const setOpen = (open) => {
      menu.classList.toggle('is-open', open);
      trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
      dropdown.hidden = !open;
    };

    setOpen(false);
    trigger.addEventListener('click', () => setOpen(!menu.classList.contains('is-open')));
    menu.addEventListener('mouseenter', () => setOpen(true));
    menu.addEventListener('mouseleave', () => setOpen(false));
    document.addEventListener('click', (event) => {
      if (!menu.contains(event.target)) setOpen(false);
    });
  }

  const cards = Array.from(document.querySelectorAll('[data-reveal-card]'));
  if (cards.length && 'IntersectionObserver' in window) {
    document.body.classList.add('motion-ready');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry, index) => {
          if (entry.isIntersecting) {
            entry.target.style.transitionDelay = `${index * 0.1}s`;
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 }
    );

    cards.forEach((card) => observer.observe(card));
  }
</script>
