<script>
  const root = document.querySelector(".aurora-page");
  const lang = root?.dataset.lang === "en" ? "en" : "es";
  const locale = lang === "en" ? "en-US" : "es-AR";
  const currency = new Intl.NumberFormat(locale, {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  });
  const decimals = new Intl.NumberFormat(locale, {
    minimumFractionDigits: 1,
    maximumFractionDigits: 1,
  });
  const integer = new Intl.NumberFormat(locale, { maximumFractionDigits: 0 });
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const cleanup = [];

  const header = document.querySelector(".home-header");
  const syncHeader = () => {
    if (!header) return;
    header.classList.toggle("is-scrolled", window.scrollY > 24);
  };

  syncHeader();
  window.addEventListener("scroll", syncHeader, { passive: true });

  const simInputs = {
    price: root?.querySelector('[data-sim-input="price"]'),
    volume: root?.querySelector('[data-sim-input="volume"]'),
    fixed: root?.querySelector('[data-sim-input="fixed"]'),
  };

  const readouts = {
    price: root?.querySelector('[data-sim-readout="price"]'),
    volume: root?.querySelector('[data-sim-readout="volume"]'),
    fixed: root?.querySelector('[data-sim-readout="fixed"]'),
  };

  const outputs = {
    margin: root?.querySelector('[data-output="margin"]'),
    cash: root?.querySelector('[data-output="cash"]'),
    breakeven: root?.querySelector('[data-output="breakeven"]'),
  };

  const hint = root?.querySelector('[data-sim-hint]');
  const trigger = root?.querySelector('[data-sim-trigger]');

  const animateValue = (element, nextValue, formatter) => {
    if (!element) return;
    const startValue = Number(element.dataset.value || 0);
    const start = performance.now();
    const duration = 480;

    const frame = (now) => {
      const progress = Math.min(1, (now - start) / duration);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = startValue + (nextValue - startValue) * eased;
      element.textContent = formatter(current);
      if (progress < 1) {
        requestAnimationFrame(frame);
      } else {
        element.dataset.value = String(nextValue);
      }
    };

    requestAnimationFrame(frame);
  };

  const updateSimulator = () => {
    if (!simInputs.price || !simInputs.volume || !simInputs.fixed) return;

    const price = Number(simInputs.price.value);
    const volume = Number(simInputs.volume.value);
    const fixed = Number(simInputs.fixed.value);

    readouts.price.textContent = `${price}%`;
    readouts.volume.textContent = `${volume}%`;
    readouts.fixed.textContent = `${fixed}%`;

    const baseRevenue = 120000;
    const variableCostRate = 0.53;
    const baseFixedCost = 26000;

    const newRevenue = baseRevenue * (1 + price / 100) * (1 - volume / 100);
    const newVariableCost = baseRevenue * (1 - volume / 100) * variableCostRate;
    const newFixedCost = baseFixedCost * (1 + fixed / 100);
    const contribution = Math.max(0.18, (newRevenue - newVariableCost) / Math.max(newRevenue, 1));
    const net = newRevenue - newVariableCost - newFixedCost;
    const margin = (net / Math.max(newRevenue, 1)) * 100;
    const cashDays = Math.max(18, Math.min(240, 112 + net / 850 - volume * 1.4 - fixed * 1.15 + price * 0.9));
    const breakeven = newFixedCost / contribution;

    animateValue(outputs.margin, margin, (value) => `${decimals.format(value)}%`);
    animateValue(outputs.cash, cashDays, (value) => `${integer.format(Math.round(value))} ${lang === "en" ? "days" : "días"}`);
    animateValue(outputs.breakeven, breakeven, (value) => currency.format(value));

    if (hint) {
      if (margin >= 22) {
        hint.textContent =
          lang === "en"
            ? "The scenario holds: margin expands, cash extends and the move stays inside a safe threshold."
            : "El escenario sostiene: el margen expande, la caja se alarga y el movimiento queda dentro de un umbral seguro.";
      } else if (margin >= 12) {
        hint.textContent =
          lang === "en"
            ? "The move is viable, but only if volume damage stays controlled and fixed cost pressure does not widen."
            : "El movimiento es viable, pero solo si el daño en volumen se mantiene controlado y la presión de costo fijo no se amplía.";
      } else {
        hint.textContent =
          lang === "en"
            ? "Threshold breached: Aurora would ask for approval before executing this version of the decision."
            : "Umbral roto: Aurora pediría aprobación antes de ejecutar esta versión de la decisión.";
      }
    }
  };

  Object.values(simInputs).forEach((input) => input?.addEventListener("input", updateSimulator));
  trigger?.addEventListener("click", updateSimulator);
  updateSimulator();

  const bootVisuals = async () => {
    try {
      const [{ default: gsap }, { ScrollTrigger }, THREE] = await Promise.all([
        import("gsap"),
        import("gsap/ScrollTrigger"),
        import("three"),
      ]);

      gsap.registerPlugin(ScrollTrigger);

      if (!prefersReducedMotion) {
        const words = Array.from(root.querySelectorAll("[data-hero-word]"));
        gsap.from(words, {
          opacity: 0,
          yPercent: 110,
          duration: 0.72,
          stagger: 0.06,
          ease: "power3.out",
        });

        gsap.utils.toArray(root.querySelectorAll("[data-reveal-group]")).forEach((group) => {
          const items = group.querySelectorAll("[data-reveal]");
          if (!items.length) return;
          gsap.from(items, {
            opacity: 0,
            y: 28,
            duration: 0.78,
            stagger: 0.08,
            ease: "power3.out",
            scrollTrigger: {
              trigger: group,
              start: "top 80%",
              toggleActions: "play none none reverse",
            },
          });
        });
      }

      const canvas = root.querySelector("#network-canvas");
      if (!canvas || prefersReducedMotion) return;

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(52, window.innerWidth / window.innerHeight, 0.1, 100);
      camera.position.z = 12;

      const renderer = new THREE.WebGLRenderer({
        canvas,
        antialias: true,
        alpha: true,
        powerPreference: "high-performance",
      });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));
      renderer.setSize(window.innerWidth, window.innerHeight);

      const group = new THREE.Group();
      scene.add(group);

      const nodeCount = 22;
      const basePositions = [];
      const lineSegments = [];

      for (let index = 0; index < nodeCount; index += 1) {
        const angle = (index / nodeCount) * Math.PI * 2;
        const radius = 3.5 + Math.sin(index * 0.7) * 1.05 + Math.random() * 0.4;
        basePositions.push(
          Math.cos(angle) * radius + (Math.random() - 0.5) * 0.6,
          Math.sin(index * 0.45) * 1.7 + (Math.random() - 0.5) * 1.4,
          Math.sin(angle) * radius * 0.72
        );
      }

      const livePoints = new Float32Array(basePositions.map((value) => value * 0.3));
      const pointGeometry = new THREE.BufferGeometry();
      pointGeometry.setAttribute("position", new THREE.BufferAttribute(livePoints, 3));
      const pointMaterial = new THREE.PointsMaterial({
        color: 0xbfc2c7,
        size: 0.14,
        transparent: true,
        opacity: 0.2,
      });

      for (let index = 0; index < nodeCount; index += 1) {
        const current = new THREE.Vector3(
          basePositions[index * 3],
          basePositions[index * 3 + 1],
          basePositions[index * 3 + 2]
        );
        const distances = [];
        for (let compareIndex = 0; compareIndex < nodeCount; compareIndex += 1) {
          if (compareIndex === index) continue;
          const compare = new THREE.Vector3(
            basePositions[compareIndex * 3],
            basePositions[compareIndex * 3 + 1],
            basePositions[compareIndex * 3 + 2]
          );
          distances.push({ compareIndex, distance: current.distanceTo(compare) });
        }
        distances
          .sort((left, right) => left.distance - right.distance)
          .slice(0, 2)
          .forEach(({ compareIndex }) => {
            if (compareIndex < index) return;
            lineSegments.push(
              basePositions[index * 3],
              basePositions[index * 3 + 1],
              basePositions[index * 3 + 2],
              basePositions[compareIndex * 3],
              basePositions[compareIndex * 3 + 1],
              basePositions[compareIndex * 3 + 2]
            );
          });
      }

      const liveLines = new Float32Array(lineSegments.map((value) => value * 0.3));
      const lineGeometry = new THREE.BufferGeometry();
      lineGeometry.setAttribute("position", new THREE.BufferAttribute(liveLines, 3));
      const lineMaterial = new THREE.LineBasicMaterial({ color: 0xbfc2c7, transparent: true, opacity: 0.08 });

      const points = new THREE.Points(pointGeometry, pointMaterial);
      const lines = new THREE.LineSegments(lineGeometry, lineMaterial);
      group.add(lines);
      group.add(points);

      const state = { progress: 0.22, mix: 0 };
      const gray = new THREE.Color(0xbfc2c7);
      const blue = new THREE.Color(0x2e5bff);

      const syncNetwork = () => {
        for (let index = 0; index < basePositions.length; index += 1) {
          livePoints[index] = basePositions[index] * state.progress;
        }
        for (let index = 0; index < lineSegments.length; index += 1) {
          liveLines[index] = lineSegments[index] * state.progress;
        }
        pointGeometry.attributes.position.needsUpdate = true;
        lineGeometry.attributes.position.needsUpdate = true;
        pointMaterial.opacity = 0.22 + state.progress * 0.4;
        lineMaterial.opacity = 0.04 + state.progress * 0.2;
        pointMaterial.color.copy(gray).lerp(blue, state.mix);
        lineMaterial.color.copy(gray).lerp(blue, state.mix * 0.92);
      };

      syncNetwork();

      const emergenceTween = gsap.to(state, {
        progress: 1,
        duration: 4,
        ease: "power2.out",
        onUpdate: syncNetwork,
      });

      const colorTween = gsap.to(state, {
        mix: 1,
        ease: "none",
        onUpdate: syncNetwork,
        scrollTrigger: {
          trigger: document.body,
          start: "top top",
          end: "bottom bottom",
          scrub: 1,
        },
      });

      group.rotation.x = -0.34;
      group.rotation.y = 0.28;

      const tick = () => {
        group.rotation.y += 0.0011;
        group.rotation.z += 0.0005;
        renderer.render(scene, camera);
      };
      gsap.ticker.add(tick);

      const onResize = () => {
        const width = window.innerWidth;
        const height = window.innerHeight;
        camera.aspect = width / height;
        camera.updateProjectionMatrix();
        renderer.setSize(width, height);
      };

      window.addEventListener("resize", onResize, { passive: true });
      cleanup.push(() => {
        emergenceTween.kill();
        colorTween.kill();
        gsap.ticker.remove(tick);
        window.removeEventListener("resize", onResize);
        pointGeometry.dispose();
        lineGeometry.dispose();
        pointMaterial.dispose();
        lineMaterial.dispose();
        renderer.dispose();
        ScrollTrigger.getAll().forEach((trigger) => trigger.kill());
      });
    } catch (error) {
      console.error("Aurora landing runtime failed", error);
    }
  };

  bootVisuals();

  window.addEventListener(
    "pagehide",
    () => {
      cleanup.forEach((fn) => fn());
      window.removeEventListener("scroll", syncHeader);
    },
    { once: true }
  );
</script>
