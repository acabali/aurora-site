---
const particles = [
  { left: "5%", top: "18%", size: 6, color: "#BFC2C7", duration: "48s", delay: "-8s", opacity: 0.34 },
  { left: "12%", top: "72%", size: 10, color: "#2E5BFF", duration: "62s", delay: "-18s", opacity: 0.42 },
  { left: "18%", top: "32%", size: 8, color: "#BFC2C7", duration: "58s", delay: "-14s", opacity: 0.36 },
  { left: "24%", top: "82%", size: 12, color: "#00C389", duration: "74s", delay: "-11s", opacity: 0.4 },
  { left: "31%", top: "22%", size: 5, color: "#BFC2C7", duration: "54s", delay: "-22s", opacity: 0.32 },
  { left: "38%", top: "64%", size: 9, color: "#BFC2C7", duration: "80s", delay: "-17s", opacity: 0.38 },
  { left: "44%", top: "12%", size: 7, color: "#FF3D3D", duration: "66s", delay: "-9s", opacity: 0.35 },
  { left: "49%", top: "78%", size: 11, color: "#BFC2C7", duration: "72s", delay: "-15s", opacity: 0.41 },
  { left: "55%", top: "26%", size: 4, color: "#BFC2C7", duration: "43s", delay: "-6s", opacity: 0.31 },
  { left: "61%", top: "68%", size: 8, color: "#2E5BFF", duration: "76s", delay: "-19s", opacity: 0.44 },
  { left: "67%", top: "16%", size: 10, color: "#BFC2C7", duration: "52s", delay: "-12s", opacity: 0.39 },
  { left: "72%", top: "84%", size: 6, color: "#BFC2C7", duration: "64s", delay: "-10s", opacity: 0.33 },
  { left: "78%", top: "38%", size: 12, color: "#00C389", duration: "70s", delay: "-20s", opacity: 0.43 },
  { left: "84%", top: "10%", size: 5, color: "#BFC2C7", duration: "56s", delay: "-7s", opacity: 0.34 },
  { left: "88%", top: "58%", size: 9, color: "#BFC2C7", duration: "78s", delay: "-16s", opacity: 0.37 },
  { left: "92%", top: "28%", size: 7, color: "#FF3D3D", duration: "60s", delay: "-13s", opacity: 0.36 },
  { left: "96%", top: "76%", size: 11, color: "#BFC2C7", duration: "68s", delay: "-21s", opacity: 0.42 },
  { left: "52%", top: "46%", size: 8, color: "#BFC2C7", duration: "44s", delay: "-5s", opacity: 0.3 },
] as const;

const tiers = [
  { name: "AURORA CORE", detail: "10 decisiones/mes" },
  { name: "AURORA PRO", detail: "100 decisiones/mes" },
  { name: "AURORA ENTERPRISE", detail: "Ilimitado + full governance" },
  { name: "AURORA ADVANCED", detail: "Premium add-ons" },
] as const;

const icons = {
  calculator: '<rect x="12" y="10" width="24" height="28" rx="4" fill="none"/><path d="M18 17h12"/><path d="M18 25h4"/><path d="M26 25h4"/><path d="M18 31h4"/><path d="M26 31h4"/>',
  futures: '<path d="M10 34l10-18 6 10 12-14" fill="none"/><path d="M20 16v18" fill="none"/><path d="M30 22l3 12" fill="none"/>',
  fracture: '<path d="M11 34c4-10 10-16 20-18" fill="none"/><path d="M29 13l8 8" fill="none"/><path d="M20 18l4 4-6 5 5 4-4 5" fill="none"/>',
  cause: '<circle cx="20" cy="20" r="8" fill="none"/><path d="M26 26l10 10" fill="none"/><path d="M20 14v12" fill="none"/><path d="M14 20h12" fill="none"/>',
  memory: '<path d="M14 10h18l4 4v24H14z" fill="none"/><path d="M32 10v8h8" fill="none"/><path d="M20 24h10" fill="none"/><path d="M20 30h10" fill="none"/>',
  investment: '<path d="M10 34h28" fill="none"/><path d="M16 28V16" fill="none"/><path d="M24 28V12" fill="none"/><path d="M32 28V20" fill="none"/>',
  cash: '<path d="M10 16h28v16H10z" fill="none"/><path d="M16 24h8" fill="none"/><path d="M14 30l5-4 5 4 8-8 4 3" fill="none"/>',
  expansion: '<path d="M10 30h12V18H10z" fill="none"/><path d="M26 34h12V14H26z" fill="none"/><path d="M22 24h4" fill="none"/>',
  pricing: '<path d="M14 14h14l8 8-14 14-8-8z" fill="none"/><path d="M22 18v8" fill="none"/><path d="M18 22h8" fill="none"/>',
  marketing: '<path d="M12 18l16-6v24l-16-6z" fill="none"/><path d="M28 18l8-4v20l-8-4" fill="none"/><path d="M10 22h4" fill="none"/>',
  hiring: '<circle cx="18" cy="18" r="5" fill="none"/><path d="M10 34c2-6 6-9 12-9s10 3 12 9" fill="none"/><path d="M33 17h8" fill="none"/><path d="M37 13v8" fill="none"/>',
} as const;

const systemCards = [
  {
    icon: "calculator",
    title: "Calculadora Estratégica",
    description: "Ve cómo interactúan todas las variables de tu negocio",
    example: "Precio +20% → Volumen -15% → Margen +5% → Caja +X%",
  },
  {
    icon: "futures",
    title: "Simulador de Futuros",
    description: "Prueba múltiples escenarios antes de mover capital, equipo o timing",
    example: "Compara 12 versiones de expansión con distintos costos, mercados y plazos",
  },
  {
    icon: "fracture",
    title: "Detector de Grietas",
    description: "Identifica exactamente dónde puede fallar un plan y cuál es su punto de ruptura",
    example: "Tu plan quiebra si el volumen cae por debajo de 40% vs baseline",
  },
  {
    icon: "cause",
    title: "Revelador de Causas",
    description: "Detecta qué variable causa realmente tu problema",
    example: "Ventas -18%. No es precio, no es canal. Es temporada + competencia nueva",
  },
  {
    icon: "memory",
    title: "Memoria Corporativa",
    description: "Registra cada decisión con contexto, inputs, outputs y resultado real",
    example: "12 meses después: sabés exactamente por qué cada decisión ganó o perdió",
  },
] as const;

const applicationCards = [
  {
    icon: "investment",
    title: "Evaluador de Inversiones",
    problem: "¿Esa inversión realmente retorna?",
    flow: "Inversión + timeline → ROI + break-even",
    example: "¿Franquicia $80k es viable o quiebro?",
  },
  {
    icon: "cash",
    title: "Detector de Fugas de Caja",
    problem: "¿Cuándo exactamente se acaba el dinero?",
    flow: "Histórico gasto → 'Caja se acaba en X días'",
    example: "Caja para 4 meses. ¿Contratas ahora o esperas?",
  },
  {
    icon: "expansion",
    title: "Validador de Expansiones",
    problem: "¿Esta expansión es viable?",
    flow: "Parámetros sucursal nueva → Viabilidad + escenarios",
    example: "Abrir segundo local. ¿Con qué alquiler sobrevivo?",
  },
  {
    icon: "pricing",
    title: "Decisor de Pricing",
    problem: "¿Cuál es el precio óptimo?",
    flow: "Precio actual + elasticidad → Precio óptimo + ROAS",
    example: "Subes 12%. Aurora te dice si ganas margen o destruyes volumen",
  },
  {
    icon: "marketing",
    title: "Decisor de Marketing",
    problem: "¿Este gasto en marketing genera ROI?",
    flow: "Gasto por canal → Costo/adquisición + ROAS",
    example: "$5k/mes Instagram. ¿Genera ventas o solo ruido?",
  },
  {
    icon: "hiring",
    title: "Decisor de Contratación",
    problem: "¿Contratar mejora o daña?",
    flow: "Empleado + salario → Impacto en margen + break-even",
    example: "¿Contratar 2 personas destruye el margen o lo sostiene?",
  },
] as const;

const governanceCards = [
  {
    icon: "#",
    title: "DECISION_ID",
    text: "Cada decisión tiene ID único para identificación y seguimiento",
  },
  {
    icon: "🔐",
    title: "DECISION_HASH",
    text: "Validación criptográfica que garantiza auditabilidad inmutable",
  },
  {
    icon: "📋",
    title: "LEDGER + AUDIT TRAIL",
    text: "Registro completo: quién, qué, cuándo, por qué, resultado real",
  },
] as const;
---

<div class="aurora-page" id="top">
  <header class="header">
    <div class="header-left">
      <a href="/" class="logo-link" aria-label="Aurora home">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 24a12 12 0 0 1 24 0" stroke="var(--color-text)" stroke-width="6" stroke-linecap="square"/>
          <path d="M36 24a12 12 0 0 1-12 12" stroke="var(--color-text)" stroke-width="6" stroke-linecap="square"/>
        </svg>
      </a>

      <div class="products-menu" id="products-menu" data-products-menu>
        <button type="button" class="products-trigger" data-products-trigger aria-expanded="false" aria-controls="products-dropdown">
          PRODUCTOS ▼
        </button>
        <div class="products-dropdown" id="products-dropdown" data-products-dropdown hidden>
          {tiers.map((tier) => (
            <div class="tier-item">
              <strong>{tier.name}</strong>
              <span>{tier.detail}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <nav class="nav" aria-label="Primary navigation">
      <a href="#sistema">SISTEMA</a>
      <a href="#aplicaciones">APLICACIONES</a>
      <a href="/demo">DEMO</a>
    </nav>

    <div class="lang-flags" aria-label="Language placeholder">
      <a href="">🇪🇸 ES</a>
      <span>|</span>
      <a href="">🇬🇧 EN</a>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="hero-particles" aria-hidden="true">
        {particles.map((particle) => (
          <span
            class="particle"
            style={`left:${particle.left};top:${particle.top};width:${particle.size}px;height:${particle.size}px;background:${particle.color};opacity:${particle.opacity};animation-duration:${particle.duration};animation-delay:${particle.delay};`}
          ></span>
        ))}
      </div>

      <div class="hero-content">
        <h1>El límite humano<br />ya no alcanza.</h1>
        <p style="margin-top: 1.5rem; color: var(--color-text-secondary);">
          El mercado ya no compite con personas.<br />
          Compite con sistemas.
        </p>
        <p style="margin-top: 1rem; color: var(--color-text-secondary);">
          Quedarse en intuición<br />
          es quedar fuera del juego real.
        </p>
        <p style="margin-top: 2rem; font-weight: 600; color: var(--color-text);">
          Aurora no mejora decisiones.
        </p>
        <p style="color: var(--color-text-secondary);">
          Desplaza el límite humano por el cálculo permanente.
        </p>
        <p style="margin-top: 2rem; color: var(--color-text-secondary);">
          No es digitalización.
        </p>
        <p style="font-weight: 600; color: var(--color-text);">
          Es sustitución operativa.
        </p>
        <div class="hero-cta-row" style="margin-top: 2rem;">
          <a href="/demo" class="cta-button">Poner una decisión bajo evidencia</a>
          <a href="/demo" class="cta-button cta-button--ghost">Ver demo completa</a>
        </div>
      </div>
    </section>

    <section class="section section-1">
      <div class="section-inner">
        <h2>Las decisiones se toman fragmentadas.</h2>
        <p>Las empresas toman decisiones sin ver todas las variables juntas. Información dispersa, procesos sin integración, contextos silenciados.</p>
        <p style="color: var(--color-accent-blue); font-weight: 600; margin-top: 1.5rem;">El costo de no ver el sistema completo crece exponencialmente.</p>
      </div>
    </section>

    <section class="section section-2">
      <div class="section-inner">
        <h2>El mercado ya opera con cálculo.</h2>
        <p>Validar antes de actuar ya es posible. La validación previa no es mejora.</p>
        <p style="color: var(--color-accent-blue); font-weight: 600; margin-top: 1.5rem;">Es condición de entrada.</p>
        <p style="margin-top: 1rem;">La precisión no optimiza. Define quién compite.</p>
      </div>
    </section>

    <section class="section section-3">
      <div class="section-inner">
        <h2>Hoy es más barato operar con cálculo.</h2>
        <p>La ventaja ya no está en crecer. Está en procesar mejor.</p>
        <p style="margin-top: 1.5rem;">Seguir expandiendo capas humanas cuando el cálculo ya es superior no es cultura.</p>
        <p style="color: var(--color-accent-red); font-weight: 600;">Es desventaja.</p>
        <p style="margin-top: 1rem;">El mercado premia cálculo. Penaliza interpretación.</p>
      </div>
    </section>

    <section class="section section-rupture">
      <div class="section-inner">
        <h2>La forma de operar cambió.</h2>
        <h2 style="margin-top: 1rem; font-size: 1.5rem;">Antes se reaccionaba. Hoy se ejecuta con ventaja informacional.</h2>

        <div class="rupture-container">
          <div class="rupture-before">
            <h3>Antes</h3>
            <ul class="rupture-list">
              <li>El error se absorbía</li>
              <li>El ajuste era posterior</li>
              <li>La velocidad era humana</li>
            </ul>
          </div>
          <div class="rupture-divider"></div>
          <div class="rupture-after">
            <h3>Hoy</h3>
            <ul class="rupture-list">
              <li>El mercado opera con sistemas autónomos</li>
              <li>Automatización estratégica</li>
              <li>Cálculo continuo</li>
            </ul>
          </div>
        </div>

        <p style="margin-top: 2rem; font-weight: 600;">No es transformación digital.</p>
        <p style="color: var(--color-accent-blue); font-weight: 600;">Es desplazamiento operativo.</p>
      </div>
    </section>

    <section class="section section-definition">
      <div class="section-inner">
        <h2>Aurora es cálculo soberano.</h2>
        <div class="definition-grid">
          <div class="definition-card">
            <p style="font-weight: 600; color: var(--color-accent-blue); margin-bottom: 1rem;">No acompaña</p>
            <p>Divide a quienes operan desde límite humano de quienes operan con potencia algorítmica.</p>
          </div>
          <div class="definition-card">
            <p style="font-weight: 600; color: var(--color-accent-blue); margin-bottom: 1rem;">Procesa complejidad</p>
            <p>Sin reducirla. Sin perder contexto. Sin omitir variables críticas.</p>
          </div>
          <div class="definition-card">
            <p style="font-weight: 600; color: var(--color-accent-blue); margin-bottom: 1rem;">Ventaja antes</p>
            <p>Tienes ventaja informacional antes de que el mercado entienda el movimiento.</p>
          </div>
        </div>
        <p style="margin-top: 3rem; font-size: 1.25rem; color: var(--color-accent-blue); font-weight: 600;">Con cálculo soberano, marcás el ritmo. Sin él, lo perseguís.</p>
      </div>
    </section>

    <section class="section section-products" id="sistema">
      <div class="section-inner">
        <h2>Cinco módulos, un solo sistema decisional</h2>
        <p class="section-subcopy">La ejecución bajo umbrales es una capacidad del sistema, no un producto aparte.</p>
        <div class="system-grid">
          {systemCards.map((card) => (
            <article class="feature-card" data-reveal-card>
              <div class="feature-icon" aria-hidden="true">
                <svg viewBox="0 0 48 48" set:html={icons[card.icon]}></svg>
              </div>
              <h3>{card.title}</h3>
              <p>{card.description}</p>
              <p class="feature-example">{card.example}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-applications" id="aplicaciones">
      <div class="section-inner">
        <h2>Seis lecturas operativas del mismo núcleo</h2>
        <p class="section-subcopy">Aurora se manifiesta en decisiones de...</p>
        <div class="applications-grid">
          {applicationCards.map((card) => (
            <article class="application-card" data-reveal-card>
              <div class="feature-icon feature-icon--small" aria-hidden="true">
                <svg viewBox="0 0 48 48" set:html={icons[card.icon]}></svg>
              </div>
              <h3>{card.title}</h3>
              <p class="application-problem">{card.problem}</p>
              <p class="application-flow">{card.flow}</p>
              <p class="application-example">{card.example}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-thresholds">
      <div class="section-inner section-inner--centered">
        <h2>Ejecución bajo umbrales definidos</h2>
        <p class="section-subcopy">Capacidad del sistema, no un producto aparte</p>

        <div class="threshold-panel">
          <div class="threshold-diagram">
            <div>INPUT</div>
            <div class="threshold-arrow">↓</div>
            <div>Aurora evalúa</div>
            <div class="threshold-arrow">↓</div>
            <div>¿Riesgo &lt; Umbral?</div>
            <div class="threshold-branches">
              <div>
                <span>SÍ</span>
                <strong>EJECUTA AUTOMÁTICAMENTE</strong>
              </div>
              <div>
                <span>NO</span>
                <strong>REQUIERE TU APROBACIÓN</strong>
              </div>
            </div>
          </div>

          <p>Defines umbrales de riesgo (ej: 15%). Aurora evalúa decisión. Si riesgo &lt; 15%, ejecuta automáticamente. Si &gt; 15%, requiere aprobación tuya. Human guardrails + automatización.</p>
          <p class="threshold-example">Riesgo operacional &lt; 15% → Ejecuta. Riesgo operacional &gt; 15% → Avísame para decidir.</p>
        </div>
      </div>
    </section>

    <section class="section section-governance" id="governance">
      <div class="section-inner">
        <h2>Full governance nativo</h2>
        <p class="section-subcopy">Decisiones auditables, no amontonadas. Governance es parte del sistema, no un agregado.</p>

        <div class="governance-cards">
          {governanceCards.map((card) => (
            <article class="governance-card" data-reveal-card>
              <span class="governance-icon" aria-hidden="true">{card.icon}</span>
              <h3>{card.title}</h3>
              <p>{card.text}</p>
            </article>
          ))}
        </div>

        <h3 class="governance-subtitle">Ejemplo de decisión auditada</h3>
        <div class="governance-table-wrap">
          <table class="governance-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Quién</th>
                <th>Acción</th>
                <th>Estado</th>
                <th>Hash</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>DEC-001</td>
                <td>Aurora+CFO</td>
                <td>Pricing Up</td>
                <td>Aprobada</td>
                <td>8fa3c2d9</td>
              </tr>
              <tr>
                <td>DEC-002</td>
                <td>Aurora+COO</td>
                <td>Expansion</td>
                <td>Requiere App</td>
                <td>1cd77ab4</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p class="governance-close">Full compliance ready (GDPR, SOX). Gobernanza integrada, no posterior.</p>
      </div>
    </section>

    <section class="section section-demo">
      <div class="section-inner section-inner--centered">
        <h2>Prueba Aurora ahora</h2>
        <div class="demo-actions">
          <a href="/demo" class="demo-button demo-button--primary">Acceder a demo interactiva</a>
          <a href="mailto:hola@aurora.io?subject=Aurora%20Demo" class="demo-button demo-button--secondary">Hablar con equipo Aurora</a>
        </div>
        <p class="demo-tagline">Los que calculan ya se movieron.</p>
      </div>
    </section>
  </main>

  <footer class="footer" id="contacto">
    <div class="footer-grid">
      <div class="footer-column">
        <a href="#top">Home</a>
        <a href="#products-menu">Pricing</a>
        <a href="#governance">Governance</a>
        <a href="https://aurora-site.com/blog" target="_blank" rel="noreferrer">Blog</a>
        <a href="mailto:hola@aurora.io">Contacto</a>
      </div>
      <div class="footer-column">
        <a href="https://linkedin.com/company/auroratech" target="_blank" rel="noreferrer">LinkedIn</a>
        <a href="https://twitter.com/auroratech" target="_blank" rel="noreferrer">Twitter</a>
        <a href="mailto:hola@aurora.io">Email</a>
      </div>
      <div class="footer-copy">© 2026 Aurora. Infraestructura decisional.</div>
    </div>
  </footer>
</div>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:wght@400;500;600;700&display=swap");

  :root {
    --color-bg: #0b0b0c;
    --color-text: #f7f7f5;
    --color-text-secondary: #bfc2c7;
    --color-accent-blue: #2e5bff;
    --color-accent-green: #00c389;
    --color-accent-red: #ff3d3d;
    --duration-normal: 250ms;
    --duration-slow: 600ms;
    --easing-smooth: cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    padding-top: 0;
    font-family: "DM Sans", sans-serif;
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.7;
    overflow-x: hidden;
  }

  main {
    display: block;
  }

  .aurora-page {
    min-height: 100vh;
  }

  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
    padding: 0 24px;
    background: rgba(11, 11, 12, 0.94);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(46, 91, 255, 0.1);
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .logo-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    text-decoration: none;
  }

  .products-menu {
    position: relative;
  }

  .products-trigger {
    border: 0;
    background: transparent;
    color: var(--color-text);
    font: 500 14px/1 "DM Sans", sans-serif;
    cursor: pointer;
    padding: 0;
  }

  .products-dropdown {
    position: absolute;
    top: calc(100% + 12px);
    left: 0;
    min-width: 250px;
    padding: 12px;
    background: rgba(46, 91, 255, 0.1);
    border: 1px solid rgba(46, 91, 255, 0.2);
    border-radius: 8px;
    display: grid;
    gap: 10px;
  }

  .products-menu:hover .products-dropdown,
  .products-menu.is-open .products-dropdown {
    display: grid;
  }

  .tier-item strong,
  .tier-item span {
    display: block;
  }

  .tier-item strong {
    font: 500 14px/1.3 "DM Sans", sans-serif;
