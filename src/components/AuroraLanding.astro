---
const { lang = "es" } = Astro.props;
const locale = lang === "en" ? "en" : "es";
const isEn = locale === "en";
const pick = (value) => (typeof value === "string" ? value : value[locale]);

const icons = {
  calculator: '<path d="M14 10h20v28H14z" fill="none"/><path d="M18 16h12"/><path d="M19 23h4"/><path d="M25 23h4"/><path d="M19 29h4"/><path d="M25 29h4"/>',
  futures: '<path d="M9 35l12-22 6 12 12-14" fill="none"/><path d="M22 16l-1 19" fill="none"/><path d="M31 21l4 14" fill="none"/>',
  fracture: '<path d="M10 34c4-10 11-16 20-18" fill="none"/><path d="M29 13l9 9" fill="none"/><path d="M20 18l4 4-6 5 5 4-4 5" fill="none"/>',
  cause: '<circle cx="21" cy="21" r="8" fill="none"/><path d="M27 27l10 10" fill="none"/><path d="M21 13v16" fill="none"/><path d="M13 21h16" fill="none"/>',
  memory: '<path d="M14 10h16l6 6v22H14z" fill="none"/><path d="M30 10v7h7" fill="none"/><path d="M20 24h10" fill="none"/><path d="M20 30h10" fill="none"/>',
  investment: '<path d="M10 32h28" fill="none"/><path d="M16 28V16" fill="none"/><path d="M24 28V12" fill="none"/><path d="M32 28V20" fill="none"/>',
  cash: '<path d="M11 16h26v16H11z" fill="none"/><path d="M18 22h12" fill="none"/><path d="M15 30l4-4 5 4 7-8 4 3" fill="none"/>',
  expansion: '<path d="M10 30h12V18H10z" fill="none"/><path d="M26 34h12V14H26z" fill="none"/><path d="M22 24h4" fill="none"/>',
  pricing: '<path d="M13 14h14l8 8-14 14-8-8z" fill="none"/><path d="M21 21h6" fill="none"/><path d="M24 18v6" fill="none"/>',
  marketing: '<path d="M12 18l16-6v24l-16-6z" fill="none"/><path d="M28 18l8-4v20l-8-4" fill="none"/><path d="M10 22h4" fill="none"/>',
  hiring: '<circle cx="18" cy="18" r="5" fill="none"/><path d="M10 34c2-6 6-9 12-9s10 3 12 9" fill="none"/><path d="M33 17h8" fill="none"/><path d="M37 13v8" fill="none"/>',
  governance: '<path d="M24 10l14 6v8c0 9-5 14-14 18-9-4-14-9-14-18v-8z" fill="none"/><path d="M18 24h12" fill="none"/><path d="M18 30h8" fill="none"/>',
};

const nav = {
  system: isEn ? "SYSTEM" : "SISTEMA",
  applications: isEn ? "APPLICATIONS" : "APLICACIONES",
  demo: "DEMO",
};

const hero = {
  label: isEn ? "Decision Infrastructure" : "Infraestructura decisional",
  title: isEn ? "Aurora tests decisions before you execute them" : "Aurora prueba decisiones antes de ejecutarlas",
  subtitle: isEn
    ? "Decision infrastructure that integrates data, simulates scenarios and executes under thresholds you control."
    : "Infraestructura decisional que integra datos, simula escenarios y ejecuta bajo umbrales que controlas.",
  primary: isEn ? "Simulate my decision" : "Simular mi decisión",
  secondary: isEn ? "See how it works" : "Ver cómo funciona",
  scroll: isEn ? "Scroll to continue" : "Scroll para continuar",
  simulatorTitle: isEn ? "Live simulator" : "Simulador en vivo",
  simulatorBody: isEn
    ? "Move three assumptions and see how margin, cash and breakeven react before you commit the decision."
    : "Mueve tres supuestos y ve cómo reaccionan margen, caja y breakeven antes de comprometer la decisión.",
  calculate: isEn ? "Calculate" : "Calcular",
  note: isEn
    ? "Illustrative scenario based on pricing, volume and fixed-cost stress."
    : "Escenario ilustrativo basado en pricing, volumen y presión de costo fijo.",
};

const simulatorLabels = {
  price: isEn ? "My price increases" : "Mi precio sube",
  volume: isEn ? "My volume decreases" : "Mi volumen baja",
  fixed: isEn ? "My fixed cost increases" : "Mi costo fijo sube",
  margin: isEn ? "Margin" : "Margen",
  cash: isEn ? "Cash" : "Caja",
  breakeven: isEn ? "Breakeven" : "Punto de equilibrio",
};

const systemSection = {
  label: nav.system,
  title: isEn ? "Five modules, one decision system" : "Cinco módulos, un solo sistema decisional",
  intro: isEn
    ? "Execution under thresholds is a capability of the system, not a separate product."
    : "La ejecución bajo umbrales es una capacidad del sistema, no un producto aparte.",
};

const applicationSection = {
  label: nav.applications,
  title: isEn ? "Six operating reads of the same core" : "Seis lecturas operativas del mismo núcleo",
  intro: isEn
    ? "Aurora manifests as investment, cash, pricing, expansion, marketing and hiring decisions."
    : "Aurora se manifiesta en decisiones de inversión, caja, pricing, expansión, marketing y contratación.",
};

const operatingSection = {
  label: isEn ? "OPERATING MODE" : "MODO OPERATIVO",
  title: isEn ? "Execution under defined thresholds" : "Ejecución bajo umbrales definidos",
  body: isEn
    ? "Define your risk thresholds. Aurora executes safe decisions automatically. Critical ones, to you."
    : "Define tus umbrales de riesgo. Aurora ejecuta automáticamente las decisiones seguras. Las críticas, para ti.",
  input: isEn ? "Input" : "Input",
  evaluates: isEn ? "Aurora evaluates" : "Aurora evalúa",
  threshold: isEn ? "Is risk < threshold?" : "¿Riesgo < umbral?",
  execute: isEn ? "Execute automatically" : "Ejecuta automáticamente",
  approval: isEn ? "Requires approval" : "Requiere aprobación",
};

const governanceSection = {
  label: isEn ? "GOVERNANCE" : "GOBERNANZA",
  title: isEn ? "Full governance native" : "Full governance nativo",
  intro: isEn
    ? "Decision ID, hash, ledger and audit trail are visible because governance is part of the product, not an afterthought."
    : "Decision ID, hash, ledger y audit trail son visibles porque la gobernanza es parte del producto, no un agregado tardío.",
  badges: isEn
    ? ["decision_id", "decision_hash", "Ledger", "Audit trail", "Compliance ready"]
    : ["decision_id", "decision_hash", "Ledger", "Audit trail", "Compliance ready"],
  status: isEn ? "Status" : "Estado",
  actor: isEn ? "Actor" : "Actor",
  action: isEn ? "Action" : "Acción",
  hash: isEn ? "Hash" : "Hash",
};

const ctaSection = {
  label: isEn ? "DEMO" : "DEMO",
  title: isEn ? "Take your next decision into simulation" : "Lleva tu próxima decisión a simulación",
  body: isEn
    ? "Start with the live calculator or go straight to the interactive demo with the Aurora team."
    : "Empieza con la calculadora en vivo o entra directo a la demo interactiva con el equipo Aurora.",
  primary: isEn ? "Access interactive demo" : "Acceder a demo interactiva",
  secondary: isEn ? "Talk to team" : "Hablar con equipo",
};

const footer = {
  privacy: isEn ? "Privacy" : "Privacidad",
  terms: isEn ? "Terms" : "Términos",
  contact: isEn ? "Contact" : "Contacto",
  copy: isEn
    ? "© 2026 Aurora. Sovereign calculation for business decisions."
    : "© 2026 Aurora. Cálculo soberano para decisiones empresariales.",
};

const modules = [
  {
    icon: "calculator",
    name: { es: "Calculadora Estratégica", en: "Strategic Calculator" },
    description: {
      es: "Ve cómo interactúan todas las variables de tu negocio en simultáneo.",
      en: "See how every business variable interacts at the same time.",
    },
    example: {
      es: "Precio +20% → Volumen -15% → Margen +5% → Caja +X%",
      en: "Price +20% → Volume -15% → Margin +5% → Cash +X%",
    },
  },
  {
    icon: "futures",
    name: { es: "Simulador de Futuros", en: "Future Simulator" },
    description: {
      es: "Prueba múltiples escenarios de una decisión antes de mover capital, equipo o timing.",
      en: "Test multiple future states before moving capital, team or timing.",
    },
    example: {
      es: "Comparas 12 versiones de expansión con distintos costos, mercados y plazos.",
      en: "Compare 12 expansion paths with different costs, markets and timing.",
    },
  },
  {
    icon: "fracture",
    name: { es: "Detector de Grietas", en: "Fracture Detector" },
    description: {
      es: "Identifica exactamente dónde puede fallar un plan y cuál es su punto de ruptura.",
      en: "Pinpoint where the plan breaks and which threshold becomes critical.",
    },
    example: {
      es: "Tu plan quiebra si el volumen cae por debajo de 40% vs baseline.",
      en: "Your plan breaks if volume falls below 40% versus baseline.",
    },
  },
  {
    icon: "cause",
    name: { es: "Revelador de Causas", en: "Cause Revealer" },
    description: {
      es: "Detecta qué variable causa realmente el problema cuando todo parece moverse a la vez.",
      en: "Detect the variable actually causing the problem when everything seems to move at once.",
    },
    example: {
      es: "Ventas -18%. No es precio ni canal. Es temporada + competencia nueva.",
      en: "Sales -18%. Not price, not channel. Seasonality + new competitor.",
    },
  },
  {
    icon: "memory",
    name: { es: "Memoria Corporativa", en: "Corporate Memory" },
    description: {
      es: "Registra cada decisión con contexto, inputs, outputs y resultado real.",
      en: "Record every decision with context, inputs, outputs and actual result.",
    },
    example: {
      es: "Doce meses después sabés por qué cada decisión ganó o perdió.",
      en: "Twelve months later you know exactly why each decision won or lost.",
    },
  },
] as const;

const applications = [
  {
    icon: "investment",
    name: { es: "Evaluador de Inversiones", en: "Investment Validator" },
    problem: {
      es: "Evalúa si una inversión realmente retorna o solo compra tiempo.",
      en: "Validate whether an investment returns value or only buys time.",
    },
    flow: {
      es: "Inversión + timeline → ROI + break-even",
      en: "Investment + timeline → ROI + breakeven",
    },
    example: {
      es: "¿Una franquicia de US$80k es viable o se rompe antes del mes 18?",
      en: "Is a US$100k franchise viable or broken before month 18?",
    },
  },
  {
    icon: "cash",
    name: { es: "Detector de Fugas de Caja", en: "Cash Leak Detector" },
    problem: {
      es: "Identifica exactamente cuándo se acaba la caja si sigues operando igual.",
      en: "Identify exactly when cash runs out if you keep operating the same way.",
    },
    flow: {
      es: "Histórico gasto → Caja en X días",
      en: "Spend history → Cash ends in X days",
    },
    example: {
      es: "Aurora encuentra la fuga dominante sin culpar al síntoma equivocado.",
      en: "Aurora finds the dominant leak instead of blaming the wrong symptom.",
    },
  },
  {
    icon: "expansion",
    name: { es: "Validador de Expansiones", en: "Expansion Validator" },
    problem: {
      es: "Prueba si abrir una nueva unidad mejora el sistema o lo tensiona.",
      en: "Test whether a new location improves the system or overloads it.",
    },
    flow: {
      es: "Nueva sucursal → Viabilidad + escenarios",
      en: "New location → Viability + scenarios",
    },
    example: {
      es: "Compara demanda, alquiler y costo operativo antes de firmar.",
      en: "Compare demand, rent and operating cost before you sign.",
    },
  },
  {
    icon: "pricing",
    name: { es: "Decisor de Pricing", en: "Pricing Decision Engine" },
    problem: {
      es: "Simula impacto de cambios de precio en volumen, margen y caja.",
      en: "Simulate price changes across volume, margin and cash.",
    },
    flow: {
      es: "Precio actual + elasticidad → Precio óptimo + ROAS",
      en: "Current price + elasticity → Optimal price + ROAS",
    },
    example: {
      es: "Subes 12% y Aurora te dice si ganas margen o destruyes demanda.",
      en: "Raise price 12% and Aurora shows whether you gain margin or destroy demand.",
    },
  },
  {
    icon: "marketing",
    name: { es: "Decisor de Marketing", en: "Marketing Decision Engine" },
    problem: {
      es: "Valida si el gasto en marketing genera ROI real o ilusión de crecimiento.",
      en: "Validate if marketing spend creates real ROI or only the illusion of growth.",
    },
    flow: {
      es: "Gasto por canal → CAC + ROAS",
      en: "Channel spend → CAC + ROAS",
    },
    example: {
      es: "Compara performance por canal y prioriza el que sostiene caja.",
      en: "Compare performance by channel and prioritize what actually sustains cash.",
    },
  },
  {
    icon: "hiring",
    name: { es: "Decisor de Contratación", en: "Hiring Decision Engine" },
    problem: {
      es: "Calcula si contratar mejora capacidad o solo agrega peso fijo.",
      en: "Calculate whether a hire improves capacity or only adds fixed weight.",
    },
    flow: {
      es: "Empleado + salario → Impacto en margen",
      en: "Headcount + salary → Margin impact",
    },
    example: {
      es: "Aurora marca el punto exacto donde la contratación pasa a ser palanca.",
      en: "Aurora marks the exact point where the hire becomes a lever.",
    },
  },
] as const;

const governanceRows = [
  {
    id: "DEC-2048",
    actor: { es: "Aurora + CFO", en: "Aurora + CFO" },
    action: { es: "Pricing update", en: "Pricing update" },
    status: { es: "Aprobada", en: "Approved" },
    hash: "8fa3c2d9",
  },
  {
    id: "DEC-2051",
    actor: { es: "Aurora + COO", en: "Aurora + COO" },
    action: { es: "Expansion screening", en: "Expansion screening" },
    status: { es: "Requiere aprobación", en: "Needs approval" },
    hash: "1cd77ab4",
  },
  {
    id: "DEC-2058",
    actor: { es: "Aurora + Growth", en: "Aurora + Growth" },
    action: { es: "Marketing reallocation", en: "Marketing reallocation" },
    status: { es: "Ejecución segura", en: "Safe execution" },
    hash: "53ee0f18",
  },
] as const;
---

<div class="aurora-page" data-lang={locale}>
  <header class="home-header" id="top">
    <div class="home-header__inner">
      <a href={isEn ? "/en/" : "/"} class="home-brand" aria-label="Aurora home">
        <svg class="home-brand__mark" viewBox="0 0 64 64" aria-hidden="true">
          <path d="M16 32a16 16 0 0 1 32 0" fill="none" pathLength="1"></path>
          <path d="M48 32a16 16 0 0 1-16 16" fill="none" pathLength="1"></path>
        </svg>
        <span class="home-brand__word">AURORA</span>
      </a>

      <nav class="home-nav" aria-label="Primary navigation">
        <a href="#system">{nav.system}</a>
        <a href="#applications">{nav.applications}</a>
        <a href="/demo">{nav.demo}</a>
      </nav>

      <div class="lang-switch" aria-label="Language switcher">
        <a href="/" class:list={{ active: !isEn }} aria-current={!isEn ? "page" : undefined}>🇪🇸 ES</a>
        <a href="/en/" class:list={{ active: isEn }} aria-current={isEn ? "page" : undefined}>🇬🇧 EN</a>
      </div>
    </div>
  </header>

  <main>
    <section class="hero-shell" id="hero">
      <canvas id="network-canvas" class="hero-shell__canvas" aria-hidden="true"></canvas>
      <div class="hero-shell__veil hero-shell__veil--left" aria-hidden="true"></div>
      <div class="hero-shell__veil hero-shell__veil--right" aria-hidden="true"></div>

      <div class="section-frame hero-grid">
        <div class="hero-copy">
          <p class="section-label hero-scroll" data-hero-scroll>
            <span></span>
            {hero.scroll}
          </p>
          <p class="hero-kicker">{hero.label}</p>
          <h1 class="hero-headline" aria-label={hero.title}>
            {pick(hero.title).split(" ").map((word) => <span data-hero-word>{word}</span>)}
          </h1>
          <p class="hero-subtitle" data-reveal>{hero.subtitle}</p>
          <div class="hero-actions" data-reveal>
            <a href="#simulator" class="cta cta--primary">{hero.primary}</a>
            <a href="#system" class="cta cta--secondary">{hero.secondary}</a>
          </div>
        </div>

        <aside class="simulator-card" id="simulator" data-reveal>
          <p class="section-label">{hero.simulatorTitle}</p>
          <h2>{isEn ? "Move the decision before it hits the business" : "Mueve la decisión antes de que golpee al negocio"}</h2>
          <p class="simulator-card__intro">{hero.simulatorBody}</p>

          <div class="simulator-controls">
            <label class="sim-field">
              <span>{simulatorLabels.price}</span>
              <div class="sim-field__row">
                <input type="range" min="0" max="30" value="12" step="1" data-sim-input="price" />
                <strong data-sim-readout="price">12%</strong>
              </div>
            </label>
            <label class="sim-field">
              <span>{simulatorLabels.volume}</span>
              <div class="sim-field__row">
                <input type="range" min="0" max="35" value="10" step="1" data-sim-input="volume" />
                <strong data-sim-readout="volume">10%</strong>
              </div>
            </label>
            <label class="sim-field">
              <span>{simulatorLabels.fixed}</span>
              <div class="sim-field__row">
                <input type="range" min="0" max="25" value="6" step="1" data-sim-input="fixed" />
                <strong data-sim-readout="fixed">6%</strong>
              </div>
            </label>
          </div>

          <button type="button" class="simulator-button" data-sim-trigger>{hero.calculate}</button>

          <div class="simulator-results" data-sim-results>
            <article>
              <span>{simulatorLabels.margin}</span>
              <strong data-output="margin" data-value="0">0.0%</strong>
            </article>
            <article>
              <span>{simulatorLabels.cash}</span>
              <strong data-output="cash" data-value="0">0</strong>
            </article>
            <article>
              <span>{simulatorLabels.breakeven}</span>
              <strong data-output="breakeven" data-value="0">$0</strong>
            </article>
          </div>

          <p class="simulator-hint" data-sim-hint>{hero.note}</p>
        </aside>
      </div>
    </section>

    <section class="aurora-section" id="system">
      <div class="section-frame" data-reveal-group>
        <p class="section-label" data-reveal>{systemSection.label}</p>
        <h2 data-reveal>{systemSection.title}</h2>
        <p class="section-intro" data-reveal>{systemSection.intro}</p>

        <div class="card-grid card-grid--modules">
          {modules.map((item) => (
            <article class="info-card" data-reveal tabindex="0">
              <div class="info-card__icon" aria-hidden="true">
                <svg viewBox="0 0 48 48" set:html={icons[item.icon]}></svg>
              </div>
              <p class="info-card__title">{pick(item.name)}</p>
              <p>{pick(item.description)}</p>
              <div class="info-card__detail">
                <p>{pick(item.example)}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="aurora-section aurora-section--tinted" id="applications">
      <div class="section-frame" data-reveal-group>
        <p class="section-label" data-reveal>{applicationSection.label}</p>
        <h2 data-reveal>{applicationSection.title}</h2>
        <p class="section-intro" data-reveal>{applicationSection.intro}</p>

        <div class="card-grid card-grid--applications">
          {applications.map((item) => (
            <article class="application-card" data-reveal>
              <div class="application-card__top">
                <div class="info-card__icon info-card__icon--small" aria-hidden="true">
                  <svg viewBox="0 0 48 48" set:html={icons[item.icon]}></svg>
                </div>
                <p class="info-card__title">{pick(item.name)}</p>
              </div>
              <p>{pick(item.problem)}</p>
              <p class="application-card__flow">{pick(item.flow)}</p>
              <p class="application-card__example">{pick(item.example)}</p>
              <span class="application-card__cta">{isEn ? "Explore" : "Explora"}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="aurora-section aurora-section--operating" id="operating">
      <div class="section-frame operating-layout" data-reveal-group>
        <div>
          <p class="section-label" data-reveal>{operatingSection.label}</p>
          <h2 data-reveal>{operatingSection.title}</h2>
          <p class="section-intro" data-reveal>{operatingSection.body}</p>
        </div>

        <div class="threshold-diagram" data-reveal>
          <div class="threshold-step">{operatingSection.input}</div>
          <div class="threshold-arrow">→</div>
          <div class="threshold-step">{operatingSection.evaluates}</div>
          <div class="threshold-arrow">→</div>
          <div class="threshold-step threshold-step--decision">{operatingSection.threshold}</div>
          <div class="threshold-branches">
            <div>
              <span>YES</span>
              <strong>{operatingSection.execute}</strong>
            </div>
            <div>
              <span>NO</span>
              <strong>{operatingSection.approval}</strong>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="aurora-section aurora-section--governance" id="governance">
      <div class="section-frame" data-reveal-group>
        <p class="section-label" data-reveal>{governanceSection.label}</p>
        <h2 data-reveal>{governanceSection.title}</h2>
        <p class="section-intro" data-reveal>{governanceSection.intro}</p>

        <div class="governance-badges" data-reveal>
          {governanceSection.badges.map((badge) => <span>{badge}</span>)}
        </div>

        <div class="governance-panel" data-reveal>
          <div class="governance-panel__header">
            <div class="info-card__icon" aria-hidden="true">
              <svg viewBox="0 0 48 48" set:html={icons.governance}></svg>
            </div>
            <div>
              <p class="info-card__title">{isEn ? "Audit-ready decision log" : "Decision log listo para auditoría"}</p>
              <p>{isEn ? "Illustrative ledger with decision_id, actor, action, status and hash." : "Ledger ilustrativo con decision_id, actor, acción, estado y hash."}</p>
            </div>
          </div>

          <div class="governance-table">
            <div class="governance-table__head">
              <span>decision_id</span>
              <span>{governanceSection.actor}</span>
              <span>{governanceSection.action}</span>
              <span>{governanceSection.status}</span>
              <span>{governanceSection.hash}</span>
            </div>
            {governanceRows.map((row) => (
              <div class="governance-table__row">
                <span data-label="decision_id">{row.id}</span>
                <span data-label={governanceSection.actor}>{pick(row.actor)}</span>
                <span data-label={governanceSection.action}>{pick(row.action)}</span>
                <span data-label={governanceSection.status}>{pick(row.status)}</span>
                <span data-label={governanceSection.hash}>{row.hash}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="aurora-section aurora-section--cta" id="demo-cta">
      <div class="section-frame final-cta" data-reveal-group>
        <p class="section-label" data-reveal>{ctaSection.label}</p>
        <h2 data-reveal>{ctaSection.title}</h2>
        <p class="section-intro" data-reveal>{ctaSection.body}</p>
        <div class="hero-actions final-cta__actions" data-reveal>
          <a href="/demo" class="cta cta--primary">{ctaSection.primary}</a>
          <a href="mailto:hola@aurora.io?subject=Aurora%20Demo" class="cta cta--secondary">{ctaSection.secondary}</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="home-footer" id="contact">
    <div class="section-frame home-footer__inner">
      <div class="home-footer__links">
        <a href="#system">{nav.system}</a>
        <a href="#applications">{nav.applications}</a>
        <a href="/demo">{nav.demo}</a>
        <a href="#contact">{footer.contact}</a>
