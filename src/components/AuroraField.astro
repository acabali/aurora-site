<div class="aurora-field" data-aurora-field aria-hidden="true">
  <canvas class="aurora-field__canvas"></canvas>
  <div class="aurora-field__veil"></div>
</div>

<style>
  .aurora-field {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 46%, rgba(46, 91, 255, 0.18), transparent 38%),
      radial-gradient(circle at 18% 20%, rgba(0, 195, 137, 0.07), transparent 28%),
      radial-gradient(circle at 76% 28%, rgba(247, 247, 245, 0.04), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.016), rgba(255, 255, 255, 0));
  }

  .aurora-field__canvas,
  .aurora-field__veil {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .aurora-field__canvas {
    display: block;
    opacity: 0.98;
  }

  .aurora-field__veil {
    pointer-events: none;
    background:
      radial-gradient(circle at 50% 50%, transparent 0 36%, rgba(11, 11, 12, 0.14) 56%, rgba(11, 11, 12, 0.78) 100%),
      linear-gradient(180deg, rgba(11, 11, 12, 0.08), rgba(11, 11, 12, 0.54));
  }
</style>

<script>
  const fieldElements = Array.from(document.querySelectorAll<HTMLElement>("[data-aurora-field]"));
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  type NodeType = "primary" | "secondary" | "signal";
  type StateName =
    | "latent"
    | "activation"
    | "tension"
    | "order"
    | "dimension-mode"
    | "contextual"
    | "breakpoint"
    | "comparison"
    | "full-system";
  type SubstateName = "pressure" | "signal" | "scenario" | "structure" | "footprint" | "ledger";
  type FieldState = {
    density: number;
    activity: number;
    tension: number;
    compression: number;
    order: number;
    signal: number;
    trails: number;
    duplication: number;
    comparison: number;
    hierarchy: number;
    breakage: number;
    contextual: number;
    labeling: number;
    glow: number;
    warmth: number;
  };
  type Node = {
    id: number;
    type: NodeType;
    clusterId: number;
    weight: number;
    pressure: number;
    connectionStrength: number;
    x: number;
    y: number;
    vx: number;
    vy: number;
    targetX: number;
    targetY: number;
    baseRadius: number;
    lastX: number;
    lastY: number;
  };
  type Edge = {
    from: number;
    to: number;
    strength: number;
    active: number;
    flash: number;
    cooldown: number;
  };
  type ResponsiveProfile = {
    visibleCount: number;
    pointerAmplitude: number;
    trailsEnabled: boolean;
    duplicateEnabled: boolean;
    gridOpacity: number;
    labelScale: number;
  };

  const clusterNames = ["Costos", "Demanda", "Regulacion", "Competencia"];

  const stateConfigMap: Record<StateName, FieldState> = {
    latent: {
      density: 0.32,
      activity: 0.2,
      tension: 0.12,
      compression: 0.04,
      order: 0.28,
      signal: 0.12,
      trails: 0.16,
      duplication: 0,
      comparison: 0,
      hierarchy: 0.24,
      breakage: 0.02,
      contextual: 0,
      labeling: 0,
      glow: 0.5,
      warmth: 0.02,
    },
    activation: {
      density: 0.48,
      activity: 0.38,
      tension: 0.18,
      compression: 0.08,
      order: 0.36,
      signal: 0.22,
      trails: 0.22,
      duplication: 0,
      comparison: 0,
      hierarchy: 0.34,
      breakage: 0.04,
      contextual: 0,
      labeling: 0,
      glow: 0.62,
      warmth: 0.04,
    },
    tension: {
      density: 0.84,
      activity: 0.76,
      tension: 0.82,
      compression: 0.28,
      order: 0.18,
      signal: 0.24,
      trails: 0.34,
      duplication: 0,
      comparison: 0,
      hierarchy: 0.18,
      breakage: 0.52,
      contextual: 0,
      labeling: 0,
      glow: 0.82,
      warmth: 0.58,
    },
    order: {
      density: 0.76,
      activity: 0.48,
      tension: 0.28,
      compression: 0.12,
      order: 0.92,
      signal: 0.2,
      trails: 0.24,
      duplication: 0,
      comparison: 0,
      hierarchy: 0.9,
      breakage: 0.04,
      contextual: 0.12,
      labeling: 0.14,
      glow: 0.88,
      warmth: 0.04,
    },
    "dimension-mode": {
      density: 0.7,
      activity: 0.54,
      tension: 0.24,
      compression: 0.14,
      order: 0.76,
      signal: 0.3,
      trails: 0.26,
      duplication: 0.08,
      comparison: 0,
      hierarchy: 0.72,
      breakage: 0.08,
      contextual: 0.18,
      labeling: 0.14,
      glow: 0.8,
      warmth: 0.06,
    },
    contextual: {
      density: 0.72,
      activity: 0.52,
      tension: 0.34,
      compression: 0.1,
      order: 0.68,
      signal: 0.28,
      trails: 0.22,
      duplication: 0,
      comparison: 0,
      hierarchy: 0.62,
      breakage: 0.1,
      contextual: 0.88,
      labeling: 0.34,
      glow: 0.76,
      warmth: 0.14,
    },
    breakpoint: {
      density: 0.78,
      activity: 0.72,
      tension: 0.92,
      compression: 0.22,
      order: 0.34,
      signal: 0.24,
      trails: 0.26,
      duplication: 0,
      comparison: 0,
      hierarchy: 0.42,
      breakage: 0.8,
      contextual: 0.08,
      labeling: 0.06,
      glow: 0.88,
      warmth: 0.74,
    },
    comparison: {
      density: 0.68,
      activity: 0.38,
      tension: 0.22,
      compression: 0.1,
      order: 0.72,
      signal: 0.18,
      trails: 0.18,
      duplication: 0,
      comparison: 1,
      hierarchy: 0.7,
      breakage: 0.04,
      contextual: 0.1,
      labeling: 0,
      glow: 0.68,
      warmth: 0.04,
    },
    "full-system": {
      density: 1,
      activity: 0.7,
      tension: 0.42,
      compression: 0.18,
      order: 1,
      signal: 0.4,
      trails: 0.28,
      duplication: 0.12,
      comparison: 0,
      hierarchy: 1,
      breakage: 0.08,
      contextual: 0.2,
      labeling: 0.2,
      glow: 1,
      warmth: 0.08,
    },
  };

  function clamp(value: number, min: number, max: number): number {
    return Math.min(Math.max(value, min), max);
  }

  function lerp(start: number, end: number, amount: number): number {
    return start + (end - start) * amount;
  }

  function easeInOut(t: number): number {
    return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
  }

  function distance(a: { x: number; y: number }, b: { x: number; y: number }): number {
    return Math.hypot(a.x - b.x, a.y - b.y) || 1;
  }

  function makeFieldState(name: StateName, substate: SubstateName | null): FieldState {
    const base = { ...stateConfigMap[name] };

    if (substate === "pressure") {
      base.compression += 0.22;
      base.tension += 0.1;
    } else if (substate === "signal") {
      base.signal += 0.34;
      base.glow += 0.08;
    } else if (substate === "scenario") {
      base.duplication += 0.56;
      base.contextual += 0.12;
    } else if (substate === "structure") {
      base.hierarchy += 0.26;
      base.order += 0.12;
    } else if (substate === "footprint") {
      base.trails += 0.42;
    } else if (substate === "ledger") {
      base.labeling += 0.56;
      base.order += 0.12;
    }

    return base;
  }

  function getResponsiveProfile(width: number): ResponsiveProfile {
    if (width <= 767) {
      return {
        visibleCount: 14,
        pointerAmplitude: 10,
        trailsEnabled: false,
        duplicateEnabled: false,
        gridOpacity: 0.018,
        labelScale: 0.82,
      };
    }

    if (width <= 1120) {
      return {
        visibleCount: 18,
        pointerAmplitude: 12,
        trailsEnabled: true,
        duplicateEnabled: false,
        gridOpacity: 0.022,
        labelScale: 0.92,
      };
    }

    return {
      visibleCount: 22,
      pointerAmplitude: 14,
      trailsEnabled: true,
      duplicateEnabled: true,
      gridOpacity: 0.028,
      labelScale: 1,
    };
  }

  function createNodes(width: number, height: number): Node[] {
    const seeds: Array<{ type: NodeType; clusterId: number; x: number; y: number; radius: number; weight: number }> = [
      { type: "primary", clusterId: 0, x: 0.28, y: 0.28, radius: 5.8, weight: 1 },
      { type: "primary", clusterId: 1, x: 0.7, y: 0.3, radius: 5.6, weight: 1 },
      { type: "primary", clusterId: 2, x: 0.69, y: 0.67, radius: 5.9, weight: 1 },
      { type: "primary", clusterId: 3, x: 0.31, y: 0.68, radius: 5.7, weight: 1 },
      { type: "secondary", clusterId: 0, x: 0.2, y: 0.21, radius: 3.3, weight: 0.62 },
      { type: "secondary", clusterId: 0, x: 0.24, y: 0.37, radius: 3, weight: 0.56 },
      { type: "secondary", clusterId: 0, x: 0.37, y: 0.18, radius: 2.8, weight: 0.48 },
      { type: "secondary", clusterId: 1, x: 0.8, y: 0.22, radius: 3.3, weight: 0.58 },
      { type: "secondary", clusterId: 1, x: 0.76, y: 0.4, radius: 3, weight: 0.52 },
      { type: "secondary", clusterId: 1, x: 0.59, y: 0.18, radius: 2.8, weight: 0.46 },
      { type: "secondary", clusterId: 2, x: 0.8, y: 0.58, radius: 3.2, weight: 0.58 },
      { type: "secondary", clusterId: 2, x: 0.62, y: 0.79, radius: 3.1, weight: 0.52 },
      { type: "secondary", clusterId: 2, x: 0.57, y: 0.61, radius: 2.8, weight: 0.46 },
      { type: "secondary", clusterId: 3, x: 0.22, y: 0.58, radius: 3.2, weight: 0.58 },
      { type: "secondary", clusterId: 3, x: 0.39, y: 0.79, radius: 3.1, weight: 0.52 },
      { type: "secondary", clusterId: 3, x: 0.43, y: 0.61, radius: 2.8, weight: 0.46 },
      { type: "signal", clusterId: 0, x: 0.1, y: 0.5, radius: 2.7, weight: 0.34 },
      { type: "signal", clusterId: 1, x: 0.5, y: 0.1, radius: 2.7, weight: 0.34 },
      { type: "signal", clusterId: 2, x: 0.9, y: 0.47, radius: 2.7, weight: 0.34 },
      { type: "signal", clusterId: 3, x: 0.54, y: 0.9, radius: 2.7, weight: 0.34 },
      { type: "signal", clusterId: 0, x: 0.16, y: 0.78, radius: 2.4, weight: 0.28 },
      { type: "signal", clusterId: 2, x: 0.84, y: 0.78, radius: 2.4, weight: 0.28 },
    ];

    return seeds.map((seed, index) => {
      const x = width * seed.x;
      const y = height * seed.y;
      return {
        id: index,
        type: seed.type,
        clusterId: seed.clusterId,
        weight: seed.weight,
        pressure: 0,
        connectionStrength: 0.6,
        x,
        y,
        vx: 0,
        vy: 0,
        targetX: x,
        targetY: y,
        baseRadius: seed.radius,
        lastX: x,
        lastY: y,
      };
    });
  }

  function createEdges(nodes: Node[]): Edge[] {
    const edges: Edge[] = [];
    const primaryIds = nodes.filter((node) => node.type === "primary").map((node) => node.id);

    nodes.forEach((node) => {
      if (node.type === "primary") {
        return;
      }

      const clusterPrimary = primaryIds[node.clusterId];
      if (clusterPrimary !== undefined) {
        edges.push({ from: clusterPrimary, to: node.id, strength: 0.68, active: 1, flash: 0, cooldown: 0 });
      }
    });

    for (let index = 0; index < primaryIds.length; index += 1) {
      const current = primaryIds[index]!;
      const next = primaryIds[(index + 1) % primaryIds.length]!;
      edges.push({ from: current, to: next, strength: 0.52, active: 1, flash: 0, cooldown: 0 });
    }

    edges.push({ from: primaryIds[0]!, to: primaryIds[2]!, strength: 0.34, active: 1, flash: 0, cooldown: 0 });
    edges.push({ from: primaryIds[1]!, to: primaryIds[3]!, strength: 0.34, active: 1, flash: 0, cooldown: 0 });

    return edges;
  }

  fieldElements.forEach((field) => {
    const canvas = field.querySelector<HTMLCanvasElement>(".aurora-field__canvas");
    const context = canvas?.getContext("2d");

    if (!canvas || !context) {
      return;
    }

    let width = 0;
    let height = 0;
    let animationFrame = 0;
    let scrollFrame = 0;
    let lastTime = 0;
    let nodes: Node[] = [];
    let edges: Edge[] = [];
    let profile = getResponsiveProfile(window.innerWidth);
    const pointer = { x: 0, y: 0, targetX: 0, targetY: 0 };
    const currentState = makeFieldState("latent", null);
    let targetState = makeFieldState("latent", null);
    let activeState: StateName = "latent";
    let activeSubstate: SubstateName | null = null;
    const page = field.closest<HTMLElement>("[data-aurora-page]") ?? document.body;
    const sections = Array.from(page.querySelectorAll<HTMLElement>("[data-aurora-state]"));
    const host = field.closest<HTMLElement>("[data-aurora-field-host]") ?? field;

    function isReducedMotion(): boolean {
      return prefersReducedMotion.matches;
    }

    function resize(): void {
      const bounds = field.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = bounds.width;
      height = bounds.height;
      profile = getResponsiveProfile(width);
      canvas.width = Math.max(1, Math.floor(width * dpr));
      canvas.height = Math.max(1, Math.floor(height * dpr));
      context.setTransform(dpr, 0, 0, dpr, 0, 0);
      nodes = createNodes(width, height);
      edges = createEdges(nodes);
    }

    function getActiveSection(): HTMLElement | null {
      const viewportCenter = window.innerHeight * 0.52;
      let best: HTMLElement | null = null;
      let bestScore = -Infinity;

      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        const visible = Math.min(rect.bottom, window.innerHeight) - Math.max(rect.top, 0);
        const coverage = clamp(visible / Math.max(1, Math.min(rect.height, window.innerHeight)), 0, 1);
        const center = rect.top + rect.height * 0.5;
        const proximity = 1 - clamp(Math.abs(center - viewportCenter) / window.innerHeight, 0, 1);
        const crossesCenter = rect.top <= viewportCenter && rect.bottom >= viewportCenter ? 0.18 : 0;
        const score = coverage * 0.62 + proximity * 0.38 + crossesCenter;

        if (score > bestScore) {
          bestScore = score;
          best = section;
        }
      });

      return best;
    }

    function getActiveSubstate(section: HTMLElement | null): SubstateName | null {
      if (!section) {
        return null;
      }

      const items = Array.from(section.querySelectorAll<HTMLElement>("[data-aurora-substate]"));
      if (!items.length) {
        return null;
      }

      const viewportCenter = window.innerHeight * 0.5;
      let best: SubstateName | null = null;
      let bestScore = -Infinity;

      items.forEach((item) => {
        const rect = item.getBoundingClientRect();
        const visible = Math.min(rect.bottom, window.innerHeight) - Math.max(rect.top, 0);
        const coverage = clamp(visible / Math.max(1, Math.min(rect.height, window.innerHeight)), 0, 1);
        const center = rect.top + rect.height * 0.5;
        const proximity = 1 - clamp(Math.abs(center - viewportCenter) / (window.innerHeight * 0.7), 0, 1);
        const score = coverage * 0.55 + proximity * 0.45;
        const substate = item.dataset.auroraSubstate as SubstateName;

        if (score > bestScore) {
          bestScore = score;
          best = substate;
        }
      });

      return best;
    }

    function syncStateFromScroll(): void {
      scrollFrame = 0;
      const section = getActiveSection();
      const nextState = (section?.dataset.auroraState as StateName | undefined) ?? "latent";
      const nextSubstate = getActiveSubstate(section);
      activeState = nextState;
      activeSubstate = nextSubstate;
      targetState = makeFieldState(nextState, nextSubstate);
      field.dataset.auroraState = nextState;
      page.dataset.auroraState = nextState;
      if (nextSubstate) {
        page.dataset.auroraSubstate = nextSubstate;
      } else {
        delete page.dataset.auroraSubstate;
      }
    }

    function scheduleStateSync(): void {
      if (scrollFrame) {
        return;
      }

      scrollFrame = window.requestAnimationFrame(syncStateFromScroll);
    }

    function handlePointerMove(event: PointerEvent): void {
      const bounds = field.getBoundingClientRect();
      const normalizedX = (event.clientX - bounds.left) / bounds.width - 0.5;
      const normalizedY = (event.clientY - bounds.top) / bounds.height - 0.5;
      pointer.targetX = normalizedX * profile.pointerAmplitude;
      pointer.targetY = normalizedY * profile.pointerAmplitude;
    }

    function handlePointerLeave(): void {
      pointer.targetX = 0;
      pointer.targetY = 0;
    }

    function getClusterCenter(clusterId: number, time: number): { x: number; y: number } {
      const compression = 1 - currentState.compression * 0.34;
      const leftX = width * lerp(0.24, 0.42, currentState.comparison * 0.88);
      const rightX = width * 0.74;
      const topY = height * 0.3;
      const bottomY = height * 0.68;
      const baseTargets = [
        { x: leftX, y: topY },
        { x: rightX, y: topY },
        { x: rightX, y: bottomY },
        { x: leftX, y: bottomY },
      ];
      const base = baseTargets[clusterId]!;
      const shiftX = Math.sin(time * 0.00022 + clusterId * 1.7) * 22 * currentState.activity;
      const shiftY = Math.cos(time * 0.00019 + clusterId * 1.2) * 16 * currentState.activity;
      const centerX = width * 0.5 + (base.x - width * 0.5) * compression;
      const centerY = height * 0.5 + (base.y - height * 0.5) * compression;
      const comparisonPull = clusterId % 2 === 0 ? -width * 0.02 * currentState.comparison : width * 0.02 * currentState.comparison;

      return {
        x: centerX + shiftX + comparisonPull + pointer.x * 0.25,
        y: centerY + shiftY + pointer.y * 0.25,
      };
    }

    function updateNodes(deltaMs: number, time: number): void {
      const delta = clamp(deltaMs / 16.666, 0.65, 1.6);
      const visibleCount = profile.visibleCount;
      const visibleNodes = nodes.slice(0, visibleCount);

      pointer.x += (pointer.targetX - pointer.x) * 0.05;
      pointer.y += (pointer.targetY - pointer.y) * 0.05;

      visibleNodes.forEach((node) => {
        node.lastX = node.x;
        node.lastY = node.y;
        const center = getClusterCenter(node.clusterId, time);
        const radialOffset = node.type === "primary" ? 0 : node.type === "signal" ? 92 : 54;
        const orbit = time * 0.00024 * (0.6 + currentState.activity * 0.8) + node.id * 0.85;
        const jitter = (node.type === "signal" ? 16 : 10) * currentState.activity;
        const orbitScaleX = radialOffset * (0.7 + node.weight * 0.6) * (1 - currentState.order * 0.18);
        const orbitScaleY = orbitScaleX * (0.82 + currentState.tension * 0.18);

        node.targetX =
          center.x +
          Math.cos(orbit) * orbitScaleX +
          Math.sin(orbit * 1.7) * jitter +
          pointer.x * (node.type === "signal" ? 0.6 : 0.34);
        node.targetY =
          center.y +
          Math.sin(orbit * 1.08) * orbitScaleY +
          Math.cos(orbit * 1.5) * jitter +
          pointer.y * (node.type === "signal" ? 0.6 : 0.34);
      });

      visibleNodes.forEach((node, index) => {
        const center = getClusterCenter(node.clusterId, time);
        let forceX = (node.targetX - node.x) * (0.0032 + currentState.order * 0.0028) * delta;
        let forceY = (node.targetY - node.y) * (0.0032 + currentState.order * 0.0028) * delta;

        visibleNodes.forEach((other, otherIndex) => {
          if (index === otherIndex) {
            return;
          }

          const dx = node.x - other.x;
          const dy = node.y - other.y;
          const distSq = dx * dx + dy * dy + 0.001;
          const dist = Math.sqrt(distSq);
          const repel = (node.clusterId === other.clusterId ? 12 : 18) * (0.72 + currentState.density * 0.48) / distSq;
          forceX += (dx / dist) * repel;
          forceY += (dy / dist) * repel;
        });

        visibleNodes.forEach((other) => {
          if (node.id === other.id || node.clusterId !== other.clusterId) {
            return;
          }

          const dx = other.x - node.x;
          const dy = other.y - node.y;
          const dist = Math.max(1, Math.hypot(dx, dy));
          const attract = (0.00045 + currentState.order * 0.0016 + currentState.density * 0.0004) * other.weight * delta;
          forceX += dx * attract;
          forceY += dy * attract;

          node.connectionStrength = clamp(1 - dist / (220 - currentState.compression * 50), 0.12, 1);
        });

        const pressureDist = distance(node, center);
        node.pressure = clamp(pressureDist / (height * 0.24), 0, 1) * (0.26 + currentState.tension * 0.74);

        node.vx = (node.vx + forceX) * (0.86 - currentState.activity * 0.08);
        node.vy = (node.vy + forceY) * (0.86 - currentState.activity * 0.08);

        if (currentState.tension > 0.4) {
          node.vx += Math.sin(time * 0.0014 + node.id) * 0.16 * currentState.tension;
          node.vy += Math.cos(time * 0.0012 + node.id * 1.3) * 0.16 * currentState.tension;
        }

        node.x = clamp(node.x + node.vx * delta, 0, width);
        node.y = clamp(node.y + node.vy * delta, 0, height);
      });
    }

    function updateEdges(deltaMs: number, time: number): void {
      const visibleIds = new Set(nodes.slice(0, profile.visibleCount).map((node) => node.id));

      edges.forEach((edge, index) => {
        if (!visibleIds.has(edge.from) || !visibleIds.has(edge.to)) {
          edge.active = 0;
          return;
        }

        const from = nodes[edge.from]!;
        const to = nodes[edge.to]!;
        const sameCluster = from.clusterId === to.clusterId;
        const dist = distance(from, to);
        const baseStrength = sameCluster ? 0.74 : 0.44;
        const structuralBias = sameCluster ? currentState.order * 0.22 : currentState.hierarchy * 0.14;
        const distancePenalty = dist / (sameCluster ? 280 : 420);
        const pressurePenalty = (from.pressure + to.pressure) * 0.18 * currentState.tension;
        edge.strength = clamp(baseStrength + structuralBias - distancePenalty - pressurePenalty, 0.04, 1);

        if (edge.cooldown > 0) {
          edge.cooldown = Math.max(0, edge.cooldown - deltaMs);
          edge.active = Math.max(0, edge.active - 0.025);
        } else {
          edge.active = lerp(edge.active, 1, 0.08);
        }

        const instability = currentState.breakage * (sameCluster ? 0.75 : 1);
        const flicker = 0.5 + Math.sin(time * 0.0022 + index * 0.6) * 0.5;
        if (instability > 0.12 && edge.cooldown === 0 && edge.strength < 0.34 + instability * 0.12 && flicker > 0.985) {
          edge.flash = 1;
          edge.cooldown = 420 + Math.random() * 520;
          edge.active = 0;
        }

        edge.flash = Math.max(0, edge.flash - 0.06);
      });
    }

    function drawGrid(): void {
      const gridSize = width <= 767 ? 96 : width <= 1120 ? 86 : 74;
      context.strokeStyle = `rgba(255, 255, 255, ${profile.gridOpacity * (0.76 + currentState.order * 0.2)})`;
      context.lineWidth = 1;

      for (let x = 0; x < width; x += gridSize) {
        context.beginPath();
        context.moveTo(x + 0.5, 0);
        context.lineTo(x + 0.5, height);
        context.stroke();
      }

      for (let y = 0; y < height; y += gridSize) {
        context.beginPath();
        context.moveTo(0, y + 0.5);
        context.lineTo(width, y + 0.5);
        context.stroke();
      }
    }

    function drawSurfaceGlow(time: number): void {
      const pulse = isReducedMotion() ? 0.4 : Math.sin(time * 0.00022) * 0.5 + 0.5;
      const glow = context.createRadialGradient(width * 0.52 + pointer.x * 0.4, height * 0.44 + pointer.y * 0.3, 0, width * 0.52, height * 0.48, Math.max(width, height) * (0.26 + currentState.glow * 0.08 + pulse * 0.02));
      glow.addColorStop(0, `rgba(46, 91, 255, ${0.08 + currentState.glow * 0.1})`);
      glow.addColorStop(0.56, `rgba(46, 91, 255, ${0.02 + currentState.glow * 0.04})`);
      glow.addColorStop(1, "rgba(46, 91, 255, 0)");
      context.fillStyle = glow;
      context.fillRect(0, 0, width, height);
    }

    function drawStructuralArc(time: number): void {
      const arcCenterX = width * lerp(0.5, 0.72, currentState.comparison * 0.8);
      const arcCenterY = height * 0.46 + Math.sin(time * 0.00018) * 10 * currentState.activity;
      const radiusX = width * (0.16 + currentState.order * 0.06 - currentState.compression * 0.02);
      const radiusY = radiusX * (0.88 + currentState.order * 0.08);

      context.beginPath();
      context.ellipse(arcCenterX, arcCenterY, radiusX, radiusY, -0.18 + currentState.order * 0.12, Math.PI * 0.96, Math.PI * 2.24);
      context.strokeStyle = `rgba(247, 247, 245, ${0.03 + currentState.order * 0.08})`;
      context.lineWidth = 1 + currentState.order * 0.3;
      context.stroke();

      context.setLineDash([7, 10]);
      context.beginPath();
      context.ellipse(arcCenterX + radiusX * 0.05, arcCenterY + radiusY * 0.05, radiusX * 0.87, radiusY * 0.88, -0.14, Math.PI * 1.02, Math.PI * 2.08);
      context.strokeStyle = `rgba(46, 91, 255, ${0.02 + currentState.glow * 0.06})`;
      context.lineWidth = 0.95;
      context.stroke();
      context.setLineDash([]);
    }

    function drawConnection(from: Node, to: Node, edge: Edge, duplicateOffsetX = 0): void {
      const startX = from.x + duplicateOffsetX;
      const endX = to.x + duplicateOffsetX;
      const dx = endX - startX;
      const dy = to.y - from.y;
      const dist = Math.hypot(dx, dy) || 1;
      const normalX = -dy / dist;
      const normalY = dx / dist;
      const curvature = (from.clusterId === to.clusterId ? 12 : 22) * (1 + currentState.tension * 0.4) * (duplicateOffsetX === 0 ? 1 : 0.76);
      const redMix = currentState.warmth * (0.28 + (1 - edge.strength) * 0.72) + edge.flash * 0.68;
      const blue = Math.round(91 - redMix * 28);
      const green = Math.round(160 - redMix * 90);
      const red = Math.round(46 + redMix * 170);
      const alpha = clamp(edge.strength * edge.active * (0.28 + currentState.density * 0.44), 0, 1);

      context.beginPath();
      context.moveTo(startX, from.y);
      context.quadraticCurveTo((startX + endX) / 2 + normalX * curvature, (from.y + to.y) / 2 + normalY * curvature, endX, to.y);
      context.strokeStyle = `rgba(${red}, ${green}, ${blue}, ${alpha})`;
      context.lineWidth = 0.6 + edge.strength * (1.1 + currentState.hierarchy * 0.45);
      context.stroke();
    }

    function drawNodes(time: number, duplicateOffsetX = 0, alphaMultiplier = 1): void {
      const visibleNodes = nodes.slice(0, profile.visibleCount);

      visibleNodes.forEach((node) => {
        const pulse = isReducedMotion() ? 0.35 : Math.sin(time * 0.0022 + node.id * 0.7) * 0.5 + 0.5;
        const signalBoost = node.type === "signal" ? currentState.signal * 0.22 : 0;
        const glowAlpha = (0.04 + currentState.glow * 0.08 + signalBoost + node.pressure * currentState.warmth * 0.18) * alphaMultiplier;
        const warmth = currentState.warmth * (node.type === "signal" ? 0.5 : 1) + node.pressure * 0.24;
        const coreRed = Math.round(247);
        const coreGreen = Math.round(247 - warmth * 90);
        const coreBlue = Math.round(245 - warmth * 120);
        const glowRed = Math.round(46 + warmth * 150);
        const glowGreen = Math.round(91 + currentState.signal * 54 - warmth * 70);
        const glowBlue = Math.round(255 - warmth * 180);
        const radius = node.baseRadius + node.weight * 1.6 + (node.type === "signal" ? pulse * 0.7 : 0);
        const x = node.x + duplicateOffsetX;

        context.beginPath();
        context.fillStyle = `rgba(${glowRed}, ${glowGreen}, ${glowBlue}, ${glowAlpha})`;
        context.arc(x, node.y, radius * (node.type === "signal" ? 3.4 : 2.7), 0, Math.PI * 2);
        context.fill();

        context.beginPath();
        context.fillStyle = `rgba(${coreRed}, ${coreGreen}, ${coreBlue}, ${0.62 + node.connectionStrength * 0.26})`;
        context.arc(x, node.y, radius, 0, Math.PI * 2);
        context.fill();
      });
    }

    function drawLabels(): void {
      if (currentState.contextual < 0.14 && currentState.labeling < 0.16) {
        return;
      }

      context.save();
      context.font = `${10 * profile.labelScale}px "DM Mono", monospace`;
      context.textBaseline = "middle";

      if (currentState.contextual > 0.14) {
        clusterNames.forEach((name, clusterId) => {
          const center = getClusterCenter(clusterId, performance.now());
          context.fillStyle = `rgba(247, 247, 245, ${0.1 + currentState.contextual * 0.18})`;
          context.fillText(name, center.x + 16, center.y - 18);
        });
      }

      if (currentState.labeling > 0.16) {
        context.fillStyle = `rgba(191, 194, 199, ${0.12 + currentState.labeling * 0.22})`;
        context.fillText("ledger", width * 0.12, height * 0.18);
        context.fillText("footprint", width * 0.72, height * 0.18);
        context.fillText("pressure point", width * 0.64, height * 0.82);
      }

      context.restore();
    }

    function drawComparisonOverlay(): void {
      if (currentState.comparison < 0.1) {
        return;
      }

      const dividerX = width * 0.5;
      context.beginPath();
      context.moveTo(dividerX, height * 0.18);
      context.lineTo(dividerX, height * 0.82);
      context.strokeStyle = `rgba(255, 255, 255, ${0.04 + currentState.comparison * 0.08})`;
      context.lineWidth = 1;
      context.stroke();
    }

    function drawScene(time: number): void {
      const clearAlpha = profile.trailsEnabled && currentState.trails > 0.18 ? 0.12 : 0.26;
      context.fillStyle = `rgba(11, 11, 12, ${clearAlpha})`;
      context.fillRect(0, 0, width, height);
      drawSurfaceGlow(time);
      drawGrid();
      drawStructuralArc(time);

      edges.forEach((edge) => {
        if (edge.active <= 0.01) {
          return;
        }
        drawConnection(nodes[edge.from]!, nodes[edge.to]!, edge);
      });

      if (profile.duplicateEnabled && currentState.duplication > 0.12) {
        const offset = width * (0.06 + currentState.duplication * 0.04);
        context.globalAlpha = 0.18 + currentState.duplication * 0.14;
        edges.forEach((edge) => {
          if (edge.active <= 0.12) {
            return;
          }
          drawConnection(nodes[edge.from]!, nodes[edge.to]!, edge, offset);
        });
        drawNodes(time, offset, 0.62);
        context.globalAlpha = 1;
      }

      if (currentState.comparison > 0.1) {
        context.save();
        context.globalAlpha = 0.32;
        const sparseNodes = nodes.slice(0, 6);
        sparseNodes.forEach((node, index) => {
          if (index < sparseNodes.length - 1) {
            const next = sparseNodes[index + 1]!;
            context.beginPath();
            context.moveTo(node.x * 0.58, node.y);
            context.lineTo(next.x * 0.58, next.y);
            context.strokeStyle = "rgba(255, 255, 255, 0.12)";
            context.lineWidth = 0.8;
            context.stroke();
          }
          context.beginPath();
          context.fillStyle = "rgba(247, 247, 245, 0.78)";
          context.arc(node.x * 0.58, node.y, node.baseRadius * 0.74, 0, Math.PI * 2);
          context.fill();
        });
        context.restore();
      }

      drawNodes(time);
      drawLabels();
      drawComparisonOverlay();
    }

    function tick(time: number): void {
      const deltaMs = lastTime === 0 ? 16.666 : Math.min(time - lastTime, 34);
      lastTime = time;

      (Object.keys(currentState) as Array<keyof FieldState>).forEach((key) => {
        currentState[key] = lerp(currentState[key], targetState[key], isReducedMotion() ? 1 : 0.06);
      });

      updateNodes(deltaMs, time);
      updateEdges(deltaMs, time);
      drawScene(time);

      if (!isReducedMotion()) {
        animationFrame = window.requestAnimationFrame(tick);
      }
    }

    function render(): void {
      window.cancelAnimationFrame(animationFrame);
      lastTime = 0;

      if (isReducedMotion()) {
        pointer.x = 0;
        pointer.y = 0;
        pointer.targetX = 0;
        pointer.targetY = 0;
        (Object.keys(currentState) as Array<keyof FieldState>).forEach((key) => {
          currentState[key] = targetState[key];
        });
        updateNodes(16.666, 0);
        updateEdges(16.666, 0);
        context.clearRect(0, 0, width, height);
        drawScene(0);
        return;
      }

      animationFrame = window.requestAnimationFrame(tick);
    }

    const resizeObserver =
      "ResizeObserver" in window
        ? new ResizeObserver(() => {
            resize();
            render();
          })
        : null;

    resize();
    syncStateFromScroll();
    render();

    host.addEventListener("pointermove", handlePointerMove);
    host.addEventListener("pointerleave", handlePointerLeave);
    window.addEventListener("scroll", scheduleStateSync, { passive: true });
    window.addEventListener("resize", () => {
      resize();
      scheduleStateSync();
      render();
    });
    prefersReducedMotion.addEventListener("change", render);
    resizeObserver?.observe(field);
  });
</script>
