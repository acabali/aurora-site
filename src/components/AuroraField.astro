<div class="aurora-field" data-aurora-field aria-hidden="true">
  <canvas class="aurora-field__canvas"></canvas>
  <div class="aurora-field__veil"></div>
</div>

<style>
  .aurora-field {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background:
      radial-gradient(circle at 52% 42%, rgba(151, 214, 186, 0.08), transparent 28%),
      radial-gradient(circle at 24% 18%, rgba(132, 186, 255, 0.05), transparent 24%),
      radial-gradient(circle at 78% 32%, rgba(255, 235, 195, 0.04), transparent 22%),
      linear-gradient(180deg, rgba(8, 11, 14, 0.08), rgba(8, 11, 14, 0.72));
  }

  .aurora-field__canvas,
  .aurora-field__veil {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .aurora-field__canvas {
    display: block;
  }

  .aurora-field__veil {
    background:
      radial-gradient(circle at 50% 44%, transparent 0 28%, rgba(7, 9, 12, 0.16) 56%, rgba(7, 9, 12, 0.74) 100%),
      linear-gradient(180deg, rgba(7, 9, 12, 0.04), rgba(7, 9, 12, 0.48));
  }
</style>

<script>
  const fields = Array.from(document.querySelectorAll<HTMLElement>("[data-aurora-field]"));
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  type AmbientState = "hero" | "context" | "proof" | "architecture" | "cta";
  type Particle = {
    x: number;
    y: number;
    vx: number;
    vy: number;
    radius: number;
    alpha: number;
    pulse: number;
    hue: number;
  };

  const stateIntensity: Record<AmbientState, { hue: number; pulse: number; drift: number }> = {
    hero: { hue: 152, pulse: 0.72, drift: 0.18 },
    context: { hue: 190, pulse: 0.36, drift: 0.14 },
    proof: { hue: 36, pulse: 0.84, drift: 0.12 },
    architecture: { hue: 214, pulse: 0.4, drift: 0.1 },
    cta: { hue: 152, pulse: 0.54, drift: 0.16 },
  };

  function clamp(value: number, min: number, max: number): number {
    return Math.min(Math.max(value, min), max);
  }

  fields.forEach((field) => {
    const canvas = field.querySelector<HTMLCanvasElement>(".aurora-field__canvas");
    const context = canvas?.getContext("2d");

    if (!canvas || !context) {
      return;
    }

    const host = field.closest<HTMLElement>("[data-aurora-page]") ?? document.body;
    const sections = Array.from(host.querySelectorAll<HTMLElement>("[data-aurora-state]"));
    let width = 0;
    let height = 0;
    let particles: Particle[] = [];
    let animationFrame = 0;
    let lastTime = 0;
    let activeState: AmbientState = "hero";

    function resize(): void {
      const bounds = field.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = Math.max(bounds.width, 1);
      height = Math.max(bounds.height, 1);
      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);
      context.setTransform(dpr, 0, 0, dpr, 0, 0);
      const density = width <= 768 ? 36 : 62;

      particles = Array.from({ length: density }, () => ({
        x: Math.random() * width,
        y: Math.random() * height,
        vx: (Math.random() - 0.5) * 0.035,
        vy: (Math.random() - 0.5) * 0.035,
        radius: 0.7 + Math.random() * 1.5,
        alpha: 0.06 + Math.random() * 0.1,
        pulse: Math.random() * Math.PI * 2,
        hue: 152 + Math.random() * 32,
      }));
    }

    function getActiveState(): AmbientState {
      const viewportCenter = window.innerHeight * 0.48;
      let bestState: AmbientState = "hero";
      let bestScore = -Infinity;

      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        const visible = Math.min(rect.bottom, window.innerHeight) - Math.max(rect.top, 0);
        const coverage = clamp(visible / Math.max(1, Math.min(rect.height, window.innerHeight)), 0, 1);
        const center = rect.top + rect.height * 0.5;
        const proximity = 1 - clamp(Math.abs(center - viewportCenter) / window.innerHeight, 0, 1);
        const score = coverage * 0.7 + proximity * 0.3;

        if (score > bestScore) {
          bestScore = score;
          bestState = (section.dataset.auroraState as AmbientState) || "hero";
        }
      });

      return bestState;
    }

    function draw(time: number): void {
      const delta = Math.min((time - lastTime) / 16.666, 2);
      lastTime = time;
      activeState = getActiveState();
      const mood = stateIntensity[activeState];

      context.clearRect(0, 0, width, height);
      context.fillStyle = "rgba(7, 9, 12, 0.05)";
      context.fillRect(0, 0, width, height);

      particles.forEach((particle, index) => {
        const slow = prefersReducedMotion.matches ? 0.16 : 1;
        const driftX = Math.sin(time * 0.00006 + particle.pulse + index) * mood.drift;
        const driftY = Math.cos(time * 0.00005 + particle.pulse) * mood.drift;

        particle.x += (particle.vx + driftX) * delta * slow;
        particle.y += (particle.vy + driftY) * delta * slow;

        if (particle.x < -8) particle.x = width + 8;
        if (particle.x > width + 8) particle.x = -8;
        if (particle.y < -8) particle.y = height + 8;
        if (particle.y > height + 8) particle.y = -8;

        const eventPulse = 0.5 + Math.sin(time * 0.001 + particle.pulse) * 0.5;
        const alpha = particle.alpha + eventPulse * mood.pulse * 0.05;
        const radius = particle.radius + eventPulse * mood.pulse * 1.2;
        const hue = particle.hue * 0.3 + mood.hue * 0.7;

        context.beginPath();
        context.fillStyle = `hsla(${hue}, 70%, 74%, ${alpha})`;
        context.arc(particle.x, particle.y, radius, 0, Math.PI * 2);
        context.fill();
      });

      animationFrame = window.requestAnimationFrame(draw);
    }

    resize();
    animationFrame = window.requestAnimationFrame(draw);

    window.addEventListener("resize", resize, { passive: true });
    window.addEventListener(
      "beforeunload",
      () => {
        window.cancelAnimationFrame(animationFrame);
      },
      { once: true }
    );
  });
</script>
