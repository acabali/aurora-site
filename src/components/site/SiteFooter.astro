---
interface Props {
  variant?: "default" | "landing";
  currentPath?: string;
}

const { variant = "default", currentPath = "/" } = Astro.props;
const homeHref = currentPath === "/" ? "#top" : "/";
const demoHref = currentPath === "/demo" ? "#top" : "/demo";
---

<footer class:list={["site-footer", variant === "landing" ? "site-footer--landing" : "site-footer--default"]}>
  <div class="site-footer-inner">
    <a href={homeHref} class="site-footer-link" aria-current={currentPath === "/" ? "page" : undefined}>Home</a>
    <a href={demoHref} class="site-footer-link" aria-current={currentPath === "/demo" ? "page" : undefined}>Demo</a>
    <span class="site-footer-copy">© 2026 Aurora</span>
  </div>
</footer>
