---
interface Props {
  variant?: "default" | "landing";
}

const { variant = "default" } = Astro.props;
const isLanding = variant === "landing";
---

<header class:list={["site-header", isLanding ? "site-header--landing" : "site-header--default"]}>
  <div class="site-header-left">
    {isLanding ? (
      <a href="/" class="site-logo-link" aria-label="Aurora inicio">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 24a12 12 0 0 1 24 0" stroke="var(--color-text)" stroke-width="6" stroke-linecap="square" />
          <path d="M36 24a12 12 0 0 1-12 12" stroke="var(--color-text)" stroke-width="6" stroke-linecap="square" />
        </svg>
      </a>
    ) : (
      <a href="/" class="site-logo" aria-label="Aurora inicio">◧</a>
    )}
  </div>

  <nav
    class:list={["site-nav", isLanding ? "site-nav--landing" : "site-nav--default"]}
    aria-label="Navegación principal"
  >
    <a href="/demo">DEMO</a>
  </nav>
</header>
