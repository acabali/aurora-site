---
interface Props {
  variant?: "default" | "landing";
  locale?: "es" | "en";
  demoHref?: string;
  homeHref?: string;
}

const {
  variant = "default",
  locale = "es",
  demoHref = locale === "en" ? "/en/demo" : "/demo",
  homeHref = locale === "en" ? "/en" : "/",
} = Astro.props;
const isLanding = variant === "landing";
const isEn = locale === "en";
---

<header class:list={["site-header", isLanding ? "site-header--landing" : "site-header--default"]}>
  <div class="site-header-left">
    {isLanding ? (
      <a href={homeHref} class="site-logo-link" aria-label="Aurora home">
        <img src="/favicon.svg" alt="Aurora" class="site-logo-image" />
      </a>
    ) : (
      <a href={homeHref} class="site-logo-link" aria-label="Aurora home">
        <img src="/favicon.svg" alt="Aurora" class="site-logo-image site-logo-image--compact" />
      </a>
    )}
  </div>

  <nav
    class:list={["site-nav", isLanding ? "site-nav--landing" : "site-nav--default"]}
    aria-label="Primary navigation"
  >
    {!isLanding && <a href={homeHref}>HOME</a>}
    <a href={demoHref}>DEMO</a>
    {isLanding && (
      <div class="site-lang-switch" aria-label="Language switcher">
        <a href="/" aria-current={!isEn ? "page" : undefined}>ES</a>
        <a href="/en" aria-current={isEn ? "page" : undefined}>EN</a>
      </div>
    )}
  </nav>
</header>
