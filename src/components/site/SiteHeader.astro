---
interface Props {
  variant?: "default" | "landing";
  currentPath?: string;
}

const { variant = "default", currentPath = "/" } = Astro.props;
const demoHref = currentPath === "/demo" ? "#top" : "/demo";
---

<header class:list={["site-header", variant === "landing" ? "site-header--landing" : "site-header--default"]}>
  <a href="/" class="site-logo" aria-label="Aurora">
    <img src="/aurora-logo.png" alt="Aurora" width="88" height="48" />
  </a>

  <nav class="site-nav" aria-label="Principal">
    <a href="/" class="site-nav__link" aria-current={currentPath === "/" ? "page" : undefined}>Inicio</a>
    <a href={demoHref} class="site-nav__cta" aria-current={currentPath === "/demo" ? "page" : undefined}>
      Someter movimiento a cálculo
    </a>
  </nav>
</header>
