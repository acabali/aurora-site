---
interface Props {
  columns?: number;
  gap?: string;
  mobileColumns?: number;
}

const {
  columns = 3,
  gap = "2.5rem",
  mobileColumns = 1
} = Astro.props;
---

<div class="grid" style={`--columns: ${columns}; --gap: ${gap}; --mobile-columns: ${mobileColumns}`}>
  <slot />
</div>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(var(--columns), 1fr);
    gap: var(--gap);
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: repeat(var(--mobile-columns), 1fr);
    }
  }
</style>
