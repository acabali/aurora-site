---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Aurora — Solutions" description="Applied outcomes for complex environments.">
  <div class="page-container">
    <section class="subpage-hero">
      <span class="eyebrow">SOLUTIONS</span>
      <h1>Applied Outcomes</h1>
      <p class="hero-sub">How calculation transforms operational reality across specific domains.</p>
    </section>

    <div class="solutions-list">
      <div class="solution-item">
        <div class="solution-content">
          <h3>Cost Optimization</h3>
          <p>Moving beyond efficiency to structural waste elimination through precise movement timing.</p>
        </div>
      </div>
      <div class="solution-item">
        <div class="solution-content">
          <h3>Growth Strategy</h3>
          <p>Identifying the single vector of highest probability for expansion without overexposure.</p>
        </div>
      </div>
      <div class="solution-item">
        <div class="solution-content">
          <h3>Marketing Strategy</h3>
          <p>Replacing attribution guesswork with structural resonance calculation.</p>
        </div>
      </div>
      <div class="solution-item">
        <div class="solution-content">
          <h3>Investment Evaluation</h3>
          <p>Stress-testing the structural integrity of a capital commitment before execution.</p>
        </div>
      </div>
      <div class="solution-item">
        <div class="solution-content">
          <h3>Decision Support</h3>
          <p>Continuous calculation of the best next move in volatile environments.</p>
        </div>
      </div>
      <div class="solution-item">
        <div class="solution-content">
          <h3>Cash / Runway Control</h3>
          <p>Precision management of survival horizon through structural liability mapping.</p>
        </div>
      </div>
    </div>

    <section class="page-cta">
      <a href="/demo" class="cta-button">→ Put a move under calculation</a>
    </section>
  </div>
</MainLayout>

<style>
  .page-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 80px 24px 120px;
  }
  .subpage-hero {
    margin-bottom: 80px;
  }
  .eyebrow {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--accent-green);
    letter-spacing: 0.15em;
    margin-bottom: 16px;
  }
  h1 {
    font-size: 56px;
    margin-bottom: 24px;
  }
  .hero-sub {
    font-size: 20px;
    max-width: 600px;
  }
  .solutions-list {
    display: flex;
    flex-direction: column;
    gap: 48px;
    margin-bottom: 80px;
  }
  .solution-item {
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .solution-content h3 {
    font-size: 24px;
    margin-bottom: 12px;
    color: var(--text-light);
  }
  .solution-content p {
    font-size: 16px;
    color: var(--text-muted);
    margin: 0;
    max-width: 700px;
  }
  .page-cta {
    text-align: center;
    padding-top: 40px;
  }
  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
    background: var(--accent-blue);
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: transform 0.2s ease;
  }
  .cta-button:hover {
    transform: translateY(-2px);
  }
</style>
