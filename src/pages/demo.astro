---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Aurora — Demo" description="Aurora calcula la estructura real del movimiento.">
  <div class="demo-wrap">

    <!-- Phase 1: Input -->
    <div id="phase-input" class="demo-phase">
      <span class="demo-eyebrow">AURORA / CÁLCULO</span>
      <h1 class="demo-h1">¿Qué decisión estás evaluando?</h1>
      <p class="demo-sub">Escribila en una frase o elegí un ejemplo para arrancar.</p>
      <textarea
        id="movement-input"
        class="demo-textarea"
        placeholder="Abrir una nueva tienda"
        rows="4"
        aria-label="Decisión a analizar"
      ></textarea>

      <div class="demo-examples" aria-label="Ejemplos de decisiones">
        <span class="demo-examples-label">Ejemplos rápidos</span>
        <div class="demo-examples-list">
          <button type="button" class="demo-example" data-example="Abrir una nueva tienda">Abrir una nueva tienda</button>
          <button type="button" class="demo-example" data-example="Subir precios 15%">Subir precios 15%</button>
          <button type="button" class="demo-example" data-example="Lanzar una segunda marca">Lanzar una segunda marca</button>
          <button type="button" class="demo-example" data-example="Vender en Amazon o Mercado Libre">Vender en Amazon o Mercado Libre</button>
          <button type="button" class="demo-example" data-example="Entrar a otro país">Entrar a otro país</button>
          <button type="button" class="demo-example" data-example="Contratar equipo comercial">Contratar equipo comercial</button>
        </div>
      </div>

      <!-- Structural calibrators -->
      <div id="calibrators" class="calibrators" aria-hidden="true">
        <div class="cal-group">
          <span class="cal-label">¿Podés deshacer esta decisión?</span>
          <div class="cal-chips" data-group="reversibility">
            <button type="button" class="chip" data-value="reversible">Fácil</button>
            <button type="button" class="chip selected" data-value="partially-locked">Con costo</button>
            <button type="button" class="chip" data-value="irreversible">No</button>
          </div>
        </div>
        <div class="cal-group">
          <span class="cal-label">¿Qué compromete principalmente?</span>
          <div class="cal-chips" data-group="resource">
            <button type="button" class="chip selected" data-value="capital">Dinero</button>
            <button type="button" class="chip" data-value="headcount">Equipo</button>
            <button type="button" class="chip" data-value="time">Tiempo</button>
            <button type="button" class="chip" data-value="position">Posición</button>
          </div>
        </div>
        <div class="cal-group">
          <span class="cal-label">¿Cuándo se verán los efectos?</span>
          <div class="cal-chips" data-group="horizon">
            <button type="button" class="chip" data-value="under-90">Menos de 3 meses</button>
            <button type="button" class="chip selected" data-value="90-365">3 a 12 meses</button>
            <button type="button" class="chip" data-value="beyond-1y">Más de 1 año</button>
          </div>
        </div>
      </div>

      <div class="demo-actions">
        <button id="btn-calc" class="btn-calc" disabled>Ver análisis</button>
        <span id="input-hint" class="input-hint" role="alert"></span>
      </div>
    </div>

    <!-- Phase 2: Loader -->
    <div id="phase-loader" class="demo-phase demo-phase--hidden">
      <div class="loader-seq" role="status" aria-label="Calculando estructura del movimiento">
        <div class="loader-line">Normalizando estructura de inputs</div>
        <div class="loader-line">Derivando concentración de exposición</div>
        <div class="loader-line">Calculando gradiente de reversión</div>
        <div class="loader-line">Midiendo inercia de compromiso</div>
        <div class="loader-line">Calculando radio de clausura</div>
      </div>
    </div>

    <!-- Phase 3: Results + Lead Gate -->
    <div id="phase-results" class="demo-phase demo-phase--hidden">
      <p class="demo-system-line">Aurora detectó la estructura real del movimiento.</p>

      <!-- Cold mirror: structural translation of the move -->
      <div class="cold-mirror" id="cold-mirror">
        <span class="cold-mirror-label">TRADUCCIÓN ESTRUCTURAL</span>
        <p class="cold-mirror-text" id="cold-mirror-text"></p>
      </div>

      <div class="demo-results">

        <!-- Output 1: Exposure Geometry -->
        <div class="output-block" data-output="geometry">
          <div class="output-block-header">
            <span class="output-block-label">GEOMETRÍA DE EXPOSICIÓN</span>
            <span class="output-shape-tag" id="shape-tag"></span>
          </div>
          <div class="output-field">
            <span class="output-field-key">EXPOSICIÓN DOMINANTE</span>
            <p class="output-field-val" id="geo-dominant"></p>
          </div>
          <div class="output-field">
            <span class="output-field-key">VECTORES SECUNDARIOS</span>
            <div class="output-field-list" id="geo-secondary"></div>
          </div>
        </div>

        <!-- Output 2: Reversal Profile -->
        <div class="output-block" data-output="reversal">
          <div class="output-block-header">
            <span class="output-block-label">PERFIL DE REVERSIÓN</span>
          </div>
          <div class="output-field">
            <span class="output-field-key">SALIDA LIMPIA MÁS TEMPRANA</span>
            <p class="output-field-val" id="rev-exit"></p>
          </div>
          <div class="output-field">
            <span class="output-field-key">PUNTO DE INFLEXIÓN DE COSTO</span>
            <p class="output-field-val" id="rev-inflection"></p>
          </div>
          <div class="output-field">
            <span class="output-field-key">BLOQUEO ESTRUCTURAL</span>
            <p class="output-field-val" id="rev-lockin"></p>
          </div>
        </div>

        <!-- Output 3: Positional Foreclosure -->
        <div class="output-block" data-output="foreclosure">
          <div class="output-block-header">
            <span class="output-block-label">CLAUSURA POSICIONAL</span>
          </div>
          <div class="output-field">
            <span class="output-field-key">POSICIONES CLAUSURADAS</span>
            <div class="output-field-list" id="fc-closed-list"></div>
          </div>
          <div class="output-field">
            <span class="output-field-key">POSICIÓN ABIERTA</span>
            <p class="output-field-val output-open-val" id="fc-open"></p>
          </div>
        </div>

      </div>

      <!-- Structural fingerprint -->
      <div class="fingerprint-block" id="fingerprint-block">
        <div class="fingerprint-header">
          <span class="fingerprint-label">PERFIL ESTRUCTURAL</span>
          <span class="fingerprint-code" id="fingerprint-code">—</span>
        </div>
        <p class="fingerprint-summary" id="fingerprint-summary"></p>
      </div>

      <!-- Decision footprint -->
      <div class="decision-meta">
        <span class="meta-item">
          <span class="meta-key">ID</span>
          <span class="meta-val" id="meta-decision-id">—</span>
        </span>
        <span class="meta-item">
          <span class="meta-key">HASH</span>
          <span class="meta-val" id="meta-decision-hash">—</span>
        </span>
      </div>

      <!-- Lead gate -->
      <div id="lead-gate" class="lead-gate">
        <div class="lead-separator"></div>
        <p class="lead-prompt">Recibe esta evaluación en tu email.</p>
        <form id="lead-form" class="lead-form" novalidate>
          <div class="lead-fields">
            <input id="lead-name"    type="text"  class="lead-input" placeholder="Nombre"              autocomplete="name" />
            <input id="lead-email"   type="email" class="lead-input" placeholder="Email"               autocomplete="email" />
            <input id="lead-company" type="text"  class="lead-input" placeholder="Empresa (opcional)"  autocomplete="organization" />
          </div>
          <div class="lead-actions">
            <button type="submit" id="btn-lead" class="btn-lead">Recibir evaluación</button>
            <span id="lead-error" class="lead-error" role="alert"></span>
          </div>
        </form>
        <div id="lead-confirm" class="lead-confirm demo-phase--hidden">
          <span class="lead-confirmed">Evaluación registrada.</span>
        </div>
      </div>

      <div class="demo-reset-row">
        <button id="btn-reset" class="btn-reset">Calcular otro movimiento</button>
      </div>
    </div>

  </div>
</MainLayout>

<style is:global>
  .demo-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: 96px 24px 120px;
  }

  /* Phase control */
  .demo-phase {
    animation: demoIn 360ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .demo-phase--hidden {
    display: none !important;
  }

  @keyframes demoIn {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Input phase */
  .demo-eyebrow {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-green);
    margin: 0 0 1.75rem;
  }

  .demo-h1 {
    font-size: clamp(32px, 5vw, 48px) !important;
    line-height: 1.15 !important;
    letter-spacing: -0.02em !important;
    font-weight: 700 !important;
    color: var(--text-light) !important;
    margin: 0 0 0.75rem !important;
  }

  .demo-sub {
    font-size: 15px !important;
    color: var(--text-muted) !important;
    line-height: 1.55 !important;
    margin: 0 0 2.5rem !important;
  }

  .demo-textarea {
    display: block;
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    color: var(--text-light);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    padding: 1rem 1.125rem;
    resize: none;
    outline: none;
    transition: border-color 180ms ease;
    margin-bottom: 1.75rem;
  }

  .demo-textarea::placeholder {
    color: rgba(191, 194, 199, 0.35);
  }

  .demo-textarea:focus {
    border-color: rgba(46, 91, 255, 0.4);
  }

  .demo-textarea:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .demo-examples {
    margin-bottom: 1.75rem;
  }

  .demo-examples-label {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(191, 194, 199, 0.42);
    margin-bottom: 0.75rem;
  }

  .demo-examples-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .demo-example {
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.02);
    color: var(--text-muted);
    border-radius: 999px;
    padding: 0.6rem 0.9rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    line-height: 1;
    cursor: pointer;
    transition: border-color 160ms ease, color 160ms ease, background 160ms ease, transform 160ms ease;
  }

  .demo-example:hover {
    border-color: rgba(46, 91, 255, 0.35);
    background: rgba(46, 91, 255, 0.08);
    color: var(--text-light);
    transform: translateY(-1px);
  }

  /* Calibrators */
  .calibrators {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    pointer-events: none;
    transform: translateY(-6px);
    transition:
      max-height 240ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
    margin-bottom: 0;
  }

  .calibrators.is-visible {
    max-height: 320px;
    opacity: 1;
    overflow: visible;
    pointer-events: auto;
    transform: translateY(0);
    margin-bottom: 2rem;
  }

  .cal-group {}

  .cal-label {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(191, 194, 199, 0.38);
    margin-bottom: 0.5rem;
  }

  .cal-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .chip {
    height: 28px;
    padding: 0 0.75rem;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 2px;
    color: rgba(191, 194, 199, 0.45);
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.07em;
    cursor: pointer;
    transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
    white-space: nowrap;
  }

  .chip:hover {
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--text-light);
  }

  .chip.selected {
    border-color: rgba(46, 91, 255, 0.45);
    background: rgba(46, 91, 255, 0.07);
    color: var(--text-light);
  }

  .demo-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .btn-calc {
    height: 48px;
    padding: 0 1.25rem;
    background: var(--accent-blue);
    color: var(--text-light);
    border: none;
    border-radius: 5px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition:
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 220ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease;
  }

  .btn-calc:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(46, 91, 255, 0.3);
  }

  .btn-calc:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .input-hint {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--accent-red);
    display: none;
  }

  .input-hint.visible {
    display: block;
  }

  /* Loader phase */
  .loader-seq {
    padding-top: 0.25rem;
  }

  .loader-line {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.65rem 0;
    color: var(--text-muted);
    opacity: 0.2;
    transition:
      opacity 200ms ease,
      color 200ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .loader-line::before {
    content: '—';
    color: inherit;
    opacity: 0.5;
    width: 1ch;
    flex-shrink: 0;
  }

  .loader-line[data-state="active"] {
    opacity: 1;
    color: var(--text-light);
    transform: translateX(4px);
  }

  .loader-line[data-state="active"]::before {
    content: '→';
    color: var(--accent-blue);
    opacity: 1;
  }

  .loader-line[data-state="done"] {
    opacity: 0.45;
    color: var(--accent-green);
    transform: translateX(0);
  }

  .loader-line[data-state="done"]::before {
    content: '—';
    color: var(--accent-green);
    opacity: 0.8;
  }

  /* Results phase */
  .demo-system-line {
    font-size: 18px !important;
    font-weight: 500 !important;
    letter-spacing: -0.01em;
    line-height: 1.35 !important;
    color: var(--text-light) !important;
    margin: 0 0 3rem !important;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 380ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .demo-system-line.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Cold mirror */
  .cold-mirror {
    border-left: 2px solid rgba(46, 91, 255, 0.22);
    padding: 0.5rem 0 0.5rem 1rem;
    margin-bottom: 2.5rem;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 320ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cold-mirror.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .cold-mirror-label {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(46, 91, 255, 0.4);
    margin-bottom: 0.375rem;
  }

  .cold-mirror-text {
    font-size: 14px !important;
    color: rgba(191, 194, 199, 0.55) !important;
    line-height: 1.65 !important;
    margin: 0 !important;
  }

  /* Structural fingerprint */
  .fingerprint-block {
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 280ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .fingerprint-block.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .fingerprint-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.25rem;
  }

  .fingerprint-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(191, 194, 199, 0.35);
  }

  .fingerprint-code {
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    letter-spacing: 0.12em;
    color: var(--text-light);
  }

  .fingerprint-summary {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.04em;
    color: rgba(191, 194, 199, 0.38);
    margin: 0 !important;
    line-height: 1.5;
  }

  .demo-results {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* Output blocks */
  .output-block {
    padding: 1.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 320ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .output-block.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .output-block-header {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 1.25rem;
  }

  .output-block-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-green);
  }

  .output-shape-tag {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(191, 194, 199, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 2px;
    padding: 0.15rem 0.5rem;
  }

  .output-field {
    margin-bottom: 1rem;
  }

  .output-field:last-child {
    margin-bottom: 0;
  }

  .output-field-key {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(191, 194, 199, 0.32);
    margin-bottom: 0.375rem;
  }

  .output-field-val {
    font-size: 14px !important;
    color: var(--text-muted) !important;
    margin: 0 !important;
    line-height: 1.6 !important;
  }

  .output-open-val {
    font-size: 14px !important;
    color: rgba(100, 130, 255, 0.7) !important;
    margin: 0 !important;
    line-height: 1.6 !important;
  }

  .output-field-list {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .output-list-item {
    font-size: 14px !important;
    color: var(--text-muted) !important;
    margin: 0 !important;
    line-height: 1.55 !important;
    padding-left: 1.125rem;
    position: relative;
  }

  .output-list-item::before {
    content: '—';
    position: absolute;
    left: 0;
    color: rgba(191, 194, 199, 0.22);
    font-family: 'DM Mono', monospace;
  }

  /* Decision footprint */
  .decision-meta {
    display: flex;
    gap: 2rem;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 280ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .decision-meta.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .meta-key {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(191, 194, 199, 0.4);
  }

  .meta-val {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(191, 194, 199, 0.5);
  }

  /* Lead gate */
  .lead-gate {
    margin-top: 0;
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 320ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .lead-gate.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .lead-separator {
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
    margin: 2.5rem 0 2rem;
  }

  .lead-prompt {
    font-size: 14px !important;
    color: var(--text-muted) !important;
    margin: 0 0 1.5rem !important;
    line-height: 1.5 !important;
  }

  .lead-form {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .lead-fields {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-bottom: 1rem;
  }

  .lead-input {
    display: block;
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    color: var(--text-light);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    line-height: 1;
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color 180ms ease;
  }

  .lead-input::placeholder {
    color: rgba(191, 194, 199, 0.35);
  }

  .lead-input:focus {
    border-color: rgba(46, 91, 255, 0.35);
  }

  .lead-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .btn-lead {
    height: 42px;
    padding: 0 1.125rem;
    background: var(--accent-blue);
    color: var(--text-light);
    border: none;
    border-radius: 4px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition:
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 220ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease;
  }

  .btn-lead:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(46, 91, 255, 0.3);
  }

  .btn-lead:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .lead-error {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--accent-red);
    display: none;
  }

  .lead-error.visible {
    display: block;
  }

  .lead-confirm {
    padding: 0.75rem 0 0;
  }

  .lead-confirmed {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-green);
  }

  /* Reset row */
  .demo-reset-row {
    margin-top: 3rem;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 300ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 300ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .demo-reset-row.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .btn-reset {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    color: var(--text-muted);
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.75rem 1.25rem;
    cursor: pointer;
    transition: border-color 180ms ease, color 180ms ease;
  }

  .btn-reset:hover {
    border-color: rgba(255, 255, 255, 0.22);
    color: var(--text-light);
  }

  @media (prefers-reduced-motion: reduce) {
    .demo-phase { animation: none; }
    .demo-system-line,
    .cold-mirror,
    .output-block,
    .fingerprint-block,
    .decision-meta,
    .lead-gate,
    .demo-reset-row {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (max-width: 768px) {
    .demo-wrap {
      padding: 64px 24px 80px;
    }

    .demo-examples-list {
      gap: 0.5rem;
    }

    .demo-example {
      width: 100%;
      justify-content: flex-start;
      text-align: left;
    }
  }
</style>

<script>
  import { analyzeMovement } from '../lib/demoEngine.ts';
  import type { DemoInput, DemoOutput } from '../lib/demoEngine.ts';
  // StructuralFingerprint, Domain included in DemoOutput

  let currentDecision: {
    id:     string;
    hash:   string;
    input:  string;
    output: DemoOutput;
  } | null = null;

  const placeholderSamples = [
    'Abrir una nueva tienda',
    'Subir precios 15%',
    'Lanzar una segunda marca más barata',
    'Vender principalmente en Amazon o Mercado Libre',
    'Entrar a otro país',
    'Contratar un equipo comercial',
    'Cerrar tiendas físicas y vender online',
    'Apostar fuerte a influencers',
  ];

  const defaultChipValues = {
    reversibility: 'partially-locked',
    resource: 'capital',
    horizon: '90-365',
  } as const;

  const textarea = document.getElementById('movement-input') as HTMLTextAreaElement;
  const hint = document.getElementById('input-hint')!;
  const btnCalc = document.getElementById('btn-calc') as HTMLButtonElement;
  const calibrators = document.getElementById('calibrators')!;
  let placeholderIndex = 1;

  // Deterministic 8-char hex hash of input text
  function decisionHash(text: string): string {
    let h = 5381;
    for (let i = 0; i < text.length; i++) {
      h = (Math.imul(33, h) ^ text.charCodeAt(i)) | 0;
    }
    return (h >>> 0).toString(16).padStart(8, '0');
  }

  function showPhase(id: string): void {
    document.querySelectorAll<HTMLElement>('.demo-phase').forEach(p => {
      p.classList.add('demo-phase--hidden');
    });
    document.getElementById('phase-' + id)!.classList.remove('demo-phase--hidden');
  }

  function runLoader(done: () => void): void {
    const lines = document.querySelectorAll<HTMLElement>('.loader-line');
    let i = 0;
    function activate(): void {
      if (i > 0) lines[i - 1]!.dataset.state = 'done';
      if (i < lines.length) {
        lines[i]!.dataset.state = 'active';
        i++;
        setTimeout(activate, 260);
      } else {
        setTimeout(done, 380);
      }
    }
    activate();
  }

  function hasInputText(): boolean {
    return textarea.value.trim().length > 0;
  }

  function setCalibratorsVisible(visible: boolean): void {
    calibrators.classList.toggle('is-visible', visible);
    calibrators.setAttribute('aria-hidden', String(!visible));
  }

  function syncInputState(): void {
    const hasText = hasInputText();
    setCalibratorsVisible(hasText);
    btnCalc.disabled = !hasText || textarea.disabled;

    if (hasText) {
      hint.textContent = '';
      hint.classList.remove('visible');
    }
  }

  function setInputValue(value: string): void {
    textarea.value = value;
    syncInputState();
  }

  function resetCalibrators(): void {
    document.querySelectorAll<HTMLElement>('.cal-chips').forEach(group => {
      const groupName = group.dataset.group as keyof typeof defaultChipValues | undefined;
      if (!groupName) return;

      group.querySelectorAll<HTMLButtonElement>('.chip').forEach(chip => {
        chip.classList.toggle('selected', chip.dataset.value === defaultChipValues[groupName]);
      });
    });
  }

  function rotatePlaceholder(): void {
    if (document.activeElement === textarea || hasInputText() || textarea.disabled) return;
    textarea.placeholder = placeholderSamples[placeholderIndex]!;
    placeholderIndex = (placeholderIndex + 1) % placeholderSamples.length;
  }

  // Read selected chip value from a calibrator group
  function getChipValue(group: string): string {
    const selected = document.querySelector<HTMLElement>(
      `.cal-chips[data-group="${group}"] .chip.selected`
    );
    return selected?.dataset.value ?? '';
  }

  // Initialize chip selectors
  document.querySelectorAll<HTMLElement>('.cal-chips').forEach(group => {
    group.querySelectorAll<HTMLButtonElement>('.chip').forEach(chip => {
      chip.addEventListener('click', () => {
        group.querySelectorAll<HTMLButtonElement>('.chip').forEach(c => c.classList.remove('selected'));
        chip.classList.add('selected');
      });
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.demo-example').forEach(button => {
    button.addEventListener('click', () => {
      const example = button.dataset.example;
      if (!example) return;

      setInputValue(example);
      textarea.focus();
      const end = textarea.value.length;
      textarea.setSelectionRange(end, end);
    });
  });

  textarea.addEventListener('input', syncInputState);
  setInterval(rotatePlaceholder, 1800);
  syncInputState();

  function populateList(containerId: string, items: string[]): void {
    const container = document.getElementById(containerId)!;
    container.innerHTML = '';
    items.forEach(text => {
      const p = document.createElement('p');
      p.className = 'output-list-item';
      p.textContent = text;
      container.appendChild(p);
    });
  }

  function showResults(output: DemoOutput, inputText: string): void {
    const id   = crypto.randomUUID();
    const hash = decisionHash(inputText);
    currentDecision = { id, hash, input: inputText, output };

    // Populate cold mirror
    document.getElementById('cold-mirror-text')!.textContent = output.cold_mirror;

    // Populate geometry block
    const geo = output.exposure_geometry;
    document.getElementById('shape-tag')!.textContent    = geo.shape.toUpperCase();
    document.getElementById('geo-dominant')!.textContent = geo.dominant_exposure;
    populateList('geo-secondary', geo.secondary_exposures);

    // Populate reversal block
    const rev = output.reversal_profile;
    document.getElementById('rev-exit')!.textContent       = rev.earliest_clean_exit;
    document.getElementById('rev-inflection')!.textContent = rev.cost_inflection_point;
    document.getElementById('rev-lockin')!.textContent     = rev.structural_lock_in;

    // Populate foreclosure block
    const fc = output.positional_foreclosure;
    populateList('fc-closed-list', fc.closed_positions);
    document.getElementById('fc-open')!.textContent = fc.open_position;

    // Populate structural fingerprint
    const fp = output.structural_fingerprint;
    document.getElementById('fingerprint-code')!.textContent    = fp.code;
    document.getElementById('fingerprint-summary')!.textContent = fp.summary;

    // Reset reveal states
    const systemLine      = document.querySelector<HTMLElement>('.demo-system-line')!;
    const coldMirrorEl    = document.getElementById('cold-mirror')!;
    const fingerprintEl   = document.getElementById('fingerprint-block')!;
    const decisionMeta    = document.querySelector<HTMLElement>('.decision-meta')!;
    const leadGate        = document.getElementById('lead-gate')!;
    const leadConfirm     = document.getElementById('lead-confirm')!;
    const resetRow        = document.querySelector<HTMLElement>('.demo-reset-row')!;
    const blocks          = document.querySelectorAll<HTMLElement>('.output-block');

    [systemLine, coldMirrorEl, fingerprintEl, decisionMeta, leadGate, resetRow]
      .forEach(el => el.classList.remove('revealed'));
    blocks.forEach(b => b.classList.remove('revealed'));
    leadConfirm.classList.add('demo-phase--hidden');

    // Populate footprint
    document.getElementById('meta-decision-id')!.textContent   = id.slice(0, 8);
    document.getElementById('meta-decision-hash')!.textContent = hash;

    // Reset lead form
    (document.getElementById('lead-name')    as HTMLInputElement).value = '';
    (document.getElementById('lead-email')   as HTMLInputElement).value = '';
    (document.getElementById('lead-company') as HTMLInputElement).value = '';
    const leadErr = document.getElementById('lead-error')!;
    leadErr.textContent = '';
    leadErr.classList.remove('visible');
    (document.getElementById('btn-lead') as HTMLButtonElement).disabled = false;
    document.getElementById('lead-form')!.classList.remove('demo-phase--hidden');

    showPhase('results');

    // Sequential reveal: system → cold mirror → 3 blocks → fingerprint → meta → gate → reset
    setTimeout(() => systemLine.classList.add('revealed'),    60);
    setTimeout(() => coldMirrorEl.classList.add('revealed'), 200);
    blocks.forEach((block, idx) => {
      setTimeout(() => block.classList.add('revealed'), 400 + idx * 200);
    });
    setTimeout(() => fingerprintEl.classList.add('revealed'), 1060);
    setTimeout(() => decisionMeta.classList.add('revealed'),  1160);
    setTimeout(() => leadGate.classList.add('revealed'),      1320);
    setTimeout(() => resetRow.classList.add('revealed'),      1480);
  }

  // Calculate
  btnCalc.addEventListener('click', () => {
    const text     = textarea.value.trim();

    if (!text) {
      hint.textContent = 'Ingresá el movimiento para calcular.';
      hint.classList.add('visible');
      return;
    }

    hint.classList.remove('visible');
    textarea.disabled = true;
    btnCalc.disabled  = true;

    const demoInput: DemoInput = {
      text,
      reversibility: (getChipValue('reversibility') || 'partially-locked') as DemoInput['reversibility'],
      resource:      (getChipValue('resource')      || 'capital')           as DemoInput['resource'],
      horizon:       (getChipValue('horizon')       || '90-365')            as DemoInput['horizon'],
    };

    const output = analyzeMovement(demoInput);

    showPhase('loader');
    runLoader(() => showResults(output, text));
  });

  // Lead form submit
  document.getElementById('lead-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!currentDecision) return;

    const name    = (document.getElementById('lead-name')    as HTMLInputElement).value.trim();
    const email   = (document.getElementById('lead-email')   as HTMLInputElement).value.trim();
    const company = (document.getElementById('lead-company') as HTMLInputElement).value.trim();
    const errEl   = document.getElementById('lead-error')!;
    const btnLead = document.getElementById('btn-lead') as HTMLButtonElement;

    errEl.textContent = '';
    errEl.classList.remove('visible');

    if (!name) {
      errEl.textContent = 'Nombre requerido.';
      errEl.classList.add('visible');
      return;
    }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errEl.textContent = 'Email inválido.';
      errEl.classList.add('visible');
      return;
    }

    btnLead.disabled = true;

    const { id, hash, input, output } = currentDecision;

    // Flatten v2.1 output into legacy Sheets columns
    const payload = {
      decision_id:   id,
      decision_hash: hash,
      timestamp:     new Date().toISOString(),
      input,
      forma:      output.cold_mirror,
      exposicion: `[${output.structural_fingerprint.code}] ${output.exposure_geometry.shape}: ${output.exposure_geometry.dominant_exposure}`,
      presion:    [
        output.reversal_profile.earliest_clean_exit,
        output.reversal_profile.cost_inflection_point,
        output.reversal_profile.structural_lock_in,
      ].join(' | '),
      posicion:   output.positional_foreclosure.closed_positions.join(' | '),
      ventana:    output.positional_foreclosure.open_position,
      name,
      email,
      company:      company || null,
      email_domain: email.split('@')[1] ?? null,
    };

    try {
      const res = await fetch('/api/lead', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(payload),
      });

      if (!res.ok) {
        const body = await res.json().catch(() => ({})) as { error?: string };
        errEl.textContent = body.error ?? 'Error al registrar. Intentá de nuevo.';
        errEl.classList.add('visible');
        btnLead.disabled = false;
        return;
      }

      document.getElementById('lead-form')!.classList.add('demo-phase--hidden');
      document.getElementById('lead-confirm')!.classList.remove('demo-phase--hidden');

    } catch {
      errEl.textContent = 'Error de red. Intentá de nuevo.';
      errEl.classList.add('visible');
      btnLead.disabled = false;
    }
  });

  // Reset
  document.getElementById('btn-reset')!.addEventListener('click', () => {
    currentDecision   = null;
    textarea.disabled = false;
    placeholderIndex = 1;
    textarea.placeholder = placeholderSamples[0]!;
    setInputValue('');
    resetCalibrators();

    document.querySelectorAll<HTMLElement>('.loader-line').forEach(l => {
      delete l.dataset.state;
    });

    hint.textContent = '';
    hint.classList.remove('visible');
    showPhase('input');
    textarea.focus();
  });
</script>
