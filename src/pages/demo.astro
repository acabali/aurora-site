---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Aurora — Demo" description="Aurora calcula la estructura real del movimiento.">
  <div class="demo-wrap">

    <!-- Phase 1: Input -->
    <div id="phase-input" class="demo-phase">
      <span class="demo-eyebrow">AURORA / CÁLCULO</span>
      <h1 class="demo-h1">Describí el movimiento.</h1>
      <p class="demo-sub">Expansión, ajuste, decisión comercial, cambio de estructura.</p>
      <textarea
        id="movement-input"
        class="demo-textarea"
        placeholder="Ej: Voy a abrir una segunda sucursal el próximo mes con financiamiento propio."
        rows="5"
        aria-label="Describí el movimiento a calcular"
      ></textarea>
      <div class="demo-actions">
        <button id="btn-calc" class="btn-calc">Calcular movimiento</button>
        <span id="input-hint" class="input-hint" role="alert"></span>
      </div>
    </div>

    <!-- Phase 2: Loader -->
    <div id="phase-loader" class="demo-phase demo-phase--hidden">
      <div class="loader-seq" role="status" aria-label="Calculando estructura del movimiento">
        <div class="loader-line">Leyendo Forma</div>
        <div class="loader-line">Detectando Exposición</div>
        <div class="loader-line">Midiendo Presión</div>
        <div class="loader-line">Calculando Posición</div>
        <div class="loader-line">Estimando Ventana</div>
      </div>
    </div>

    <!-- Phase 3: Results + Lead Gate -->
    <div id="phase-results" class="demo-phase demo-phase--hidden">
      <p class="demo-system-line">Aurora detectó la estructura real del movimiento.</p>

      <div class="demo-results">
        <div class="result-row" data-result="forma">
          <span class="result-label">FORMA</span>
          <p class="result-text"></p>
        </div>
        <div class="result-row" data-result="exposicion">
          <span class="result-label">EXPOSICIÓN</span>
          <p class="result-text"></p>
        </div>
        <div class="result-row" data-result="presion">
          <span class="result-label">PRESIÓN</span>
          <p class="result-text"></p>
        </div>
        <div class="result-row" data-result="posicion">
          <span class="result-label">POSICIÓN</span>
          <p class="result-text"></p>
        </div>
        <div class="result-row" data-result="ventana">
          <span class="result-label">VENTANA</span>
          <p class="result-text"></p>
        </div>
      </div>

      <!-- Decision footprint -->
      <div class="decision-meta">
        <span class="meta-item">
          <span class="meta-key">ID</span>
          <span class="meta-val" id="meta-decision-id">—</span>
        </span>
        <span class="meta-item">
          <span class="meta-key">HASH</span>
          <span class="meta-val" id="meta-decision-hash">—</span>
        </span>
      </div>

      <!-- Lead gate -->
      <div id="lead-gate" class="lead-gate">
        <div class="lead-separator"></div>
        <p class="lead-prompt">Recibe esta evaluación en tu email.</p>
        <form id="lead-form" class="lead-form" novalidate>
          <div class="lead-fields">
            <input id="lead-name"    type="text"  class="lead-input" placeholder="Nombre"              autocomplete="name" />
            <input id="lead-email"   type="email" class="lead-input" placeholder="Email"               autocomplete="email" />
            <input id="lead-company" type="text"  class="lead-input" placeholder="Empresa (opcional)"  autocomplete="organization" />
          </div>
          <div class="lead-actions">
            <button type="submit" id="btn-lead" class="btn-lead">Recibir evaluación</button>
            <span id="lead-error" class="lead-error" role="alert"></span>
          </div>
        </form>
        <div id="lead-confirm" class="lead-confirm demo-phase--hidden">
          <span class="lead-confirmed">Evaluación registrada.</span>
        </div>
      </div>

      <div class="demo-reset-row">
        <button id="btn-reset" class="btn-reset">Calcular otro movimiento</button>
      </div>
    </div>

  </div>
</MainLayout>

<style is:global>
  .demo-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: 96px 24px 120px;
  }

  /* Phase control */
  .demo-phase {
    animation: demoIn 360ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .demo-phase--hidden {
    display: none !important;
  }

  @keyframes demoIn {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Input phase */
  .demo-eyebrow {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-green);
    margin: 0 0 1.75rem;
  }

  .demo-h1 {
    font-size: clamp(32px, 5vw, 48px) !important;
    line-height: 1.15 !important;
    letter-spacing: -0.02em !important;
    font-weight: 700 !important;
    color: var(--text-light) !important;
    margin: 0 0 0.75rem !important;
  }

  .demo-sub {
    font-size: 15px !important;
    color: var(--text-muted) !important;
    line-height: 1.55 !important;
    margin: 0 0 2.5rem !important;
  }

  .demo-textarea {
    display: block;
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    color: var(--text-light);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    padding: 1rem 1.125rem;
    resize: none;
    outline: none;
    transition: border-color 180ms ease;
    margin-bottom: 1.5rem;
  }

  .demo-textarea::placeholder {
    color: rgba(191, 194, 199, 0.35);
  }

  .demo-textarea:focus {
    border-color: rgba(46, 91, 255, 0.4);
  }

  .demo-textarea:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .demo-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .btn-calc {
    height: 48px;
    padding: 0 1.25rem;
    background: var(--accent-blue);
    color: var(--text-light);
    border: none;
    border-radius: 5px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition:
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 220ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease;
  }

  .btn-calc:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(46, 91, 255, 0.3);
  }

  .btn-calc:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .input-hint {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--accent-red);
    display: none;
  }

  .input-hint.visible {
    display: block;
  }

  /* Loader phase */
  .loader-seq {
    padding-top: 0.25rem;
  }

  .loader-line {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.65rem 0;
    color: var(--text-muted);
    opacity: 0.2;
    transition:
      opacity 200ms ease,
      color 200ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .loader-line::before {
    content: '—';
    color: inherit;
    opacity: 0.5;
    width: 1ch;
    flex-shrink: 0;
  }

  .loader-line[data-state="active"] {
    opacity: 1;
    color: var(--text-light);
    transform: translateX(4px);
  }

  .loader-line[data-state="active"]::before {
    content: '→';
    color: var(--accent-blue);
    opacity: 1;
  }

  .loader-line[data-state="done"] {
    opacity: 0.45;
    color: var(--accent-green);
    transform: translateX(0);
  }

  .loader-line[data-state="done"]::before {
    content: '—';
    color: var(--accent-green);
    opacity: 0.8;
  }

  /* Results phase */
  .demo-system-line {
    font-size: 18px !important;
    font-weight: 500 !important;
    letter-spacing: -0.01em;
    line-height: 1.35 !important;
    color: var(--text-light) !important;
    margin: 0 0 3rem !important;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 380ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .demo-system-line.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .demo-results {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .result-row {
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 300ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 300ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .result-row.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .result-label {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-green);
    margin-bottom: 0.5rem;
  }

  .result-text {
    font-size: 15px !important;
    color: var(--text-muted) !important;
    margin: 0 !important;
    line-height: 1.6 !important;
  }

  /* Decision footprint */
  .decision-meta {
    display: flex;
    gap: 2rem;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 280ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .decision-meta.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .meta-key {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(191, 194, 199, 0.4);
  }

  .meta-val {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(191, 194, 199, 0.5);
  }

  /* Lead gate */
  .lead-gate {
    margin-top: 0;
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 320ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .lead-gate.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .lead-separator {
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
    margin: 2.5rem 0 2rem;
  }

  .lead-prompt {
    font-size: 14px !important;
    color: var(--text-muted) !important;
    margin: 0 0 1.5rem !important;
    line-height: 1.5 !important;
  }

  .lead-form {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .lead-fields {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-bottom: 1rem;
  }

  .lead-input {
    display: block;
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    color: var(--text-light);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    line-height: 1;
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color 180ms ease;
  }

  .lead-input::placeholder {
    color: rgba(191, 194, 199, 0.35);
  }

  .lead-input:focus {
    border-color: rgba(46, 91, 255, 0.35);
  }

  .lead-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .btn-lead {
    height: 42px;
    padding: 0 1.125rem;
    background: var(--accent-blue);
    color: var(--text-light);
    border: none;
    border-radius: 4px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition:
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 220ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease;
  }

  .btn-lead:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(46, 91, 255, 0.3);
  }

  .btn-lead:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .lead-error {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--accent-red);
    display: none;
  }

  .lead-error.visible {
    display: block;
  }

  .lead-confirm {
    padding: 0.75rem 0 0;
  }

  .lead-confirmed {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-green);
  }

  /* Reset row */
  .demo-reset-row {
    margin-top: 3rem;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 300ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 300ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .demo-reset-row.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .btn-reset {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    color: var(--text-muted);
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.75rem 1.25rem;
    cursor: pointer;
    transition: border-color 180ms ease, color 180ms ease;
  }

  .btn-reset:hover {
    border-color: rgba(255, 255, 255, 0.22);
    color: var(--text-light);
  }

  @media (prefers-reduced-motion: reduce) {
    .demo-phase { animation: none; }
    .demo-system-line,
    .result-row,
    .decision-meta,
    .lead-gate,
    .demo-reset-row {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (max-width: 768px) {
    .demo-wrap {
      padding: 64px 24px 80px;
    }
  }
</style>

<script>
  import { analyzeMovement } from '../lib/demoEngine.ts';
  import type { DemoOutput } from '../lib/demoEngine.ts';

  // Decision footprint stored between calc and lead submit
  let currentDecision: {
    id: string;
    hash: string;
    input: string;
    output: DemoOutput;
  } | null = null;

  // Deterministic 8-char hex hash of input text
  function decisionHash(text: string): string {
    let h = 5381;
    for (let i = 0; i < text.length; i++) {
      h = (Math.imul(33, h) ^ text.charCodeAt(i)) | 0;
    }
    return (h >>> 0).toString(16).padStart(8, '0');
  }

  function showPhase(id: string): void {
    document.querySelectorAll<HTMLElement>('.demo-phase').forEach(p => {
      p.classList.add('demo-phase--hidden');
    });
    const el = document.getElementById('phase-' + id)!;
    el.classList.remove('demo-phase--hidden');
  }

  function runLoader(done: () => void): void {
    const lines = document.querySelectorAll<HTMLElement>('.loader-line');
    let i = 0;

    function activate(): void {
      if (i > 0) lines[i - 1]!.dataset.state = 'done';
      if (i < lines.length) {
        lines[i]!.dataset.state = 'active';
        i++;
        setTimeout(activate, 260);
      } else {
        setTimeout(done, 380);
      }
    }

    activate();
  }

  function showResults(output: DemoOutput, input: string): void {
    // Generate decision footprint
    const id   = crypto.randomUUID();
    const hash = decisionHash(input);

    currentDecision = { id, hash, input, output };

    // Populate result rows
    document.querySelectorAll<HTMLElement>('.result-row').forEach(row => {
      const key = row.dataset.result as keyof DemoOutput;
      row.querySelector<HTMLElement>('.result-text')!.textContent = output[key];
      row.classList.remove('revealed');
    });

    // Reset reveal states
    const systemLine   = document.querySelector<HTMLElement>('.demo-system-line')!;
    const decisionMeta = document.querySelector<HTMLElement>('.decision-meta')!;
    const leadGate     = document.getElementById('lead-gate')!;
    const leadConfirm  = document.getElementById('lead-confirm')!;
    const resetRow     = document.querySelector<HTMLElement>('.demo-reset-row')!;
    [systemLine, decisionMeta, leadGate, resetRow].forEach(el => el.classList.remove('revealed'));
    leadConfirm.classList.add('demo-phase--hidden');

    // Populate footprint display (truncated for readability)
    document.getElementById('meta-decision-id')!.textContent   = id.slice(0, 8);
    document.getElementById('meta-decision-hash')!.textContent = hash;

    // Reset lead form
    (document.getElementById('lead-name')  as HTMLInputElement).value = '';
    (document.getElementById('lead-email') as HTMLInputElement).value = '';
    (document.getElementById('lead-company') as HTMLInputElement).value = '';
    const leadErr = document.getElementById('lead-error')!;
    leadErr.textContent = '';
    leadErr.classList.remove('visible');
    (document.getElementById('btn-lead') as HTMLButtonElement).disabled = false;

    showPhase('results');

    // Sequential reveal
    setTimeout(() => systemLine.classList.add('revealed'), 60);
    document.querySelectorAll<HTMLElement>('.result-row').forEach((row, idx) => {
      setTimeout(() => row.classList.add('revealed'), 200 + idx * 100);
    });
    setTimeout(() => decisionMeta.classList.add('revealed'), 760);
    setTimeout(() => leadGate.classList.add('revealed'),     1000);
    setTimeout(() => resetRow.classList.add('revealed'),     1200);
  }

  // Calc
  document.getElementById('btn-calc')!.addEventListener('click', () => {
    const input   = document.getElementById('movement-input') as HTMLTextAreaElement;
    const hint    = document.getElementById('input-hint')!;
    const btnCalc = document.getElementById('btn-calc') as HTMLButtonElement;
    const text    = input.value.trim();

    if (!text) {
      hint.textContent = 'Ingresá el movimiento para calcular.';
      hint.classList.add('visible');
      return;
    }

    hint.classList.remove('visible');
    input.disabled = true;
    btnCalc.disabled = true;

    const output = analyzeMovement(text);

    showPhase('loader');
    runLoader(() => showResults(output, text));
  });

  // Lead form submit
  document.getElementById('lead-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!currentDecision) return;

    const name    = (document.getElementById('lead-name')    as HTMLInputElement).value.trim();
    const email   = (document.getElementById('lead-email')   as HTMLInputElement).value.trim();
    const company = (document.getElementById('lead-company') as HTMLInputElement).value.trim();
    const errEl   = document.getElementById('lead-error')!;
    const btnLead = document.getElementById('btn-lead') as HTMLButtonElement;

    errEl.textContent = '';
    errEl.classList.remove('visible');

    if (!name) {
      errEl.textContent = 'Nombre requerido.';
      errEl.classList.add('visible');
      return;
    }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errEl.textContent = 'Email inválido.';
      errEl.classList.add('visible');
      return;
    }

    btnLead.disabled = true;

    const { id, hash, input, output } = currentDecision;
    const payload = {
      decision_id:   id,
      decision_hash: hash,
      timestamp:     new Date().toISOString(),
      input,
      forma:         output.forma,
      exposicion:    output.exposicion,
      presion:       output.presion,
      posicion:      output.posicion,
      ventana:       output.ventana,
      name,
      email,
      company:      company || null,
      email_domain: email.split('@')[1] ?? null,
    };

    try {
      const res = await fetch('/api/lead', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(payload),
      });

      if (!res.ok) {
        const body = await res.json().catch(() => ({})) as { error?: string };
        errEl.textContent = body.error ?? 'Error al registrar. Intentá de nuevo.';
        errEl.classList.add('visible');
        btnLead.disabled = false;
        return;
      }

      // Hide form, show confirmation
      document.getElementById('lead-form')!.classList.add('demo-phase--hidden');
      document.getElementById('lead-confirm')!.classList.remove('demo-phase--hidden');

    } catch {
      errEl.textContent = 'Error de red. Intentá de nuevo.';
      errEl.classList.add('visible');
      btnLead.disabled = false;
    }
  });

  // Reset
  document.getElementById('btn-reset')!.addEventListener('click', () => {
    const input   = document.getElementById('movement-input') as HTMLTextAreaElement;
    const btnCalc = document.getElementById('btn-calc') as HTMLButtonElement;

    currentDecision = null;
    input.value    = '';
    input.disabled = false;
    btnCalc.disabled = false;

    document.querySelectorAll<HTMLElement>('.loader-line').forEach(l => {
      delete l.dataset.state;
    });

    // Restore lead form visibility for next run
    document.getElementById('lead-form')!.classList.remove('demo-phase--hidden');

    showPhase('input');
    input.focus();
  });
</script>
