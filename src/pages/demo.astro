---
import MainLayout from "../layouts/MainLayout.astro";
import {
  DECISION_ABSORPTION_OPTIONS,
  DECISION_REVERSIBILITY_OPTIONS,
} from "../lib/aurora/decision/types";
---

<MainLayout
  title="Aurora — Demo"
  description="Aurora envía el request canónico al engine real y renderiza la lectura estructural sin fallback local."
  shell="landing"
>
  <section class="decision-demo" data-decision-demo data-status="idle">
    <div class="decision-demo__shell">
      <div class="decision-demo__intro">
        <p class="decision-demo__kicker">Demo de decisión</p>
        <h1>POST /api/decision</h1>
        <p class="decision-demo__lead">
          La interfaz mapea capital, absorción y reversibilidad al contrato canónico. El
          resultado se renderiza únicamente desde la respuesta del engine.
        </p>
        <div class="decision-demo__trace" data-demo-trace>US$ 50.000 · Absorción restringida · Reversibilidad parcial</div>
      </div>

      <div class="decision-demo__grid">
        <form class="decision-form" data-demo-form>
          <input name="protocol" type="hidden" value="vΩ" />

          <label class="decision-form__field">
            <span>capital</span>
            <input name="capital" type="number" min="0" step="1000" value="50000" required />
          </label>

          <label class="decision-form__field">
            <span>absorption</span>
            <select name="absorption">
              {DECISION_ABSORPTION_OPTIONS.map((option) => (
                <option value={option} selected={option === "restricted"}>{option}</option>
              ))}
            </select>
          </label>

          <label class="decision-form__field">
            <span>reversibility</span>
            <select name="reversibility">
              {DECISION_REVERSIBILITY_OPTIONS.map((option) => (
                <option value={option} selected={option === "partial"}>{option}</option>
              ))}
            </select>
          </label>

          <button type="submit" class="decision-form__submit">Evaluate movement</button>
        </form>

        <div class="decision-output">
          <div class="decision-output__status">
            <span class="decision-output__eyebrow">Frontend state</span>
            <p class="decision-output__label" data-demo-status-label>idle</p>
            <p class="decision-output__summary" data-demo-summary>form visible, no request in flight</p>
          </div>

          <div class="decision-output__panel">
            <p class="decision-output__text" data-demo-primary>capital, absorción y reversibilidad quedan mapeados al request canónico.</p>
            <p class="decision-output__text decision-output__text--secondary" data-demo-secondary>el demo no calcula localmente ni completa datos por fuera del engine.</p>
          </div>

          <ul class="decision-output__terminal" data-demo-terminal>
            <li>request.shape</li>
            <li>capital: number</li>
            <li>absorption: yes | restricted | no</li>
            <li>reversibility: full | partial | none</li>
            <li>protocol: vΩ</li>
          </ul>

          <div class="decision-output__meta" data-demo-metrics hidden>
            <p class="decision-output__meta-item" data-demo-pressure-score hidden></p>
            <p class="decision-output__meta-item" data-demo-pressure-day hidden></p>
            <p class="decision-output__meta-item" data-demo-structural-load hidden></p>
          </div>

          <div class="decision-output__creatives" data-demo-creatives hidden>
            <span class="decision-output__eyebrow">Creative variants</span>
            <ul class="decision-output__creative-list" data-demo-creatives-list></ul>
          </div>

          <p class="decision-output__error" data-demo-error></p>

          <button type="button" class="decision-output__retry" data-demo-retry hidden>Retry</button>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .decision-demo {
    padding: 96px 24px 120px;
  }

  .decision-demo__shell {
    width: min(1160px, 100%);
    margin: 0 auto;
    display: grid;
    gap: 2.2rem;
  }

  .decision-demo__intro {
    display: grid;
    gap: 0.9rem;
    max-width: 760px;
  }

  .decision-demo__kicker {
    margin: 0;
    color: var(--color-accent);
    font: 600 11px/1 "Inter", sans-serif;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .decision-demo h1 {
    margin: 0;
    color: var(--color-text);
    font-size: clamp(42px, 7vw, 78px);
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  .decision-demo__lead,
  .decision-demo__trace {
    margin: 0;
  }

  .decision-demo__lead {
    max-width: 36ch;
    color: rgba(244, 246, 242, 0.9);
    font-size: 22px;
    line-height: 1.42;
    letter-spacing: -0.025em;
  }

  .decision-demo__trace {
    color: var(--color-text-secondary);
    font-size: 15px;
    line-height: 1.6;
  }

  .decision-demo__grid {
    display: grid;
    grid-template-columns: minmax(320px, 420px) minmax(0, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .decision-form,
  .decision-output {
    display: grid;
    gap: 1rem;
    padding: 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015)),
      rgba(8, 11, 14, 0.82);
    backdrop-filter: blur(14px);
  }

  .decision-form__field {
    display: grid;
    gap: 0.4rem;
  }

  .decision-form__field span,
  .decision-output__eyebrow {
    color: var(--color-text-secondary);
    font: 600 11px/1 "Inter", sans-serif;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .decision-form input,
  .decision-form select {
    min-height: 48px;
    padding: 0 0.95rem;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.09);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text);
    font: 500 15px/1 "Inter", sans-serif;
  }

  .decision-form__submit,
  .decision-output__retry {
    min-height: 48px;
    padding: 0 1rem;
    border-radius: 999px;
    border: 1px solid rgba(151, 214, 186, 0.28);
    background: rgba(151, 214, 186, 0.12);
    color: var(--color-text);
    font: 600 15px/1 "Inter", sans-serif;
    cursor: pointer;
  }

  .decision-output__status,
  .decision-output__panel {
    display: grid;
    gap: 0.55rem;
  }

  .decision-output__label,
  .decision-output__summary,
  .decision-output__text,
  .decision-output__error {
    margin: 0;
  }

  .decision-output__label {
    color: var(--color-text);
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.04;
    letter-spacing: -0.045em;
  }

  .decision-output__summary,
  .decision-output__text {
    color: rgba(244, 246, 242, 0.9);
    font-size: 17px;
    line-height: 1.68;
  }

  .decision-output__text--secondary,
  .decision-output__error {
    color: var(--color-text-secondary);
    font-size: 15px;
  }

  .decision-output__terminal {
    display: grid;
    gap: 0.45rem;
    margin: 0;
    padding: 1rem;
    list-style: none;
    border: 1px solid rgba(151, 214, 186, 0.14);
    background: rgba(4, 8, 10, 0.92);
    color: #c7ffd9;
    font: 500 13px/1.6 "IBM Plex Mono", monospace;
  }

  .decision-output__meta,
  .decision-output__creatives,
  .decision-output__creative-list {
    display: grid;
    gap: 0.6rem;
  }

  .decision-output__meta {
    padding: 0.95rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
  }

  .decision-output__meta-item,
  .decision-output__creative-item {
    margin: 0;
    color: rgba(244, 246, 242, 0.88);
    font-size: 14px;
    line-height: 1.55;
  }

  .decision-output__creative-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .decision-output__creative-item {
    padding: 0.85rem 1rem;
    border: 1px solid rgba(151, 214, 186, 0.14);
    background: rgba(4, 8, 10, 0.56);
  }

  .decision-output__creative-hook,
  .decision-output__creative-angle {
    display: block;
  }

  .decision-output__creative-hook {
    color: var(--color-text);
    font-size: 15px;
  }

  .decision-output__creative-angle {
    color: var(--color-text-secondary);
    font: 500 12px/1.5 "IBM Plex Mono", monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .decision-output__error:empty {
    display: none;
  }

  [data-decision-demo][data-status="loading"] .decision-output__label {
    color: var(--color-accent-strong);
  }

  [data-decision-demo][data-status="error"] .decision-output__terminal {
    border-color: rgba(255, 125, 102, 0.34);
    color: #ff8c7d;
  }

  [data-decision-demo][data-status="error"] .decision-output__label {
    color: #ff8c7d;
  }

  @media (max-width: 920px) {
    .decision-demo {
      padding: 72px 20px 92px;
    }

    .decision-demo__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (max-width: 640px) {
    .decision-demo h1 {
      font-size: clamp(34px, 12vw, 52px);
    }

    .decision-demo__lead {
      font-size: 18px;
    }
  }
</style>

<script>
  import { mountDecisionDemo } from "../lib/aurora/decision/demoController";

  mountDecisionDemo();
</script>
