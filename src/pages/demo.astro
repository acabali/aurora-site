---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Aurora — Demo" description="Aurora procesa la estructura real del movimiento.">
  <div class="demo-wrap">

    <!-- Phase 1: Hero -->
    <div id="phase-hero" class="demo-phase">
      <span class="demo-eyebrow">AURORA / EVALUACIÓN</span>
      <h1 class="demo-h1">Calcula.<br>No interpreta.</h1>
      <p class="demo-sub">
        Tres variables de entrada. El sistema deriva el resto.
      </p>
      <button id="btn-start" class="btn-start">Iniciar evaluación →</button>
    </div>

    <!-- Phase 2: Inputs -->
    <div id="phase-inputs" class="demo-phase demo-phase--hidden">
      <span class="demo-eyebrow">AURORA / CÁLCULO</span>
      <h2 class="demo-h2">Variables de entrada</h2>

      <!-- Capital -->
      <div class="input-group">
        <label class="input-label" for="input-capital">Capital comprometido (USD)</label>
        <input
          id="input-capital"
          type="number"
          class="demo-number-input"
          placeholder="50000"
          min="0"
          step="1000"
          aria-label="Capital comprometido en dólares"
        />
      </div>

      <!-- Absorption -->
      <div class="input-group">
        <span class="input-label">¿El mercado absorbe este movimiento?</span>
        <div class="cal-chips" data-group="absorption">
          <button type="button" class="chip selected" data-value="yes">Sí</button>
          <button type="button" class="chip" data-value="restricted">Restringido</button>
          <button type="button" class="chip" data-value="no">No</button>
        </div>
      </div>

      <!-- Reversibility -->
      <div class="input-group">
        <span class="input-label">¿Qué tan reversible es?</span>
        <div class="cal-chips" data-group="reversibility">
          <button type="button" class="chip selected" data-value="full">Total</button>
          <button type="button" class="chip" data-value="partial">Parcial</button>
          <button type="button" class="chip" data-value="none">Ninguna</button>
        </div>
      </div>

      <div class="demo-actions">
        <button id="btn-process" class="btn-calc">Procesar movimiento</button>
        <span id="input-hint" class="input-hint" role="alert"></span>
      </div>
    </div>

    <!-- Phase 3: Loader -->
    <div id="phase-loader" class="demo-phase demo-phase--hidden">
      <div class="loader-seq" role="status" aria-label="Procesando movimiento">
        <div class="loader-line">Analizando capital comprometido…</div>
        <div class="loader-line">
          Calculando margen de corrección…
          <span class="loader-badge">≠ INPUT</span>
        </div>
        <div class="loader-line">Detectando interacción dominante…</div>
        <div class="loader-line">
          Estimando ventana crítica…
          <span class="loader-badge">≠ INPUT</span>
        </div>
        <div class="loader-line">Calculando presión de ejecución…</div>
      </div>
    </div>

    <!-- Phase 4: Results -->
    <div id="phase-results" class="demo-phase demo-phase--hidden">

      <!-- Insight -->
      <div class="insight-block" id="insight-block">
        <p class="insight-line" id="insight-0"></p>
        <p class="insight-line" id="insight-1"></p>
        <p class="insight-line insight-line--key" id="insight-2"></p>
      </div>

      <!-- Relationship map -->
      <div class="rel-map" id="rel-map" aria-label="Mapa de relación estructural">
        <div class="rel-node">
          <span class="rel-node-name">Capital</span>
          <span class="rel-node-val" id="map-capital">—</span>
        </div>
        <div class="rel-connector" aria-hidden="true">→</div>
        <div class="rel-node rel-node--derived">
          <span class="rel-derived-tag">← DERIVADO</span>
          <span class="rel-node-name">Ventana de corrección</span>
          <span class="rel-node-val" id="map-window">—</span>
        </div>
        <div class="rel-connector" aria-hidden="true">→</div>
        <div class="rel-node">
          <span class="rel-node-name">Reversibilidad</span>
          <span class="rel-node-val" id="map-reversibility">—</span>
        </div>
      </div>

      <!-- Registration ritual -->
      <div class="reg-ritual" id="reg-ritual">
        <span class="reg-title">Movimiento registrado</span>
        <div class="reg-fields">
          <div class="reg-field">
            <span class="reg-key">ID</span>
            <span class="reg-val" id="reg-id">—</span>
          </div>
          <div class="reg-field">
            <span class="reg-key">HASH</span>
            <span class="reg-val" id="reg-hash">—</span>
          </div>
          <div class="reg-field">
            <span class="reg-key">PRESIÓN</span>
            <span class="reg-val" id="reg-pressure">—</span>
          </div>
          <div class="reg-field">
            <span class="reg-key">VENTANA</span>
            <span class="reg-val" id="reg-window">—</span>
          </div>
          <div class="reg-field">
            <span class="reg-key">TIMESTAMP</span>
            <span class="reg-val" id="reg-ts">—</span>
          </div>
        </div>
        <p class="reg-guarantee">Same movement. Same hash. Always.</p>
      </div>

      <!-- CTA -->
      <div class="cta-block" id="cta-block">
        <button class="btn-cta">Procesar en Aurora →</button>
      </div>

      <!-- Reset -->
      <div class="demo-reset-row" id="reset-row">
        <button id="btn-reset" class="btn-reset">Calcular otro movimiento</button>
      </div>

    </div>

  </div>
</MainLayout>

<style is:global>
  .demo-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: 96px 24px 120px;
  }

  /* Phase control */
  .demo-phase {
    animation: demoIn 360ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .demo-phase--hidden {
    display: none !important;
  }

  @keyframes demoIn {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Shared typography */
  .demo-eyebrow {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-green);
    margin: 0 0 1.75rem;
  }

  .demo-h1 {
    font-size: clamp(36px, 6vw, 64px) !important;
    line-height: 1.08 !important;
    letter-spacing: -0.03em !important;
    font-weight: 700 !important;
    color: var(--text-light) !important;
    margin: 0 0 1rem !important;
  }

  .demo-h2 {
    font-size: clamp(22px, 4vw, 32px) !important;
    line-height: 1.2 !important;
    letter-spacing: -0.02em !important;
    font-weight: 700 !important;
    color: var(--text-light) !important;
    margin: 0 0 2rem !important;
  }

  .demo-sub {
    font-size: 16px !important;
    color: var(--text-muted) !important;
    line-height: 1.6 !important;
    margin: 0 0 2.5rem !important;
  }

  /* Hero CTA */
  .btn-start {
    height: 48px;
    padding: 0 1.5rem;
    background: var(--accent-blue);
    color: var(--text-light);
    border: none;
    border-radius: 5px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition:
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .btn-start:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(46, 91, 255, 0.3);
  }

  /* Input groups */
  .input-group {
    margin-bottom: 2rem;
  }

  .input-label {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(191, 194, 199, 0.45);
    margin-bottom: 0.75rem;
  }

  .demo-number-input {
    display: block;
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    color: var(--text-light);
    font-family: 'DM Mono', monospace;
    font-size: 20px;
    letter-spacing: 0.02em;
    padding: 0.875rem 1rem;
    outline: none;
    transition: border-color 180ms ease;
    -moz-appearance: textfield;
  }

  .demo-number-input::-webkit-outer-spin-button,
  .demo-number-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
  }

  .demo-number-input::placeholder {
    color: rgba(191, 194, 199, 0.22);
  }

  .demo-number-input:focus {
    border-color: rgba(46, 91, 255, 0.4);
  }

  /* Chips */
  .cal-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .chip {
    height: 32px;
    padding: 0 0.875rem;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 2px;
    color: rgba(191, 194, 199, 0.45);
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.07em;
    cursor: pointer;
    transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
    white-space: nowrap;
  }

  .chip:hover {
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--text-light);
  }

  .chip.selected {
    border-color: rgba(46, 91, 255, 0.45);
    background: rgba(46, 91, 255, 0.07);
    color: var(--text-light);
  }

  /* Actions row */
  .demo-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .btn-calc {
    height: 48px;
    padding: 0 1.25rem;
    background: var(--accent-blue);
    color: var(--text-light);
    border: none;
    border-radius: 5px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition:
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .btn-calc:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(46, 91, 255, 0.3);
  }

  .input-hint {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--accent-red);
    display: none;
  }

  .input-hint.visible {
    display: block;
  }

  /* Loader */
  .loader-seq {
    padding-top: 0.25rem;
  }

  .loader-line {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.65rem 0;
    color: var(--text-muted);
    opacity: 0.2;
    transition:
      opacity 200ms ease,
      color 200ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .loader-line::before {
    content: '—';
    color: inherit;
    opacity: 0.5;
    width: 1ch;
    flex-shrink: 0;
  }

  .loader-line[data-state="active"] {
    opacity: 1;
    color: var(--text-light);
    transform: translateX(4px);
  }

  .loader-line[data-state="active"]::before {
    content: '→';
    color: var(--accent-blue);
    opacity: 1;
  }

  .loader-line[data-state="done"] {
    opacity: 0.45;
    color: var(--accent-green);
    transform: translateX(0);
  }

  .loader-line[data-state="done"]::before {
    content: '—';
    color: var(--accent-green);
    opacity: 0.8;
  }

  /* ≠ INPUT badge */
  .loader-badge {
    margin-left: auto;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(46, 91, 255, 0.75);
    border: 1px solid rgba(46, 91, 255, 0.25);
    border-radius: 2px;
    padding: 0.1rem 0.4rem;
    opacity: 0;
    transition: opacity 200ms ease;
    flex-shrink: 0;
  }

  .loader-line[data-state="active"] .loader-badge,
  .loader-line[data-state="done"] .loader-badge {
    opacity: 1;
  }

  /* Insight block */
  .insight-block {
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 380ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .insight-block.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .insight-line {
    font-size: 15px !important;
    color: var(--text-muted) !important;
    line-height: 1.7 !important;
    margin: 0 0 0.375rem !important;
  }

  .insight-line--key {
    font-size: 18px !important;
    font-weight: 500 !important;
    color: var(--text-light) !important;
    border-left: 2px solid rgba(46, 91, 255, 0.45);
    padding-left: 1rem;
    margin-top: 1.25rem !important;
    line-height: 1.5 !important;
  }

  /* Relationship map */
  .rel-map {
    display: flex;
    align-items: stretch;
    margin-bottom: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 4px;
    overflow: hidden;
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 360ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 360ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .rel-map.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .rel-node {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    padding: 1.25rem 0.75rem;
    background: rgba(255, 255, 255, 0.015);
    text-align: center;
  }

  .rel-node--derived {
    background: rgba(46, 91, 255, 0.05);
    border-left:  1px solid rgba(46, 91, 255, 0.14);
    border-right: 1px solid rgba(46, 91, 255, 0.14);
  }

  .rel-derived-tag {
    font-family: 'DM Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(46, 91, 255, 0.6);
    border: 1px solid rgba(46, 91, 255, 0.2);
    border-radius: 2px;
    padding: 0.1rem 0.35rem;
  }

  .rel-node-name {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(191, 194, 199, 0.38);
  }

  .rel-node-val {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--text-light);
    line-height: 1.4;
  }

  .rel-connector {
    display: flex;
    align-items: center;
    padding: 0 0.375rem;
    color: rgba(191, 194, 199, 0.18);
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    flex-shrink: 0;
  }

  /* Registration ritual */
  .reg-ritual {
    padding: 1.5rem 0;
    border-top:    1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    margin-bottom: 2.5rem;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 320ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reg-ritual.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .reg-title {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-green);
    margin-bottom: 1rem;
  }

  .reg-fields {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .reg-field {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  .reg-key {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(191, 194, 199, 0.32);
    min-width: 76px;
    flex-shrink: 0;
  }

  .reg-val {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
    color: rgba(191, 194, 199, 0.6);
    word-break: break-all;
  }

  .reg-guarantee {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.06em;
    color: rgba(191, 194, 199, 0.25);
    margin: 0 !important;
  }

  /* CTA block */
  .cta-block {
    margin-bottom: 2rem;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 300ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 300ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cta-block.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .btn-cta {
    height: 48px;
    padding: 0 1.5rem;
    background: var(--accent-blue);
    color: var(--text-light);
    border: none;
    border-radius: 5px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition:
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .btn-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(46, 91, 255, 0.3);
  }

  /* Reset row */
  .demo-reset-row {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 300ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 300ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .demo-reset-row.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .btn-reset {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    color: var(--text-muted);
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.75rem 1.25rem;
    cursor: pointer;
    transition: border-color 180ms ease, color 180ms ease;
  }

  .btn-reset:hover {
    border-color: rgba(255, 255, 255, 0.22);
    color: var(--text-light);
  }

  /* Responsive */
  @media (max-width: 600px) {
    .demo-wrap {
      padding: 64px 20px 80px;
    }

    .rel-map {
      flex-direction: column;
    }

    .rel-connector {
      padding: 0.375rem 0;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .demo-phase     { animation: none; }
    .insight-block,
    .rel-map,
    .reg-ritual,
    .cta-block,
    .demo-reset-row { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  import { computeMovement } from "../lib/movementEngine";
  import type { Absorption, ReversibilityLevel } from "../lib/movementEngine";
  import { computeMovementHash, movementId } from "../lib/hash";

  // ── Phase control ───────────────────────────────────────────────────────

  function showPhase(id: string): void {
    document.querySelectorAll<HTMLElement>(".demo-phase").forEach((p) => {
      p.classList.add("demo-phase--hidden");
    });
    document.getElementById("phase-" + id)!.classList.remove("demo-phase--hidden");
  }

  // ── Chip selection ──────────────────────────────────────────────────────

  document.querySelectorAll<HTMLElement>(".cal-chips").forEach((group) => {
    group.querySelectorAll<HTMLButtonElement>(".chip").forEach((chip) => {
      chip.addEventListener("click", () => {
        group.querySelectorAll<HTMLButtonElement>(".chip").forEach((c) =>
          c.classList.remove("selected")
        );
        chip.classList.add("selected");
      });
    });
  });

  function getChipValue(group: string): string {
    return (
      document.querySelector<HTMLElement>(
        `.cal-chips[data-group="${group}"] .chip.selected`
      )?.dataset.value ?? ""
    );
  }

  // ── Hero → Inputs ───────────────────────────────────────────────────────

  document.getElementById("btn-start")!.addEventListener("click", () => {
    showPhase("inputs");
    (document.getElementById("input-capital") as HTMLInputElement).focus();
  });

  // ── Loader ──────────────────────────────────────────────────────────────

  function runLoader(done: () => void): void {
    const lines = document.querySelectorAll<HTMLElement>(".loader-line");
    let i = 0;
    function activate(): void {
      if (i > 0) lines[i - 1]!.dataset.state = "done";
      if (i < lines.length) {
        lines[i]!.dataset.state = "active";
        i++;
        setTimeout(activate, 280);
      } else {
        setTimeout(done, 420);
      }
    }
    activate();
  }

  // ── Reveal helper ───────────────────────────────────────────────────────

  function revealEl(id: string, delay: number): void {
    setTimeout(
      () => document.getElementById(id)?.classList.add("revealed"),
      delay
    );
  }

  // ── Process ─────────────────────────────────────────────────────────────

  document.getElementById("btn-process")!.addEventListener("click", async () => {
    const capitalInput = document.getElementById("input-capital") as HTMLInputElement;
    const capital      = parseFloat(capitalInput.value);
    const hint         = document.getElementById("input-hint")!;

    if (!capitalInput.value || isNaN(capital) || capital < 0) {
      hint.textContent = "Ingresá un valor de capital válido.";
      hint.classList.add("visible");
      return;
    }

    hint.classList.remove("visible");

    const absorption    = (getChipValue("absorption")    || "yes")  as Absorption;
    const reversibility = (getChipValue("reversibility") || "full") as ReversibilityLevel;

    // Deterministic engine
    const output = computeMovement({ capital, absorption, reversibility });

    // Reset loader state
    document.querySelectorAll<HTMLElement>(".loader-line").forEach((l) => {
      delete l.dataset.state;
    });

    showPhase("loader");

    runLoader(async () => {
      // Deterministic SHA-256 hash
      const fullHash = await computeMovementHash({
        capital,
        absorption,
        reversibility,
        pressureDay: output.pressureDay,
      });

      const id = movementId(fullHash);
      const ts = new Date().toISOString().slice(0, 19).replace("T", " ") + " UTC";

      // Insight lines (derived, not input)
      const insight = [
        "Este movimiento crea presión antes del resultado.",
        "El capital comprometido reduce el margen de corrección.",
        `La ventana de corrección empieza a cerrarse: día ${output.pressureDay}.`,
      ] as const;

      document.getElementById("insight-0")!.textContent = insight[0];
      document.getElementById("insight-1")!.textContent = insight[1];
      document.getElementById("insight-2")!.textContent = insight[2];

      // Relationship map
      document.getElementById("map-capital")!.textContent =
        `$${capital.toLocaleString("es", { maximumFractionDigits: 0 })}`;
      document.getElementById("map-window")!.textContent =
        `Día ${output.pressureDay} · ${output.correctionWindowDays}d margen`;
      document.getElementById("map-reversibility")!.textContent =
        reversibility === "full"
          ? "Total"
          : reversibility === "partial"
          ? "Parcial"
          : "Ninguna";

      // Registration ritual
      document.getElementById("reg-id")!.textContent       = id;
      document.getElementById("reg-hash")!.textContent     = fullHash.slice(0, 16);
      document.getElementById("reg-pressure")!.textContent = `Día ${output.pressureDay}`;
      document.getElementById("reg-window")!.textContent   = `${output.correctionWindowDays} días`;
      document.getElementById("reg-ts")!.textContent       = ts;

      // Reset reveals
      ["insight-block", "rel-map", "reg-ritual", "cta-block", "reset-row"].forEach(
        (elId) => document.getElementById(elId)?.classList.remove("revealed")
      );

      showPhase("results");

      // Sequential reveal
      revealEl("insight-block", 60);
      revealEl("rel-map",       440);
      revealEl("reg-ritual",    820);
      revealEl("cta-block",     1080);
      revealEl("reset-row",     1280);
    });
  });

  // ── Reset ───────────────────────────────────────────────────────────────

  document.getElementById("btn-reset")!.addEventListener("click", () => {
    (document.getElementById("input-capital") as HTMLInputElement).value = "";

    document
      .querySelectorAll<HTMLButtonElement>('[data-group="absorption"] .chip')
      .forEach((c) => c.classList.toggle("selected", c.dataset.value === "yes"));

    document
      .querySelectorAll<HTMLButtonElement>('[data-group="reversibility"] .chip')
      .forEach((c) => c.classList.toggle("selected", c.dataset.value === "full"));

    const hint = document.getElementById("input-hint")!;
    hint.textContent = "";
    hint.classList.remove("visible");

    showPhase("hero");
  });
</script>
