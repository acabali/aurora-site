---
import MainLayout from "../layouts/MainLayout.astro";
import {
  DECISION_CATEGORY_OPTIONS,
  DECISION_INDUSTRY_OPTIONS,
} from "../lib/aurora/decision/types";
---

<MainLayout
  title="Aurora — Demo"
  description="Aurora prepara un movimiento para el engine real y devuelve una lectura estructural antes de ejecutar."
  shell="landing"
>
  <section class="decision-demo" data-decision-demo data-status="idle">
    <div class="decision-demo__shell">
      <div class="decision-demo__intro">
        <p class="decision-demo__kicker">Demo de decisión</p>
        <h1>Someter movimiento a cálculo</h1>
        <p class="decision-demo__lead">
          La interfaz registra un movimiento, cierra el contrato mínimo y devuelve riesgo,
          contrafactual e identidad de decisión desde un único adapter.
        </p>
        <div class="decision-demo__trace" data-demo-trace>USD 120.000 · Ventas y canales · Movimiento único</div>
      </div>

      <div class="decision-demo__grid">
        <form class="decision-form" data-demo-form>
          <label class="decision-form__field">
            <span>Monto del movimiento (USD)</span>
            <input name="amount" type="number" min="1" step="1000" value="120000" required />
          </label>

          <label class="decision-form__field">
            <span>Caja comprometida a 30 días</span>
            <select name="cashCommitment30d">
              <option value="BAJA">Baja</option>
              <option value="MEDIA" selected>Media</option>
              <option value="ALTA">Alta</option>
            </select>
          </label>

          <label class="decision-form__field">
            <span>Naturaleza del movimiento</span>
            <select name="nature">
              <option value="UNICO" selected>Único</option>
              <option value="RECURRENTE">Recurrente</option>
            </select>
          </label>

          <label class="decision-form__field">
            <span>Categoría</span>
            <select name="category">
              {DECISION_CATEGORY_OPTIONS.map((option) => (
                <option value={option} selected={option === "VENTAS_CANALES"}>
                  {option === "EQUIPAMIENTO"
                    ? "Equipamiento y estructura"
                    : option === "VENTAS_CANALES"
                      ? "Ventas y canales"
                      : "Adquisición paga"}
                </option>
              ))}
            </select>
          </label>

          <label class="decision-form__field">
            <span>Reversibilidad</span>
            <select name="reversibility">
              <option value="ALTA">Alta</option>
              <option value="MEDIA" selected>Media</option>
              <option value="BAJA">Baja</option>
            </select>
          </label>

          <label class="decision-form__field">
            <span>Industria</span>
            <select name="industry">
              {DECISION_INDUSTRY_OPTIONS.map((option) => (
                <option value={option} selected={option === "SAAS"}>
                  {option === "OTRA" ? "Otra" : option}
                </option>
              ))}
            </select>
          </label>

          <button type="submit" class="decision-form__submit">Someter movimiento a cálculo</button>
        </form>

        <div class="decision-output">
          <div class="decision-output__status">
            <span class="decision-output__eyebrow">Lectura del sistema</span>
            <p class="decision-output__label" data-demo-status-label>Listo para calcular</p>
            <p class="decision-output__summary" data-demo-summary>La demo prepara el movimiento para el adapter único de Aurora.</p>
          </div>

          <div class="decision-output__panel">
            <p class="decision-output__text" data-demo-insight>Ingresa el movimiento y ejecuta el cálculo.</p>
            <p class="decision-output__text decision-output__text--secondary" data-demo-counterfactual>El resultado devolverá insight, contrafactual y huella de decisión.</p>
          </div>

          <div class="decision-output__ids">
            <p data-demo-decision-id>decision_id: --</p>
            <p data-demo-decision-hash>decision_hash: --</p>
          </div>

          <ul class="decision-output__evidence" data-demo-evidence></ul>

          <p class="decision-output__error" data-demo-error></p>

          <button type="button" class="decision-output__retry" data-demo-retry hidden>Reintentar cálculo</button>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .decision-demo {
    padding: 96px 24px 120px;
  }

  .decision-demo__shell {
    width: min(1160px, 100%);
    margin: 0 auto;
    display: grid;
    gap: 2.2rem;
  }

  .decision-demo__intro {
    display: grid;
    gap: 0.9rem;
    max-width: 760px;
  }

  .decision-demo__kicker {
    margin: 0;
    color: var(--color-accent);
    font: 600 11px/1 "Inter", sans-serif;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .decision-demo h1 {
    margin: 0;
    color: var(--color-text);
    font-size: clamp(42px, 7vw, 78px);
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  .decision-demo__lead,
  .decision-demo__trace {
    margin: 0;
  }

  .decision-demo__lead {
    max-width: 34ch;
    color: rgba(244, 246, 242, 0.9);
    font-size: 22px;
    line-height: 1.42;
    letter-spacing: -0.025em;
  }

  .decision-demo__trace {
    color: var(--color-text-secondary);
    font-size: 15px;
    line-height: 1.6;
  }

  .decision-demo__grid {
    display: grid;
    grid-template-columns: minmax(320px, 460px) minmax(0, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .decision-form,
  .decision-output {
    display: grid;
    gap: 1rem;
    padding: 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015)),
      rgba(8, 11, 14, 0.82);
    backdrop-filter: blur(14px);
  }

  .decision-form__field {
    display: grid;
    gap: 0.4rem;
  }

  .decision-form__field span,
  .decision-output__eyebrow {
    color: var(--color-text-secondary);
    font: 600 11px/1 "Inter", sans-serif;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .decision-form input,
  .decision-form select {
    min-height: 48px;
    padding: 0 0.95rem;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.09);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text);
    font: 500 15px/1 "Inter", sans-serif;
  }

  .decision-form__submit,
  .decision-output__retry {
    min-height: 48px;
    padding: 0 1rem;
    border-radius: 999px;
    border: 1px solid rgba(151, 214, 186, 0.28);
    background: rgba(151, 214, 186, 0.12);
    color: var(--color-text);
    font: 600 15px/1 "Inter", sans-serif;
    cursor: pointer;
  }

  .decision-output__status,
  .decision-output__panel,
  .decision-output__ids {
    display: grid;
    gap: 0.55rem;
  }

  .decision-output__label,
  .decision-output__summary,
  .decision-output__text,
  .decision-output__ids p,
  .decision-output__evidence li,
  .decision-output__error {
    margin: 0;
  }

  .decision-output__label {
    color: var(--color-text);
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.04;
    letter-spacing: -0.045em;
  }

  .decision-output__summary,
  .decision-output__text {
    color: rgba(244, 246, 242, 0.9);
    font-size: 17px;
    line-height: 1.68;
  }

  .decision-output__text--secondary,
  .decision-output__ids p,
  .decision-output__evidence li,
  .decision-output__error {
    color: var(--color-text-secondary);
    font-size: 15px;
  }

  .decision-output__ids {
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .decision-output__evidence {
    display: grid;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .decision-output__evidence li::before {
    content: "· ";
    color: var(--color-accent);
  }

  .decision-output__error:empty {
    display: none;
  }

  [data-decision-demo][data-status="loading"] .decision-output__label {
    color: var(--color-accent-strong);
  }

  [data-decision-demo][data-status="error"] .decision-output__label {
    color: #ffd08f;
  }

  @media (max-width: 920px) {
    .decision-demo {
      padding: 72px 20px 92px;
    }

    .decision-demo__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (max-width: 640px) {
    .decision-demo h1 {
      font-size: clamp(34px, 12vw, 52px);
    }

    .decision-demo__lead {
      font-size: 18px;
    }
  }
</style>

<script>
  import { mountDecisionDemo } from "../lib/aurora/decision/demoController";

  mountDecisionDemo();
</script>
