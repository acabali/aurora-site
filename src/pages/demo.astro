---
import MainLayout from "../layouts/MainLayout.astro";
import Container from "../components/layout/Container.astro";
import Section from "../components/layout/Section.astro";
import DemoExperience from "../components/system/DemoExperience.astro";
---

<MainLayout title="Demo | Aurora Decision System">
  <Section id="demo-main">
    <Container>
      <div class="demo-intro">
        <h1 class="demo-title">Decision Calculation</h1>
        <p class="demo-subtitle">Map the structural load and pressure points of your next move.</p>
      </div>

      <DemoExperience />
    </Container>
  </Section>
</MainLayout>

<style>
  .demo-intro {
    text-align: center;
    margin-bottom: 5rem;
  }

  .demo-title {
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .demo-subtitle {
    font-size: 20px;
    color: var(--color-text-secondary, #bfc2c7);
  }

  @media (max-width: 768px) {
    .demo-title {
      font-size: 32px;
    }
  }
</style>
