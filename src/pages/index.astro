---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Aurora — Era Experience"
  description="Aurora: arquitectura de decisiones, cálculo soberano y ventaja operativa."
>

<style is:global>
  /* ===========================
     AURORA DESIGN TOKENS
  =========================== */
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500&display=swap');

  :root {
    /* Colors */
    --color-bg:               #0B0B0C;
    --color-bg-layer:         #0E0E10;
    --color-text:             #F7F7F5;
    --color-text-secondary:   #8A8E97;
    --color-text-muted:       #4A4D54;
    --color-accent-blue:      #2E5BFF;
    --color-accent-blue-dim:  rgba(46, 91, 255, 0.12);
    --color-accent-green:     #00C389;
    --color-accent-green-dim: rgba(0, 195, 137, 0.1);
    --color-accent-red:       #FF3D3D;
    --color-accent-red-dim:   rgba(255, 61, 61, 0.1);
    --color-border:           rgba(255, 255, 255, 0.06);
    --color-border-blue:      rgba(46, 91, 255, 0.15);

    /* Typography */
    --font-sans: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: 'DM Mono', 'Courier New', monospace;

    /* Motion */
    --duration-fast:    150ms;
    --duration-normal:  300ms;
    --duration-slow:    600ms;
    --duration-xslow:   1200ms;
    --easing-smooth:    cubic-bezier(0.34, 1.56, 0.64, 1);
    --easing-snappy:    cubic-bezier(0.6, 0, 0.4, 1);
    --easing-out:       cubic-bezier(0.16, 1, 0.3, 1);

    /* Layout */
    --max-width: 1200px;
    --section-padding: clamp(4rem, 8vw, 8rem);
    --section-padding-x: clamp(1.5rem, 5vw, 4rem);
  }

  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    scroll-behavior: auto; /* Lenis maneja esto */
  }

  body {
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ===========================
     KEYFRAMES
  =========================== */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(32px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes line-draw {
    from { clip-path: inset(0 100% 0 0); }
    to   { clip-path: inset(0 0% 0 0); }
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.8); }
  }

  @keyframes scan-line {
    from { transform: translateY(-100%); }
    to   { transform: translateY(100vh); }
  }

  /* ===========================
     REVEAL SYSTEM
  =========================== */
  .reveal {
    opacity: 0;
    animation: fade-up var(--duration-slow) var(--easing-out) forwards;
  }
  .reveal-delay-1  { animation-delay: 0.05s; }
  .reveal-delay-2  { animation-delay: 0.15s; }
  .reveal-delay-3  { animation-delay: 0.28s; }
  .reveal-delay-4  { animation-delay: 0.42s; }
  .reveal-delay-5  { animation-delay: 0.58s; }
  .reveal-delay-6  { animation-delay: 0.72s; }
  .reveal-delay-7  { animation-delay: 0.88s; }
  .reveal-delay-8  { animation-delay: 1.05s; }
</style>

<!-- ===========================
     HEADER STICKY
=========================== -->
<header class="header" id="header">
  <a href="/" class="logo-link" aria-label="Aurora Home">
    <div class="logo-mark">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="14" cy="14" r="12" stroke="var(--color-accent-blue)" stroke-width="1.5" opacity="0.3"/>
        <path d="M14 3 A11 11 0 0 1 25 14" stroke="var(--color-accent-blue)" stroke-width="2" fill="none" stroke-linecap="round"/>
        <circle cx="14" cy="14" r="3" fill="var(--color-accent-blue)" opacity="0.8"/>
        <circle cx="25" cy="14" r="1.5" fill="var(--color-accent-blue)"/>
        <circle cx="14" cy="3" r="1.5" fill="var(--color-accent-blue)" opacity="0.6"/>
      </svg>
      <span class="logo-text">AURORA</span>
    </div>
  </a>
  <nav class="nav" aria-label="Main navigation">
    <a href="/" class="nav-link active">Home</a>
    <a href="/demo" class="nav-link">Demo</a>
    <a href="mailto:hola@aurora.io" class="nav-link nav-link--cta">Contactar</a>
  </nav>
</header>

<style>
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.25rem var(--section-padding-x);
  background: rgba(11, 11, 12, 0.8);
  backdrop-filter: blur(20px) saturate(1.5);
  -webkit-backdrop-filter: blur(20px) saturate(1.5);
  border-bottom: 1px solid var(--color-border);
  transition: border-color var(--duration-normal) ease,
              background var(--duration-normal) ease;
}

.header.scrolled {
  background: rgba(11, 11, 12, 0.95);
  border-color: var(--color-border-blue);
}

.logo-link {
  text-decoration: none;
  transition: opacity var(--duration-normal) ease;
}
.logo-link:hover { opacity: 0.7; }

.logo-mark {
  display: flex;
  align-items: center;
  gap: 0.6rem;
}

.logo-text {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  color: var(--color-text-secondary);
}

.nav {
  display: flex;
  align-items: center;
  gap: 2rem;
}

.nav-link {
  text-decoration: none;
  color: var(--color-text-secondary);
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.02em;
  transition: color var(--duration-fast) ease;
  position: relative;
}

.nav-link::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  right: 0;
  height: 1px;
  background: var(--color-accent-blue);
  transform: scaleX(0);
  transition: transform var(--duration-normal) var(--easing-snappy);
  transform-origin: left;
}

.nav-link:hover,
.nav-link.active {
  color: var(--color-text);
}

.nav-link:hover::after,
.nav-link.active::after {
  transform: scaleX(1);
}

.nav-link--cta {
  padding: 0.5rem 1.25rem;
  background: var(--color-accent-blue-dim);
  border: 1px solid var(--color-border-blue);
  border-radius: 4px;
  color: var(--color-accent-blue);
  font-size: 0.8rem;
  letter-spacing: 0.04em;
}

.nav-link--cta::after { display: none; }

.nav-link--cta:hover {
  background: rgba(46, 91, 255, 0.2);
  color: var(--color-accent-blue);
  border-color: rgba(46, 91, 255, 0.4);
}

@media (max-width: 640px) {
  .header { padding: 1rem 1.25rem; }
  .nav { gap: 1rem; }
  .nav-link { font-size: 0.8rem; }
  .nav-link--cta { display: none; }
}
</style>

<!-- ===========================
     HERO: THREE.JS + REVEAL
=========================== -->
<section class="hero" id="hero">
  <!-- Three.js canvas -->
  <canvas id="network-canvas" class="hero-canvas" aria-hidden="true"></canvas>

  <!-- Grain overlay -->
  <div class="hero-grain" aria-hidden="true"></div>

  <!-- Scan line effect -->
  <div class="hero-scan" aria-hidden="true"></div>

  <!-- Content -->
  <div class="hero-content">
    <!-- Live status indicator -->
    <div class="status-badge reveal reveal-delay-1">
      <span class="status-dot" aria-hidden="true"></span>
      <span>Sistema activo</span>
    </div>

    <h1 class="hero-h1">
      <span class="hero-line reveal reveal-delay-2">El límite humano</span>
      <span class="hero-line reveal reveal-delay-3">ya no alcanza.</span>
    </h1>

    <div class="hero-body">
      <p class="reveal reveal-delay-4">
        El mercado ya no compite con personas.<br>
        <strong>Compite con sistemas.</strong>
      </p>
      <p class="reveal reveal-delay-5">
        Quedarse en intuición es quedar<br>fuera del juego real.
      </p>
    </div>

    <div class="hero-statement reveal reveal-delay-6">
      <p class="statement-main">Aurora no mejora decisiones.</p>
      <p class="statement-main statement-main--accent">Desplaza el límite humano por el cálculo permanente.</p>
    </div>

    <div class="hero-footnote reveal reveal-delay-7">
      <span class="footnote-label">No es digitalización.</span>
      <span class="footnote-divider" aria-hidden="true">—</span>
      <span class="footnote-value">Es sustitución operativa.</span>
    </div>

    <div class="hero-cta reveal reveal-delay-8">
      <a href="/demo" class="btn btn-primary">
        Poner una decisión bajo evidencia
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#problema" class="btn btn-ghost">Ver el problema</a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator reveal reveal-delay-8" aria-hidden="true">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: calc(80px + 4rem) var(--section-padding-x) 4rem;
  overflow: hidden;
  background: var(--color-bg);
}

.hero-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.hero-grain {
  position: absolute;
  inset: 0;
  z-index: 1;
  opacity: 0.025;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  background-size: 200px;
  pointer-events: none;
}

.hero-scan {
  position: absolute;
  inset: 0;
  z-index: 1;
  overflow: hidden;
  pointer-events: none;
}
.hero-scan::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(46,91,255,0.3), transparent);
  animation: scan-line 8s linear infinite;
  animation-delay: 3s;
}

.hero-content {
  position: relative;
  z-index: 10;
  max-width: 780px;
}

/* Status badge */
.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.35rem 0.85rem;
  background: var(--color-bg-layer);
  border: 1px solid var(--color-border);
  border-radius: 2px;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  color: var(--color-text-secondary);
  text-transform: uppercase;
  margin-bottom: 2.5rem;
}

.status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-accent-green);
  animation: pulse-dot 2s ease-in-out infinite;
}

/* H1 */
.hero-h1 {
  display: flex;
  flex-direction: column;
  font-size: clamp(2.8rem, 7.5vw, 5rem);
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -0.03em;
  color: var(--color-text);
  margin-bottom: 2.5rem;
}

.hero-line {
  display: block;
}

/* Body text */
.hero-body {
  margin-bottom: 2.5rem;
}

.hero-body p {
  font-size: clamp(1rem, 2vw, 1.2rem);
  color: var(--color-text-secondary);
  line-height: 1.75;
  margin-bottom: 0.75rem;
}

.hero-body strong {
  color: var(--color-text);
  font-weight: 600;
}

/* Statement */
.hero-statement {
  margin-bottom: 2rem;
  padding: 1.5rem;
  background: rgba(46, 91, 255, 0.04);
  border-left: 2px solid var(--color-accent-blue);
  border-radius: 0 4px 4px 0;
}

.statement-main {
  font-size: clamp(1rem, 2vw, 1.15rem);
  font-weight: 600;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.statement-main--accent {
  color: var(--color-text);
  margin-top: 0.25rem;
}

/* Footnote */
.hero-footnote {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 2.5rem;
  font-family: var(--font-mono);
  font-size: 0.8rem;
}

.footnote-label {
  color: var(--color-text-muted);
  letter-spacing: 0.04em;
}

.footnote-divider {
  color: var(--color-text-muted);
}

.footnote-value {
  color: var(--color-accent-blue);
  font-weight: 500;
  letter-spacing: 0.04em;
}

/* CTAs */
.hero-cta {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  align-items: center;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-sans);
  font-size: 0.875rem;
  font-weight: 600;
  text-decoration: none;
  border-radius: 4px;
  transition: all var(--duration-normal) var(--easing-out);
  letter-spacing: 0.02em;
  white-space: nowrap;
}

.btn-primary {
  padding: 0.875rem 1.75rem;
  background: var(--color-accent-blue);
  color: #fff;
  border: 1px solid var(--color-accent-blue);
}

.btn-primary:hover {
  background: #1e45e8;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(46, 91, 255, 0.35);
}

.btn-ghost {
  padding: 0.875rem 1.75rem;
  background: transparent;
  color: var(--color-text-secondary);
  border: 1px solid var(--color-border);
}

.btn-ghost:hover {
  color: var(--color-text);
  border-color: rgba(255,255,255,0.15);
  background: rgba(255,255,255,0.04);
}

/* Scroll indicator */
.scroll-indicator {
  position: absolute;
  bottom: 2.5rem;
  left: var(--section-padding-x);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  color: var(--color-text-muted);
  text-transform: uppercase;
}

.scroll-line {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, var(--color-text-muted), transparent);
  animation: fade-in 1s ease 2s both;
}

@media (max-width: 768px) {
  .hero { padding: calc(70px + 2.5rem) 1.25rem 3rem; }
  .scroll-indicator { display: none; }
  .hero-statement { padding: 1.25rem; }
}

@media (max-width: 480px) {
  .hero-cta { flex-direction: column; }
  .btn-primary, .btn-ghost { width: 100%; justify-content: center; }
}
</style>

<!-- ===========================
     SECCIÓN 1: PROBLEMA
=========================== -->
<section class="section section-1" id="problema" data-section="1">
  <div class="section-inner">
    <div class="section-label">01 — El problema</div>
    <h2 class="section-h2">Las decisiones se toman<br>fragmentadas.</h2>
    <div class="section-body">
      <p>Las empresas toman decisiones sin ver todas las variables juntas. Información dispersa, procesos sin integración, contextos silenciados.</p>
      <p class="highlight-blue">El costo de no ver el sistema completo<br>crece exponencialmente.</p>
    </div>
    <div class="metric-row">
      <div class="metric">
        <span class="metric-value">73%</span>
        <span class="metric-label">de decisiones críticas se toman sin datos completos</span>
      </div>
      <div class="metric">
        <span class="metric-value">4.2×</span>
        <span class="metric-label">más errores en empresas sin cálculo integrado</span>
      </div>
      <div class="metric">
        <span class="metric-value">18m</span>
        <span class="metric-label">tiempo promedio hasta detectar una decisión incorrecta</span>
      </div>
    </div>
  </div>
</section>

<!-- ===========================
     SECCIÓN 2: CAMBIO
=========================== -->
<section class="section section-2" data-section="2">
  <div class="section-inner">
    <div class="section-label">02 — El cambio</div>
    <h2 class="section-h2">El mercado ya opera<br>con cálculo.</h2>
    <div class="section-body">
      <p>Validar antes de actuar ya es posible. La validación previa no es mejora.</p>
      <p class="highlight-blue" style="font-size: 1.3rem; font-weight: 700;">Es condición de entrada.</p>
      <p>La precisión no optimiza. <strong>Define quién compite.</strong></p>
    </div>
  </div>
</section>

<!-- ===========================
     SECCIÓN 3: DESAJUSTE
=========================== -->
<section class="section section-3" data-section="3">
  <div class="section-inner">
    <div class="section-label">03 — El desajuste</div>
    <h2 class="section-h2">Hoy es más barato<br>operar con cálculo.</h2>
    <div class="section-body">
      <p>La ventaja ya no está en crecer. Está en procesar mejor.</p>
      <p>Seguir expandiendo capas humanas cuando el cálculo ya es superior no es cultura.</p>
      <p class="highlight-red">Es desventaja.</p>
      <p>El mercado premia cálculo. <strong>Penaliza interpretación.</strong></p>
    </div>
  </div>
</section>

<style>
/* ===== SECTIONS BASE ===== */
.section {
  padding: var(--section-padding) var(--section-padding-x);
  position: relative;
  overflow: hidden;
}

.section-inner {
  max-width: var(--max-width);
  margin: 0 auto;
}

.section-label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.18em;
  color: var(--color-text-muted);
  text-transform: uppercase;
  margin-bottom: 2rem;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.section.in-view .section-label {
  opacity: 1;
  transform: translateY(0);
}

.section-h2 {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.025em;
  color: var(--color-text);
  margin-bottom: 2.5rem;
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.7s var(--easing-out) 0.1s,
              transform 0.7s var(--easing-out) 0.1s;
}

.section.in-view .section-h2 {
  opacity: 1;
  transform: translateY(0);
}

.section-body {
  max-width: 640px;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.7s var(--easing-out) 0.2s,
              transform 0.7s var(--easing-out) 0.2s;
}

.section.in-view .section-body {
  opacity: 1;
  transform: translateY(0);
}

.section-body p {
  font-size: clamp(1rem, 2vw, 1.125rem);
  color: var(--color-text-secondary);
  line-height: 1.85;
  margin-bottom: 1.25rem;
}

.section-body strong {
  color: var(--color-text);
  font-weight: 600;
}

.highlight-blue {
  color: var(--color-accent-blue) !important;
  font-weight: 600 !important;
}

.highlight-red {
  color: var(--color-accent-red) !important;
  font-weight: 600 !important;
}

/* Metrics */
.metric-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-top: 3.5rem;
  padding-top: 3rem;
  border-top: 1px solid var(--color-border);
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.7s var(--easing-out) 0.35s,
              transform 0.7s var(--easing-out) 0.35s;
}

.section.in-view .metric-row {
  opacity: 1;
  transform: translateY(0);
}

.metric {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.metric-value {
  font-family: var(--font-mono);
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 500;
  color: var(--color-accent-blue);
  letter-spacing: -0.02em;
}

.metric-label {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  line-height: 1.5;
}

/* Section backgrounds */
.section-1 { background: var(--color-bg); }
.section-2 {
  background: linear-gradient(180deg, var(--color-bg) 0%, rgba(46,91,255,0.025) 100%);
}
.section-3 {
  background: linear-gradient(180deg, rgba(46,91,255,0.015) 0%, rgba(255,61,61,0.02) 100%);
}

@media (max-width: 768px) {
  .metric-row { grid-template-columns: 1fr; gap: 2rem; }
}
</style>

<!-- ===========================
     SECCIÓN 4: RUPTURA BINARIA (CRÍTICA)
=========================== -->
<section class="section section-rupture" id="ruptura" data-section="rupture" data-binary-boundary>
  <div class="section-inner rupture-inner">
    <div class="section-label">04 — La ruptura</div>

    <h2 class="section-h2" style="max-width: 800px">
      La forma de operar cambió.<br>
      <span class="rupture-h2-sub">Antes se reaccionaba. Hoy se ejecuta con ventaja informacional.</span>
    </h2>

    <!-- La pieza central: ANTES / HOY -->
    <div class="rupture-container" id="rupture-container">
      <!-- ANTES -->
      <div class="rupture-side rupture-before">
        <div class="rupture-era-label">
          <span class="era-tag era-tag--before">ANTES</span>
        </div>
        <ul class="rupture-items">
