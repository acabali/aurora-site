---
import PageLayout from "../layouts/PageLayout.astro";
import DecisionField from "../components/system/DecisionField.astro";
import { home_narrativa_ajustada } from "../content/home";

const { hero, blocks } = home_narrativa_ajustada;
---

<PageLayout title="Aurora" page="home">
  <DecisionField />

  <nav
    id="products-menu"
    class="products-menu"
    data-products-menu
    aria-label="Selector de algoritmos"
    hidden
  >
    <section id="productos" class="products-console" aria-labelledby="products-heading-system">
      <section class="products-group" aria-labelledby="products-heading-system">
        <p id="products-heading-system" class="products-group-title">SYSTEM MODULES</p>
        <p class="products-group-note">Módulos base para decisiones trazables en operación real.</p>
        <ul class="products-list">
          <li class="products-item">
            <button
              type="button"
              class="product-trigger"
              data-product="core"
              data-group="system-modules"
              data-field-algorithm="core"
            >
              <span class="product-name">Core</span>
              <p class="product-tech">Modelo base de dependencias para una decisión estructural.</p>
              <p class="product-impact">Define la variable dominante antes de asignar capital.</p>
            </button>
          </li>
          <li class="products-item">
            <button
              type="button"
              class="product-trigger"
              data-product="scenario"
              data-group="system-modules"
              data-field-algorithm="scenario"
            >
              <span class="product-name">Scenario</span>
              <p class="product-tech">Simula bifurcaciones con supuestos trazables y comparables.</p>
              <p class="product-impact">Mide qué escenario preserva margen y velocidad de ejecución.</p>
            </button>
          </li>
          <li class="products-item">
            <button
              type="button"
              class="product-trigger"
              data-product="risk"
              data-group="system-modules"
              data-field-algorithm="risk"
            >
              <span class="product-name">Risk</span>
              <p class="product-tech">Calcula concentración de fragilidad por nodo y por secuencia.</p>
              <p class="product-impact">Reduce exposición antes de que el desvío sea irreversible.</p>
            </button>
          </li>
          <li class="products-item">
            <button
              type="button"
              class="product-trigger"
              data-product="signal"
              data-group="system-modules"
              data-field-algorithm="signal"
            >
              <span class="product-name">Signal</span>
              <p class="product-tech">Filtra ruido operativo y prioriza señales con causalidad.</p>
              <p class="product-impact">Acelera decisiones con foco en impacto verificable.</p>
            </button>
          </li>
          <li class="products-item">
            <button
              type="button"
              class="product-trigger"
              data-product="ledger"
              data-group="system-modules"
              data-field-algorithm="ledger"
            >
              <span class="product-name">Ledger</span>
              <p class="product-tech">Registra hipótesis, umbrales y resultados en cadena auditable.</p>
              <p class="product-impact">Sostiene accountability técnico entre equipos y ciclos.</p>
            </button>
          </li>
        </ul>
      </section>

      <section class="products-group" aria-labelledby="products-heading-advanced">
        <p id="products-heading-advanced" class="products-group-title">ADVANCED CAPABILITIES</p>
        <p class="products-group-note">Capas avanzadas para lectura de régimen y complejidad dinámica.</p>
        <ul class="products-list">
          <li class="products-item">
            <button
              type="button"
              class="product-trigger"
              data-product="counterfactual"
              data-group="advanced-capabilities"
              data-field-algorithm="scenario"
            >
              <span class="product-name">Counterfactual</span>
              <p class="product-tech">Genera mundos alternos y estima desvíos contra la base.</p>
              <p class="product-impact">Anticipa costo de oportunidad antes de ejecutar.</p>
            </button>
          </li>
          <li class="products-item">
            <button
              type="button"
              class="product-trigger"
              data-product="regime"
              data-group="advanced-capabilities"
              data-field-algorithm="risk"
            >
              <span class="product-name">Regime</span>
              <p class="product-tech">Detecta cambios de régimen con rupturas de distribución.</p>
              <p class="product-impact">Reconfigura estrategia cuando cambian las reglas del entorno.</p>
            </button>
          </li>
          <li class="products-item">
            <button
              type="button"
              class="product-trigger"
              data-product="entropy"
              data-group="advanced-capabilities"
              data-field-algorithm="integration"
            >
              <span class="product-name">Entropy</span>
              <p class="product-tech">Mapea entropía decisional y pérdida de información útil.</p>
              <p class="product-impact">Recupera claridad donde la complejidad bloquea acción.</p>
            </button>
          </li>
          <li class="products-item">
            <button
              type="button"
              class="product-trigger"
              data-product="integration"
              data-group="advanced-capabilities"
              data-field-algorithm="integration"
            >
              <span class="product-name">Integration</span>
              <p class="product-tech">Sincroniza modelos, áreas y tiempos en un mismo marco.</p>
              <p class="product-impact">Evita contradicciones y alinea ejecución con evidencia.</p>
            </button>
          </li>
        </ul>
      </section>
    </section>
  </nav>

  <main class="home-main home-surface">
    <article class="home-column home-stack">
      <section class="home-block home-hero" data-field-stage="0.05" data-field-block="hero" data-field-role="hero">
        <div class="hero-occluder" aria-hidden="true"></div>
        <div class="hero-body">
          <h1 class="hero-title">{hero.lines[0]}</h1>
          <div class="hero-declarations" data-field-role="hero-lines">
            {hero.lines.slice(1).map((line) => (
              <p class="declaration">{line}</p>
            ))}
          </div>
          <ul class="hero-instrumentation" aria-label="Instrumentación del sistema">
            <li><span>signal latency</span><span>7.4ms</span></li>
            <li><span>regime drift</span><span>0.29 sigma</span></li>
            <li><span>decision trace</span><span>184 nodes</span></li>
          </ul>
          <a href="/demo" class="home-cta">{hero.cta}</a>
        </div>
      </section>

      {blocks.map((block, index) => (
        <section
          class="home-block"
          data-field-stage={String(0.18 + index * 0.15)}
          data-field-block={`block-${index}`}
          data-field-role="section"
        >
          <p class="micro-title">{block.title}</p>
          {block.lines.map((line) => (
            <p class="declaration">{line}</p>
          ))}
        </section>
      ))}
    </article>
  </main>

  <script>
    import { mountHomeField } from "../lib/homeField";

    let cleanup;

    const boot = () => {
      cleanup = mountHomeField();
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", boot, { once: true });
    } else {
      boot();
    }

    window.addEventListener(
      "pagehide",
      () => {
        if (typeof cleanup === "function") cleanup();
      },
      { once: true }
    );
  </script>
</PageLayout>
