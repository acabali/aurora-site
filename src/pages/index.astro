<style>.hero{min-height:100vh;display:flex;align-items:center;padding:2rem;background:var(--color-bg);position:relative}.hero-canvas{position:absolute;top:0;left:0;width:100%;height:100%;z-index:0}.hero-content{position:relative;z-index:10;max-width:90%;margin-top:100px}.hero h1{font-size:clamp(2.5rem,8vw,4rem);font-weight:700;margin-bottom:2rem;color:var(--color-text)}.hero-subtitle{font-size:1.125rem;color:var(--color-text-secondary);margin-bottom:1.5rem;max-width:700px;line-height:1.8}.hero p{font-size:1.125rem;color:var(--color-text-secondary);margin-bottom:1rem;line-height:1.8;max-width:700px}.cta-button{display:inline-block;padding:1rem 2rem;background:var(--color-accent-blue);color:var(--color-bg);border-radius:32px;font-weight:600;text-decoration:none;transition:all 250ms cubic-bezier(.6,0,.4,1);text-transform:uppercase;font-size:.95rem;letter-spacing:.05em}.cta-button:hover{transform:translateY(-4px);box-shadow:0 20px 40px rgba(46,91,255,.3)}section{padding:6rem 4rem;position:relative;z-index:5;min-height:50vh;display:flex;align-items:center;max-width:1400px;margin:0 auto}section h2{font-size:clamp(1.875rem,5vw,3rem);font-weight:700;margin-bottom:2rem;line-height:1.2;color:var(--color-text)}section p{font-size:1.125rem;color:var(--color-text-secondary);line-height:1.8;margin-bottom:1.5rem;max-width:800px}.rupture-container{display:grid;grid-template-columns:1fr auto 1fr;gap:4rem;align-items:flex-start;margin:3rem 0;padding:3rem;background:rgba(46,91,255,.05);border-radius:12px}.rupture-before h3{color:var(--color-accent-red);font-size:1.25rem;font-weight:700;margin-bottom:1.5rem}.rupture-after h3{color:var(--color-accent-green);font-size:1.25rem;font-weight:700;margin-bottom:1.5rem}.rupture-list{list-style:none}.rupture-list li{padding:.5rem 0;font-size:1.1rem;font-weight:600;margin-bottom:.5rem}.rupture-before .rupture-list li{color:var(--color-accent-red)}.rupture-after .rupture-list li{color:var(--color-accent-green)}.rupture-divider{width:1px;height:140px;background:linear-gradient(to bottom,var(--color-accent-red),var(--color-accent-blue),var(--color-accent-green))}.rupture-conclusion{margin-top:2rem;font-size:1.125rem;font-weight:600;line-height:1.8;color:var(--color-text)}.definition-block{padding:2.5rem;background:rgba(46,91,255,.03);border-left:3px solid var(--color-accent-blue);margin:3rem 0;border-radius:8px}.definition-emphasis{font-size:1.125rem;font-weight:600;margin:1.5rem 0;color:var(--color-accent-green)}.demo-narrative{margin:3rem 0;padding:2rem;background:rgba(0,195,137,.03);border-radius:8px}.demo-statement{font-size:1.125rem;font-weight:600;margin-bottom:1rem;color:var(--color-accent-green)}strong{color:var(--color-accent-blue);font-weight:700}@media(max-width:1024px){.rupture-container{grid-template-columns:1fr;gap:2rem}.rupture-divider{width:100%;height:1px;background:linear-gradient(to right,var(--color-accent-red),var(--color-accent-blue),var(--color-accent-green))}}@media(max-width:768px){.hero{min-height:auto;padding:1rem}.hero-content{margin-top:40px}.hero h1{font-size:2rem;margin-bottom:1.5rem}section{padding:3rem 1rem}.cta-button{width:100%;text-align:center;display:block}}</style><section class="hero" data-era-section data-era-phase="unstable"><canvas id="network-canvas" class="hero-canvas"></canvas><div class="hero-content"><h1>El límite humano<br>ya no alcanza.</h1><p>El mercado ya no compite con personas.<br>Compite con sistemas.</p><p>Quedarse en intuición<br>es quedar fuera del juego real.</p><p style="margin-top:2rem;font-size:1.125rem;font-weight:600">Aurora no mejora decisiones.</p><p>Desplaza el límite humano por el cálculo permanente.</p><p style="margin-top:2rem">No es digitalización.</p><p style="font-size:1.125rem;font-weight:600">Es sustitución operativa.</p><a href="/demo" class="cta-button" style="margin-top:2rem">Poner una decisión bajo evidencia</a></div></section><section data-era-section data-era-phase="compressing"><div style="width:100%;max-width:900px"><h2>La forma de operar cambió.</h2><p>Validar antes de actuar ya es posible.</p><p style="margin-top:2rem"><strong>La validación previa no es mejora.</strong><br>Es condición de entrada.</p><p><strong>La precisión no optimiza.</strong><br>Define quién compite.</p></div></section><section data-era-section data-era-phase="collision"><div style="width:100%;max-width:900px"><h2>Hoy es más barato y más eficiente operar con capacidad algorítmica que con estructura inflada.</h2><p>La ventaja ya no está en crecer.<br>Está en procesar mejor.</p><p style="margin-top:2rem">Seguir expandiendo capas humanas<br>cuando el cálculo ya es superior<br>no es cultura.</p><p><strong>Es desventaja.</strong></p><p style="margin-top:2rem">El mercado premia cálculo.<br>Penaliza interpretación.</p></div></section><section data-era-section data-era-phase="rupture"><div style="width:100%;max-width:900px"><h2>Aurora es una capa de cálculo soberano.</h2><p>No acompaña.</p><p><strong>Divide.</strong></p><p style="margin-top:2rem">Divide a quienes operan desde límite humano<br>de quienes operan con potencia algorítmica.</p><p style="margin-top:2rem">El entorno ya está gobernado por datos en tiempo real,<br>automatización y modelos autónomos.</p><p style="margin-top:2rem">Actuar solo con intuición<br>no es identidad.</p><p><strong>Es inferioridad estructural.</strong></p></div></section><section class="section-rupture" data-era-section data-era-phase="rupture" data-binary-boundary><div style="width:100%"><h2>Antes se reaccionaba.</h2><h2>Hoy se ejecuta con ventaja informacional.</h2><div class="rupture-container"><div><h3>ANTES</h3><ul class="rupture-list"><li>El error se absorbía</li><li>El ajuste era posterior</li><li>La velocidad era humana</li></ul></div><div class="rupture-divider"></div><div><h3>HOY</h3><ul class="rupture-list"><li>El mercado opera con sistemas autónomos</li><li>Automatización estratégica</li><li>Cálculo continuo</li></ul></div></div><p class="rupture-conclusion">No es transformación digital.<br><strong>Es desplazamiento operativo.</strong></p><p class="rupture-conclusion">No es evolución.<br><strong>Es sustitución de estándar.</strong></p></div></section><section data-era-section data-era-phase="reordering"><div style="width:100%"><h2>Cálculo soberano.</h2><div class="definition-block"><p>Cálculo soberano significa <strong>autonomía frente al error recurrente.</strong></p><p>Significa <strong>procesar complejidad sin reducirla.</strong></p><p>Significa <strong>tener ventaja antes de que el mercado entienda el movimiento.</strong></p><p class="definition-emphasis">No es mejora.</p><p class="definition-emphasis"><strong>Es reemplazo.</strong></p><p style="margin-top:2rem;font-size:1.125rem;font-weight:600">Con cálculo soberano, marcas el ritmo.<br>Sin él, lo persigues.</p></div></div></section><section data-era-section data-era-phase="stabilized"><div style="width:100%"><h2>Pon tu próximo movimiento bajo evidencia.</h2><div class="demo-narrative"><p class="demo-statement"><strong>Aurora no opina.</strong> Calcula.</p><p>Detecta la interacción dominante.<br>Expone la vulnerabilidad central.</p><p style="margin-top:1rem"><strong>Una señal.</strong><br>Un movimiento correcto.</p></div><div style="margin-top:2rem;display:flex;gap:2rem;flex-wrap:wrap"><a href="/demo" class="cta-button">Abrir Demo</a><a href="mailto:hola@aurora.io" class="cta-button" style="background:transparent;border:2px solid var(--color-accent-blue);color:var(--color-accent-blue)">Contactar</a></div></div></section><script>import*as THREE from"three";import gsap from"gsap";import{ScrollTrigger}from"gsap/ScrollTrigger";gsap.registerPlugin(ScrollTrigger);const canvas=document.getElementById("network-canvas");if(canvas){const scene=new THREE.Scene,camera=new THREE.PerspectiveCamera(75,window.innerWidth/window.innerHeight,.1,1e3),renderer=new THREE.WebGLRenderer({canvas,antialias:!0,alpha:!0});renderer.setSize(window.innerWidth,window.innerHeight),renderer.setPixelRatio(Math.min(window.devicePixelRatio,2)),renderer.setClearColor(0x0b0b0c,1),camera.position.z=8;const nodeCount=15,positions=[],nodes=[];for(let i=0;i<nodeCount;i++){const theta=i/nodeCount*Math.PI*2,r=3+2*Math.random(),x=Math.cos(theta)*r+(.5-Math.random())*.5,y=(.5-Math.random())*4,z=Math.sin(theta)*r+(.5-Math.random())*.5;positions.push(x,y,z),nodes.push({x,y,z})}const nodeGeometry=new THREE.BufferGeometry;nodeGeometry.setAttribute("position",new THREE.BufferAttribute(new Float32Array(positions),3));const nodeMaterial=new THREE.PointsMaterial({color:0x2e5bff,size:.15,sizeAttenuation:!0}),pointsMesh=new THREE.Points(nodeGeometry,nodeMaterial);scene.add(pointsMesh);const linePositions=[];for(let i=0;i<nodeCount;i++)for(let j=0;j<2+Math.floor(2*Math.random());j++){const neighborIdx=(i+1+j)%nodeCount;linePositions.length<150&&linePositions.push(nodes[i].x,nodes[i].y,nodes[i].z,nodes[neighborIdx].x,nodes[neighborIdx].y,nodes[neighborIdx].z)}const lineGeometry=new THREE.BufferGeometry;lineGeometry.setAttribute("position",new THREE.BufferAttribute(new Float32Array(linePositions),3));const lineMaterial=new THREE.LineBasicMaterial({color:0xbfc2c7,transparent:!0,opacity:.6}),linesMesh=new THREE.LineSegments(lineGeometry,lineMaterial);scene.add(linesMesh);const group=new THREE.Group;group.add(pointsMesh),group.add(linesMesh),scene.add(group),gsap.fromTo(nodeMaterial,{opacity:0},{opacity:1,duration:.3,delay:.3}),gsap.to(group.rotation,{scrollTrigger:{trigger:"body",scrub:1},z:2*Math.PI,duration:10});let lastScrollY=0;window.addEventListener("scroll",()=>{const scrollVelocity=window.scrollY-lastScrollY;lastScrollY=window.scrollY;const colorValue=Math.min(1,Math.abs(scrollVelocity)/20);lineMaterial.color.set(new THREE.Color(THREE.MathUtils.lerp(0xbfc2c7,0x2e5bff,colorValue))),nodeMaterial.opacity=.6+.4*colorValue,group.rotation.z+=scrollVelocity/1e4*.1}),window.addEventListener("resize",()=>{camera.aspect=window.innerWidth/window.innerHeight,camera.updateProjectionMatrix(),renderer.setSize(window.innerWidth,window.innerHeight)});function animate(){requestAnimationFrame(animate),group.rotation.x+=.0002,group.rotation.y+=.0003,renderer.render(scene,camera)}animate()}
</script>
