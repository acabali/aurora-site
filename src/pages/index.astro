<!-- ===========================
     SCRIPTS: THREE.JS + GSAP + SCROLL
=========================== -->
<script>
  import * as THREE from 'three';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ===== LENIS SMOOTH SCROLL =====
  async function setupLenis() {
    try {
      const LenisModule = await import('@studio-freight/lenis');
      const Lenis = LenisModule.default;
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        direction: 'vertical',
        smooth: true,
        smoothTouch: false,
        touchMultiplier: 2,
      });

      lenis.on('scroll', ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });

      gsap.ticker.lagSmoothing(0);

      console.log('[Aurora] Lenis activo');
    } catch (e) {
      console.log('[Aurora] Lenis no disponible — scroll estándar activo');
    }
  }

  setupLenis();

  // ===== HEADER SCROLL STATE =====
  const header = document.getElementById('header');
  if (header) {
    window.addEventListener('scroll', () => {
      header.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });
  }

  // ===========================
  // THREE.JS NETWORK EMERGENCE
  // ===========================
  const canvas = document.getElementById('network-canvas');
  if (canvas) {
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(
      65,
      window.innerWidth / window.innerHeight,
      0.1,
      1000
    );
    camera.position.z = 9;

    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: false,
      precision: 'highp',
    });

    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x0B0B0C, 1);
    renderer.sortObjects = false;

    // ─── NODOS ───
    const NODE_COUNT = 22;
    const nodePositions = [];
    const nodeData = [];

    for (let i = 0; i < NODE_COUNT; i++) {
      const theta = (i / NODE_COUNT) * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);
      const r = 2.5 + Math.random() * 2.8;

      const x = r * Math.sin(phi) * Math.cos(theta);
      const y = (Math.random() - 0.5) * 5;
      const z = r * Math.sin(phi) * Math.sin(theta);

      nodePositions.push(x, y, z);
      nodeData.push({ x, y, z, origX: x, origY: y, origZ: z });
    }

    const nodeGeometry = new THREE.BufferGeometry();
    nodeGeometry.setAttribute(
      'position',
      new THREE.BufferAttribute(new Float32Array(nodePositions), 3)
    );

    const nodeMaterial = new THREE.PointsMaterial({
      color: 0x2E5BFF,
      size: 0.18,
      sizeAttenuation: true,
      fog: false,
      transparent: true,
      opacity: 0,
    });

    const points = new THREE.Points(nodeGeometry, nodeMaterial);

    // ─── LÍNEAS ───
    const linePositions = [];
    for (let i = 0; i < NODE_COUNT; i++) {
      const connectionCount = 2 + Math.floor(Math.random() * 3);
      for (let j = 1; j <= connectionCount; j++) {
        const targetIdx = (i + j) % NODE_COUNT;
        if (linePositions.length < 200) {
          linePositions.push(
            nodeData[i].x, nodeData[i].y, nodeData[i].z,
            nodeData[targetIdx].x, nodeData[targetIdx].y, nodeData[targetIdx].z
          );
        }
      }
    }

    const lineGeometry = new THREE.BufferGeometry();
    lineGeometry.setAttribute(
      'position',
      new THREE.BufferAttribute(new Float32Array(linePositions), 3)
    );

    const lineMaterial = new THREE.LineBasicMaterial({
      color: 0x3A3F52,
      transparent: true,
      opacity: 0,
      fog: false,
    });

    const lines = new THREE.LineSegments(lineGeometry, lineMaterial);

    // ─── GRUPO PRINCIPAL ───
    const networkGroup = new THREE.Group();
    networkGroup.add(points);
    networkGroup.add(lines);
    scene.add(networkGroup);

    // ─── EMERGENCE ANIMATION (T=0-3s) ───
    // Fase 1: nodos emergen (T=0.3s)
    gsap.to(nodeMaterial, {
      opacity: 1,
      duration: 0.5,
      delay: 0.3,
      ease: 'power2.inOut'
    });

    // Fase 2: líneas draw (T=0.8s)
    gsap.to(lineMaterial, {
      opacity: 0.55,
      duration: 1.2,
      delay: 0.8,
      ease: 'power2.inOut'
    });

    // Fase 3: intro scale
    networkGroup.scale.setScalar(0.7);
    gsap.to(networkGroup.scale, {
      x: 1, y: 1, z: 1,
      duration: 2.5,
      delay: 0.3,
      ease: 'expo.out'
    });

    // ─── SCROLL REACTIVO ───
    let scrollY = 0;
    let targetRotY = 0;
    let targetRotX = 0;
    let scrollVelocity = 0;
    let lastScrollY = 0;
    let colorBlend = 0;
    let targetColorBlend = 0;

    window.addEventListener('scroll', () => {
      scrollY = window.scrollY;
      scrollVelocity = Math.abs(scrollY - lastScrollY);
      lastScrollY = scrollY;

      targetRotY = scrollY * 0.0003;
      targetRotX = scrollY * 0.0001;
      targetColorBlend = Math.min(1, scrollVelocity / 25);
    }, { passive: true });

    // ─── GSAP SCROLL: color lines on scroll ───
    ScrollTrigger.create({
      trigger: 'body',
      start: 'top top',
      end: 'bottom bottom',
      scrub: 0.5,
      onUpdate: (self) => {
        const p = self.progress;
        const r = Math.round(THREE.MathUtils.lerp(58, 46, p));
        const g = Math.round(THREE.MathUtils.lerp(63, 91, p));
        const b = Math.round(THREE.MathUtils.lerp(82, 255, p));
        lineMaterial.color.setRGB(r/255, g/255, b/255);
      }
    });

    // ─── ANIMATION LOOP ───
    let rafId;
    function animate() {
      rafId = requestAnimationFrame(animate);

      // Smooth scroll rotation
      networkGroup.rotation.y += (targetRotY - networkGroup.rotation.y) * 0.04;
      networkGroup.rotation.x += (targetRotX - networkGroup.rotation.x) * 0.03;

      // Ambient drift
      networkGroup.rotation.z += 0.00015;

      // Velocity-based node brightness
      colorBlend += (targetColorBlend - colorBlend) * 0.12;
      nodeMaterial.opacity = 0.75 + colorBlend * 0.25;

      // Decay velocity
      targetColorBlend *= 0.9;

      renderer.render(scene, camera);
    }

    animate();

    // ─── RESIZE ───
    window.addEventListener('resize', () => {
      const w = window.innerWidth;
      const h = window.innerHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    }, { passive: true });

    // Pause on hidden
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        cancelAnimationFrame(rafId);
      } else {
        animate();
      }
    });
  }

  // ===========================
  // INTERSECTION OBSERVER (Section reveals)
  // ===========================
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -60px 0px' }
  );

  document.querySelectorAll('[data-section]').forEach((s) => {
    sectionObserver.observe(s);
  });

  // ===========================
  // MODULE CARDS: stagger cascade
  // ===========================
  const moduleObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const cards = entry.target.querySelectorAll('.module-card');
          cards.forEach((card, i) => {
            setTimeout(() => {
              card.classList.add('visible');
            }, i * 100);
          });
          moduleObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  const modulesSection = document.querySelector('.section-modules');
  if (modulesSection) {
    moduleObserver.observe(modulesSection);
  }

  // ===========================
  // RUPTURA BINARIA: GSAP ScrollTrigger
  // ===========================
  const ruptureContainer = document.getElementById('rupture-container');
  if (ruptureContainer) {
    gsap.to(ruptureContainer, {
      scrollTrigger: {
        trigger: '.section-rupture',
        start: 'top 55%',
        end: 'center 30%',
        scrub: 1.2,
        onEnter: () => ruptureContainer.classList.add('activated'),
        onLeaveBack: () => ruptureContainer.classList.remove('activated'),
      },
    });
  }

  // ===========================
  // GSAP: Section headline reveals (fallback/boost)
  // ===========================
  const sections = document.querySelectorAll('[data-section]');
  sections.forEach((section) => {
    const h2 = section.querySelector('.section-h2');
    if (h2) {
      gsap.fromTo(h2,
        { opacity: 0, y: 32 },
        {
          opacity: 1, y: 0,
          duration: 0.8,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: section,
            start: 'top 75%',
            toggleActions: 'play none none none',
          }
        }
      );
    }
  });
</script>

</MainLayout>
