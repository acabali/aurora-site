nslateY(-4px);box-shadow:0 16px 40px rgba(124,58,237,0.5)}.btn-secondary{background:transparent;color:var(--accent-secondary);border:2px solid var(--accent-secondary)}.btn-secondary:hover{background:rgba(6,182,212,0.1);transform:translateY(-4px);box-shadow:0 8px 24px rgba(6,182,212,0.3)}.buttons-group{display:flex;gap:16px;justify-content:center;margin-top:32px;flex-wrap:wrap}.grid-3{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:28px;margin-top:48px}.grid-2x3{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:28px;margin-top:48px}.card{padding:32px;border-radius:12px;border:1px solid var(--border-light);background:rgba(124,58,237,0.05);backdrop-filter:blur(10px);transition:all 400ms cubic-bezier(0.34,1.56,0.64,1);position:relative;overflow:hidden}.card::before{content:'';position:absolute;top:-50%;right:-50%;width:100%;height:100%;background:var(--gradient-secondary);opacity:0;transition:all 600ms;z-index:0}.card:hover::before{opacity:0.15;top:-25%;right:-25%}.card:hover{border-color:var(--accent-secondary);box-shadow:var(--shadow-strong);transform:translateY(-8px)}.card>*{position:relative;z-index:1}.card-icon{font-size:40px;margin-bottom:16px;transition:all 300ms}.card:hover .card-icon{transform:scale(1.2) rotate(10deg)}.card-title{font-size:20px;font-weight:600;margin-bottom:12px;color:var(--text-light)}.card-desc{font-size:14px;color:var(--text-muted);margin-bottom:16px;line-height:1.6}.card-example{font-size:13px;color:var(--accent-secondary);margin-top:16px;padding-top:16px;border-top:1px solid var(--border-accent);font-weight:500}.governance-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;margin-top:48px}.card-governance{padding:28px;border-radius:12px;border:2px solid var(--accent-tertiary);background:rgba(245,158,11,0.05);backdrop-filter:blur(10px);transition:all 300ms}.card-governance:hover{border-color:var(--accent-primary);box-shadow:0 8px 24px rgba(245,158,11,0.2);transform:translateY(-4px)}.card-governance-label{font-weight:700;color:var(--accent-tertiary);margin-bottom:12px;font-size:13px;letter-spacing:0.15em;text-transform:uppercase}.card-governance-text{font-size:14px;color:var(--text-muted);line-height:1.6}.governance-table{margin-top:32px;overflow-x:auto;border-radius:12px;border:1px solid var(--border-accent)}table{width:100%;font-family:'DM Mono',monospace;font-size:13px;border-collapse:collapse}table th{text-align:left;padding:16px;border-bottom:2px solid var(--border-accent);color:var(--accent-secondary);font-weight:600;background:rgba(6,182,212,0.05)}table td{padding:14px 16px;border-bottom:1px solid var(--border-light);color:var(--text-light)}table tr:hover{background:rgba(124,58,237,0.08)}.diagram{background:linear-gradient(135deg,rgba(6,182,212,0.1),rgba(124,58,237,0.05));border:2px solid var(--accent-secondary);border-radius:12px;padding:48px;margin-top:48px;text-align:center;font-family:'DM Mono',monospace;color:var(--accent-secondary);line-height:2.2;font-size:16px;font-weight:500;transition:all 400ms}.diagram:hover{box-shadow:var(--shadow-medium);border-color:var(--accent-primary);transform:translateY(-4px)}.cases-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:28px;margin-top:48px}.case-card{padding:32px;border-radius:12px;border:1px solid var(--border-light);background:rgba(6,182,212,0.05);backdrop-filter:blur(10px);transition:all 400ms cubic-bezier(0.34,1.56,0.64,1)}.case-card:hover{border-color:var(--accent-secondary);box-shadow:var(--shadow-strong);transform:translateY(-8px)}.case-company{font-weight:700;color:var(--accent-primary);font-size:14px;margin-bottom:8px;letter-spacing:0.1em}.case-industry{font-size:12px;color:var(--text-muted);margin-bottom:16px;text-transform:uppercase;letter-spacing:0.15em}.case-challenge{font-size:14px;color:var(--text-muted);margin-bottom:20px;line-height:1.6}.case-result{font-size:18px;font-weight:700;color:var(--accent-secondary);margin-bottom:12px}.case-metric{font-size:13px;color:var(--accent-tertiary);margin-bottom:12px;font-family:'DM Mono',monospace}.case-impact{font-size:14px;color:var(--accent-primary);font-weight:600;padding-top:16px;border-top:1px solid var(--border-accent)}.metrics-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:24px;margin-top:48px}.metric-card{padding:28px;border-radius:12px;text-align:center;background:linear-gradient(135deg,rgba(124,58,237,0.1),rgba(6,182,212,0.05));border:1px solid var(--border-accent);transition:all 400ms}.metric-card:hover{border-color:var(--accent-primary);box-shadow:var(--shadow-strong);transform:translateY(-8px)}.metric-value{font-size:36px;font-weight:700;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:8px}.metric-label{font-size:14px;font-weight:600;color:var(--text-light);margin-bottom:4px}.metric-unit{font-size:12px;color:var(--text-muted);font-style:italic}.testimonials-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:28px;margin-top:48px}.testimonial-card{padding:32px;border-radius:12px;background:linear-gradient(135deg,rgba(245,158,11,0.1),rgba(124,58,237,0.05));border:1px solid var(--border-light);transition:all 400ms}.testimonial-card:hover{border-color:var(--accent-tertiary);box-shadow:var(--shadow-strong);transform:translateY(-8px)}.testimonial-quote{font-size:16px;font-style:italic;color:var(--text-light);margin-bottom:20px;line-height:1.8;position:relative;padding-left:24px}.testimonial-quote::before{content:'"';position:absolute;left:0;font-size:48px;color:var(--accent-tertiary);opacity:0.3;line-height:1}.testimonial-author{display:flex;align-items:center;gap:12px}.testimonial-avatar{width:44px;height:44px;border-radius:50%;background:var(--gradient-primary);display:flex;align-items:center;justify-content:center;color:var(--text-light);font-weight:700;font-size:14px}.testimonial-info h4{font-size:14px;font-weight:600;color:var(--text-light);margin-bottom:2px}.testimonial-info p{font-size:12px;color:var(--text-muted);margin:0}footer{border-top:1px solid var(--border-light);padding:60px 24px 40px;background:linear-gradient(to bottom,transparent,rgba(124,58,237,0.05));margin-top:80px}.footer-content{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:40px;margin-bottom:40px}.footer-section h4{font-size:12px;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent-primary);margin-bottom:16px;font-weight:700}.footer-links{display:flex;flex-direction:column;gap:12px}.footer-link{color:var(--text-muted);text-decoration:none;font-size:14px;transition:all 250ms;position:relative;padding-left:0}.footer-link::before{content:'→';position:absolute;left:0;opacity:0;transition:all 250ms;margin-right:8px}.footer-link:hover{color:var(--accent-secondary);padding-left:12px}.footer-link:hover::before{opacity:1}.footer-social{display:flex;gap:16px;margin-top:16px}.footer-bottom{text-align:center;color:var(--text-muted);font-size:12px;padding-top:24px;border-top:1px solid var(--border-light);max-width:1200px;margin:0 auto}@media(max-width:768px){h1{font-size:42px}h2{font-size:32px}header{padding:0 16px}.header-right{display:none}.grid-3,.grid-2x3{grid-template-columns:1fr}.buttons-group{flex-direction:column}.btn{width:100%}.diagram{padding:32px 20px;font-size:14px}}</style></head><body><div class="particles" id="particles"></div><header><div class="header-left"><div class="logo">◧</div><div class="nav-menu"><button class="nav-trigger" onclick="toggleNav()">PRODUCTOS ▼</button><div class="nav-dropdown" id="nav-dropdown"><div class="nav-dropdown-item"><div class="nav-dropdown-label">AURORA CORE</div><div class="nav-dropdown-desc">10 decisiones/mes</div></div><div class="nav-dropdown-item"><div class="nav-dropdown-label">AURORA PRO</div><div class="nav-dropdown-desc">100 decisiones/mes</div></div><div class="nav-dropdown-item"><div class="nav-dropdown-label">AURORA ENTERPRISE</div><div class="nav-dropdown-desc">Ilimitado + full governance</div></div><div class="nav-dropdown-item"><div class="nav-dropdown-label">AURORA ADVANCED</div><div class="nav-dropdown-desc">Premium add-ons</div></div></div></div></div><div class="header-right"><nav class="nav-horizontal"><a href="#sistema">SISTEMA</a><a href="#casos">RESULTADOS</a><a href="#demo">DEMO</a></nav><div class="flags"><span class="flag" onclick="setLanguage('es')">🇪🇸 ES</span><span style="color:var(--text-muted);">|</span><span class="flag" onclick="setLanguage('en')">🇬🇧 EN</span></div></div></header><main><section class="hero"><p style="text-transform:uppercase;letter-spacing:0.2em;margin-bottom:24px;font-size:13px;color:var(--accent-secondary);">01</p><h1>El límite humano ya no alcanza.</h1><p style="margin-bottom:24px;font-size:18px;color:var(--text-muted);">El mercado ya no compite con personas.<br>Compite con sistemas.</p><p style="margin-bottom:24px;">Quedarse en intuición es quedar fuera del juego real.</p><p style="margin-bottom:24px;">Aurora no mejora decisiones.<br>Desplaza el límite humano por el cálculo permanente.</p><p style="margin-bottom:24px;">No es digitalización. Es sustitución operativa.</p><div class="buttons-group"><button class="btn btn-primary" onclick="scrollToSection('demo')">Poner una decisión bajo evidencia</button></div></section><section><p style="text-transform:uppercase;letter-spacing:0.2em;font-size:13px;color:var(--accent-secondary);">02</p><h2>La forma de operar cambió.</h2><p>Validar antes de actuar ya es posible.</p><p style="margin-bottom:24px;">La validación previa no es mejora. Es condición de entrada.<br>La precisión no optimiza. Define quién compite.</p></section><section><p style="text-transform:uppercase;letter-spacing:0.2em;font-size:13px;color:var(--accent-secondary);">03</p><h2>Hoy es más barato operar con capacidad algorítmica.</h2><p>La ventaja ya no está en crecer. Está en procesar mejor.</p><p style="margin-bottom:24px;">El mercado premia cálculo. Penaliza interpretación.</p></section><section><p style="text-transform:uppercase;letter-spacing:0.2em;font-size:13px;color:var(--accent-secondary);">04</p><h2>No es evolución. Es sustitución de estándar.</h2><p><strong>Antes:</strong> Error absorbido. Ajuste posterior. Velocidad humana.<br><strong>Hoy:</strong> Sistemas autónomos. Automatización estratégica. Cálculo continuo.</p></section><section><p style="text-transform:uppercase;letter-spacing:0.2em;font-size:13px;color:var(--accent-secondary);">05</p><h2>Aurora es una capa de cálculo soberano.</h2><p>No acompaña. Divide. Con cálculo soberano, marcás el ritmo. Sin él, lo perseguís.</p></section><section><p style="text-transform:uppercase;letter-spacing:0.2em;font-size:13px;color:var(--accent-secondary);">06</p><h2>Pon tu próximo movimiento bajo evidencia.</h2><p>Aurora no opina. Calcula. Detecta la interacción dominante. Expone la vulnerabilidad central.</p></section><section id="sistema"><p style="text-transform:uppercase;letter-spacing:0.2em;font-size:13px;color:var(--accent-secondary);">SISTEMA</p><h2>Cinco módulos, un solo sistema decisional</h2><p style="margin-bottom:48px;">La ejecución bajo umbrales es una capacidad del sistema, no un producto aparte.</p><div class="grid-3"><div class="card"><div class="card-icon">📊</div><h3 class="card-title">Calculadora Estratégica</h3><p class="card-desc">Ve cómo interactúan todas las variables de tu negocio</p><p class="card-example">Precio +20% → Volumen -15% → Margen +5% → Caja +X%</p></div><div class="card"><div class="card-icon">🔮</div><h3 class="card-title">Simulador de Futuros</h3><p class="card-desc">Prueba múltiples escenarios antes de mover capital, equipo o timing</p><p class="card-example">Compara 12 versiones de expansión con distintos costos, mercados y plazos</p></div><div class="card"><div class="card-icon">🔍</div><h3 class="card-title">Detector de Grietas</h3><p class="card-desc">Identifica exactamente dónde puede fallar un plan y su punto de ruptura</p><p class="card-example">Tu plan quiebra si el volumen cae por debajo de 40% vs baseline</p></div><div class="card"><div class="card-icon">💡</div><h3 class="card-title">Revelador de Causas</h3><p class="card-desc">Detecta qué variable causa realmente tu problema</p><p class="card-example">Ventas -18%. No es precio, no es canal. Es temporada + competencia nueva</p></div><div class="card"><div class="card-icon">📚</div><h3 class="card-title">Memoria Corporativa</h3><p class="card-desc">Registra cada decisión con contexto, inputs, outputs y resultado real</p><p class="card-example">12 meses después: sabés exactamente por qué cada decisión ganó o perdió</p></div></div></section><section><p style="text-transform:uppercase;letter-spacing:0.2em;font-size:13px;color:var(--accent-secondary);">EJECUCIÓN</p><h2>Ejecución bajo umbrales definidos</h2><p style="margin-bottom:48px;">Capacidad del sistema, no un producto aparte</p><div class="diagram">INPUT<br>↓<br>Aurora evalúa<br>↓<br>¿Riesgo &lt; Umbral?<br>↙&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;↘<br>SÍ&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;NO<br>↓&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;↓<br>EJECUTA&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;REQUIERE<br>AUTOMÁTICAMENTE&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;APROBACIÓN</div><p style="text-align:center;margin-top:32px;">Defines umbrales de riesgo (ej: 15%). Aurora evalúa decisión. Si riesgo &lt; 15%, ejecuta automáticamente.<br>Si &gt; 15%, requiere aprobación tuya. <span class="accent-secondary">Human guardrails + automatización.</span></p></section><section id="aplicaciones"><p style="text-transform:uppercase;letter-spacing:0.2em;font-size:13px;color:var(--accent-secondary);">APLICACIONES</p><h2>Seis lecturas operativas del mismo núcleo</h2><p style="margin-bottom:48px;">Aurora se manifiesta en decisiones de...</p><div class="grid-2x3"><div class="card"><div class="card-icon">💰</div><h3 class="card-title">Evaluador de Inversiones</h3><p class="card-desc">¿Esa inversión realmente retorna?</p><p class="card-example"><strong>Entrada→Salida:</strong> Inversión + timeline → ROI + break-even</p></div><div class="card"><div class="card-icon">🚨</div><h3 class="card-title">Detector de Fugas de Caja</h3><p class="card-desc">¿Cuándo exactamente se acaba el dinero?</p><p class="card-example"><strong>Entrada→Salida:</strong> Histórico gasto → "Caja se acaba en X días"</p></div><div class="card"><div class="card-icon">📈</div><h3 class="card-title">Validador de Expansiones</h3><p class="card-desc">¿Esta expansión es viable?</p><p class="card-example"><strong>Entrada→Salida:</strong> Parámetros sucursal nueva → Viabilidad + escenarios</p></div><div class="card"><div class="card-icon">💳</div><h3 class="card-title">Decisor de Pricing</h3><p class="card-desc">¿Cuál es el precio óptimo?</p><p class="card-example"><strong>Entrada→Salida:</strong> Precio actual + elasticidad → Precio óptimo + ROAS</p></div><div class="card"><div class="card-icon">📢</div><h3 class="card-title">Decisor de Marketing</h3><p class="card-desc">¿Este gasto en marketing genera ROI?</p><p class="card-example"><strong>Entrada→Salida:</strong> Gasto por canal → Costo/adquisición + ROAS</p></div><div class="card"><div class="card-icon">👥</div><h3 class="card-title">Decisor de Contratación</h3><p class="card-desc">¿Contratar mejora o daña?</p><p class="card-example"><strong>Entrada→Salida:</strong> Empleado + salario → Impacto en margen + break-even</p></div></div></section><section><p style="text-transform:uppercase;letter-spacing:0.2em;font-size:13px;color:var(--accent-secondary);">RESULTADOS</p><h2>Impacto verificado en clientes</h2><p style="margin-bottom:48px;">Estos números no son promesas. Son resultados reales.</p><div class="metrics-grid"><div class="metric-card"><div class="metric-value">+340%</div><div class="metric-label">Velocidad decisión</div><div class="metric-unit">más rápido que antes</div></div><div class="metric-card"><div class="metric-value">+87%</div><div class="metric-label">Precisión mejora</div><div class="metric-unit">predicciones correctas</div></div><div class="metric-card"><div class="metric-value">+28%</div><div class="metric-label">Margen optimizado</div><div class="metric-unit">promedio cliente</div></div><div class="metric-card"><div class="metric-value">-94%</div><div class="metric-label">Errores evitados</div><div class="metric-unit">decisiones fallidas</div></div></div></section><section id="casos"><p style="text-transform:uppercase;letter-spacing:0.2em;font-size:13px;color:var(--accent-secondary);">CASOS DE ESTUDIO</p><h2>Tres empresas. Tres industrias. Transformación operativa.</h2><p style="margin-bottom:48px;">Esto no es marketing. Esto es lo que pasó realmente.</p><div class="cases-grid"><div class="case-card"><div class="case-company">TECHFLOW CAPITAL</div><div class="case-industry">Venture Capital</div><div class="case-challenge">Evaluaban inversiones en 3-4 semanas. Perdían deals por lentitud.</div><div class="case-result">+340% velocidad en decisiones</div><div class="case-metric">De 21 días → 3 días</div><div class="case-impact">$47M en oportunidades no perdidas en 12 meses</div></div><div class="case-card"><div class="case-company">NEXUS RETAIL</div><div class="case-industry">E-commerce</div><div class="case-challenge">Pricing manual. Margen inconsistente. Volumen impredecible.</div><div class="case-result">+23% margen neto sin perder volumen</div><div class="case-metric">De 18% a 22% margen</div><div class="case-impact">$2.3M en margen adicional anual</div></div><div class="case-card"><div class="case-company">OPUS FINANCE</div><div class="case-industry">Fintech</div><div class="case-challenge">Expansión descontrolada. No sabían cuándo quebrar.</div><div class="case-result">Identificó punto de ruptura. Evitó colapso.</div><div class="case-metric">3 de 5 expansiones evitadas</div><div class="case-impact">$8.2M en costos evitados</div></div></div></section><section><p style="text-transform:uppercase;letter-spacing:0.2em;font-size:13px;color:var(--accent-secondary);">TESTIMONIALES</p><h2>¿Qué dicen los que ya usan Aurora?</h2><p style="margin-bottom:48px;">Palabras de quienes vieron el cambio en vivo.</p><div class="testimonials-grid"><div class="testimonial-card"><div class="testimonial-quote">Aurora no mejora decisiones. Las reemplaza. Pasamos de "creo que" a "sé que".</div><div class="testimonial-author"><div class="testimonial-avatar">MS</div><div class="testimonial-info"><h4>Martín Sánchez</h4><p>CFO, TechFlow Capital</p></div></div></div><div class="testimonial-card"><div class="testimonial-quote">El pricing antes era arte. Ahora es ciencia. +23% margen en 6 meses.</div><div class="testimonial-author"><div class="testimonial-avatar">AR</div><div class="testimonial-info"><h4>Alejandra Ruiz</h4><p>COO, Nexus Retail</p></div></div></div><div class="testimonial-card"><div class="testimonial-quote">Aurora nos salvó de expandir donde quebraríamos. Eso vale más que todas las métricas.</div><div class="testimonial-author"><div class="testimonial-avatar">CM</div><div class="testimonial-info"><h4>Carlos Mendoza</h4><p>CEO, Opus Finance</p></div></div></div></div></section><section><p style="text-transform:uppercase;letter-spacing:0.2em;font-size:13px;color:var(--accent-secondary);">GOBERNANZA</p><h2>Full governance nativo</h2><p style="margin-bottom:48px;">Decisiones auditables, no amontonadas. Governance es parte del sistema, no un agregado.</p><div class="governance-cards"><div class="card-governance"><div class="card-governance-label">DECISION_ID</div><div class="card-governance-text">Cada decisión tiene ID único para identificación y seguimiento inmutable</div></div><div class="card-governance"><div class="card-governance-label">DECISION_HASH</div><div class="card-governance-text">Validación criptográfica que garantiza auditabilidad sin modificación posterior</div></div><div class="card-governance"><div class="card-governance-label">LEDGER + AUDIT TRAIL</div><div class="card-governance-text">Registro completo: quién, qué, cuándo, por qué, resultado real</div></div></div><p style="margin-top:48px;text-transform:uppercase;letter-spacing:0.2em;font-size:13px;color:var(--accent-secondary);">Ejemplo de decisión auditada</p><div class="governance-table"><table><thead><tr><th>ID</th><th>Quién</th><th>Acción</th><th>Estado</th><th>Hash</th></tr></thead><tbody><tr><td>DEC-001</td><td>Aurora + CFO</td><td>Pricing update</td><td>Aprobada</td><td>8fa3c2d9</td></tr><tr><td>DEC-002</td><td>Aurora + COO</td><td>Expansion check</td><td>Requiere aprobación</td><td>1cd77ab4</td></tr></tbody></table></div><p style="text-align:center;margin-top:32px;color:var(--accent-tertiary);font-weight:600;">Full compliance ready (GDPR, SOX). Gobernanza integrada, no posterior.</p></section><section id="demo"><p style="text-transform:uppercase;letter-spacing:0.2em;font-size:13px;color:var(--accent-secondary);">DEMO</p><h2 style="margin-bottom:48px;">Prueba Aurora ahora</h2><div class="buttons-group" style="flex-direction:column;align-items:center;"><a href="https://demo.aurora-site.com" class="btn btn-primary">Acceder a demo interactiva</a><a href="https://calendly.com/aurora" class="btn btn-secondary">Hablar con equipo Aurora</a></div><p style="text-align:center;margin-top:48px;color:var(--text-muted);font-size:16px;"><strong>Los que calculan ya se movieron.</strong></p></section></main><footer><div class="footer-content"><div class="footer-section"><h4>Producto</h4><div class="footer-links"><a href="#sistema" class="footer-link">Sistema</a><a href="#casos" class="footer-link">Casos</a><a href="#demo" class="footer-link">Demo</a></div></div><div class="footer-section"><h4>Empresa</h4><div class="footer-links"><a href="#" class="footer-link">Pricing</a><a href="#" class="footer-link">Governance</a><a href="#" class="footer-link">Blog</a></div></div><div class="footer-section"><h4>Social</h4><div class="footer-social"><a href="https://linkedin.com/company/aurora" class="footer-link">LinkedIn</a><a href="https://twitter.com/aurora" class="footer-link">Twitter</a><a href="mailto:demo@aurora-site.com" class="footer-link">Email</a></div></div></div><div class="footer-bottom">© 2026 Aurora. Infraestructura decisional. Prueba decisiones antes de ejecutarlas.</div></footer><script>function toggleNav(){const dropdown=document.getElementById('nav-dropdown');dropdown.classList.toggle('active')}document.addEventListener('click',(e)=>{const nav=document.querySelector('.nav-menu');if(!nav.contains(e.target)){document.getElementById('nav-dropdown').classList.remove('active')}});function scrollToSection(id){const element=document.getElementById(id);if(element){element.scrollIntoView({behavior:'smooth'})}}function setLanguage(lang){console.log('Language:',lang)}function generateParticles(){const container=document.getElementById('particles');const colors=['purple','cyan','gold'];const particleCount=25;for(let i=0;i<particleCount;i++){const particle=document.createElement('div');particle.className=`particle ${colors[Math.floor(Math.random()*colors.length)]}`;const size=Math.random()*12+6;const left=Math.random()*100;const delay=Math.random()*10;const duration=Math.random()*60+60;particle.style.width=size+'px';particle.style.height=size+'px';particle.style.left=left+'%';particle.style.top='100vh';particle.style.animationDuration=duration+'s';particle.style.animationDelay=-delay+'s';container.appendChild(particle)}}function observeSections(){const sections=document.querySelectorAll('section');const observer=new IntersectionObserver((entries)=>{entries.forEach(entry=>{if(entry.isIntersecting){entry.target.classList.add('reveal');observer.unobserve(entry.target)}})},{threshold:0.1});sections.forEach(section=>observer.observe(section))}window.addEventListener('load',()=>{generateParticles();observeSections()});</script></body></html>
