import AuroraEnhancements from "../components/system/AuroraEnhancements.astro"
---
import PageLayout from "../layouts/PageLayout.astro";
import AuroraField from "../components/system/AuroraField.astro";
import SystemRail from "../components/system/SystemRail.astro";
---

<PageLayout title="Aurora" page="home">
  <div class="home-system-shell">
    <AuroraField />
<AuroraEnhancements />
    <SystemRail />

    <main id="field" class="home-main" data-home-main>
      <section class="section-block section-hero" id="hero" data-home-section data-field-state="hero">
        <p class="section-id" aria-hidden="true">01</p>
        <h1>El límite humano ya no alcanza.</h1>

<p>El mercado ya no compite con personas.</p>
<p>Compite con sistemas.</p>

<p>Quedarse en intuición</p>
<p>es quedar fuera del juego real.</p>

<p>Aurora no mejora decisiones.</p>

<p>Desplaza el límite humano por el cálculo permanente.</p>

<p>No es digitalización.</p>

<p>Es sustitución operativa.</p>

        <a href="#demo" class="cta-primary">Poner una decisión bajo evidencia</a>
      </section>

      <section class="section-block" id="system" data-home-section data-field-state="system">
        <p class="section-id" aria-hidden="true">02</p>
        <p>La forma de operar cambió.</p>

<p>Validar antes de actuar ya es posible.</p>

<p>La validación previa no es mejora.</p>
<p>Es condición de entrada.</p>

<p>La precisión no optimiza.</p>
        <p>Define quién compite.</p>
      </section>

      <section class="section-block" id="misfit" data-home-section data-field-state="misfit">
        <p class="section-id" aria-hidden="true">03</p>

<p>Hoy es más barato y más eficiente operar con capacidad algorítmica que con estructura inflada.</p>

<p>La ventaja ya no está en crecer.</p>

<p>Está en procesar mejor.</p>

<p>Seguir expandiendo capas humanas</p>
<p>cuando el cálculo ya es superior</p>
<p>no es cultura.</p>

<p>Es desventaja.</p>

<p>El mercado premia cálculo.</p>
        <p>Penaliza interpretación.</p>
      </section>

      <section class="section-block" id="engine" data-home-section data-field-state="engine">
        <p class="section-id" aria-hidden="true">04</p>

<p>Antes:</p>

<p>El error se absorbía.</p>
<p>El ajuste era posterior.</p>
<p>La velocidad era humana.</p>

<p>Hoy:</p>

<p>El mercado opera con sistemas autónomos.</p>
<p>Automatización estratégica.</p>
<p>Cálculo continuo.</p>

<p>Antes se reaccionaba.</p>
<p>Hoy se ejecuta con ventaja informacional.</p>

<p>No es transformación digital.</p>
<p>Es desplazamiento operativo.</p>

<p>No es evolución.</p>
        <p>Es sustitución de estándar.</p>
      </section>

      <section class="section-block" id="what" data-home-section data-field-state="what">
        <p class="section-id" aria-hidden="true">05</p>

<p>Aurora es una capa de cálculo soberano.</p>

<p>No acompaña.</p>
<p>Divide.</p>

<p>Divide a quienes operan desde límite humano</p>
<p>de quienes operan con potencia algorítmica.</p>

<p>El entorno ya está gobernado por datos en tiempo real,</p>
<p>automatización y modelos autónomos.</p>

<p>Actuar solo con intuición</p>
<p>no es identidad.</p>

<p>Es inferioridad estructural.</p>

<p>Cálculo soberano significa autonomía frente al error recurrente.</p>

<p>Significa procesar complejidad sin reducirla.</p>

<p>Significa tener ventaja antes de que el mercado entienda el movimiento.</p>

<p>No es mejora.</p>
<p>Es reemplazo.</p>

<p>Con cálculo soberano, marcas el ritmo.</p>

        <p>Sin él, lo persigues.</p>
      </section>

      <section class="section-block section-demo" id="demo" data-home-section data-field-state="demo">
        <p class="section-id" aria-hidden="true">06</p>

<p>Pon tu próximo movimiento bajo evidencia.</p>

<p>Aurora no opina.</p>
<p>Calcula.</p>

<p>Detecta la interacción dominante.</p>
<p>Expone la vulnerabilidad central.</p>

<p>Una señal.</p>
<p>Un movimiento correcto.</p>

        <a href="/demo" class="cta-primary">Abrir demo</a>
      </section>
    </main>
  </div>

  <script type="module">
    import { initHomeSystem } from "../lib/homeField";

    let cleanup;

    const boot = () => {
      cleanup = initHomeSystem();
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", boot, { once: true });
    } else {
      boot();
    }

    window.addEventListener(
      "pagehide",
      () => {
        if (typeof cleanup === "function") cleanup();
      },
      { once: true }
    );
  </script>
</PageLayout>
