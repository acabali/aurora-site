#!/usr/bin/env bash
set -e

LOCKFILE="ops/locks/codex_freeze.txt"

if [ ! -f "$LOCKFILE" ]; then
  exit 0
fi

FILES=$(git diff --cached --name-only)

while read -r LOCKED; do
  if echo "$FILES" | grep -q "$LOCKED"; then
    echo "❌ COMMIT BLOQUEADO"
    echo "Intentaste modificar archivo congelado:"
    echo "$LOCKED"
    echo "Estos archivos no pueden ser tocados por CODEX."
    exit 1
  fi
done < "$LOCKFILE"

echo "✔ commit permitido"
