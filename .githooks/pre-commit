#!/usr/bin/env bash
set -euo pipefail

# DEMO y narrativa congeladas
IMMUTABLE='^(src/pages/demo\.astro|src/components/blocks/Demo\.astro|src/content/home\.ts)$'

CHANGED="$(git diff --cached --name-only || true)"
if echo "$CHANGED" | rg -n "$IMMUTABLE" >/dev/null; then
  echo "ABORT: Archivo inmutable tocado (DEMO o narrativa). Revertí el cambio."
  echo "$CHANGED" | rg -n "$IMMUTABLE" || true
  exit 1
fi
