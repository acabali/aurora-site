# =========================
# AURORA WEB vΩ .gitignore
# =========================

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist/
build/
.out/
.cache/
.astro/

# Vercel
.vercel

# Environment
.env
.env.local
.env.*.local

# Logs
logs
*.log

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Temporary
tmp/
temp/

# Coverage / tests
coverage/

# Local dev artifacts
*.local

# Aurora ops runtime artifacts
ops/*.log
ops/tmp/
ops/cache/

# Ignore generated audit files
aurora_root_audit.log
aurora_deploy.log

# Ignore large assets not meant for repo
*.mp4
*.mov
*.zip
*.tar.gz

# Ignore system caches
.cache-loader
.eslintcache

# Ignore service workers build artifacts
sw.js
sw.js.map

# Mac extended attributes
._*

# Vercel build cache
.vercel/cache

# Astro generated types
src/env.d.ts

# Ignore local CLI artifacts
*.pid
*.seed
*.pid.lock
.env*.local
